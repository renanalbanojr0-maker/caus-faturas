<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Faturas Caus Site</title>

<style>
body::before{content:'';}
@page{size:A4;margin:0}
body{margin:0;background:#ececec;font-family:"Times New Roman",serif;color:#000}

.topbar{
position:fixed;
top:0; left:0; right:0;
background:#111;
padding:12px;
display:flex;
gap:10px;
justify-content:center;
align-items:center;
z-index:99999;
}

.topbar button{
padding:10px 16px;
border:none;
border-radius:8px;
font-size:15px;
cursor:pointer;
color:#fff;
font-weight:700;
}

.btnBlue{background:#0d6efd;}
.btnGreen{background:#198754;}
.btnGray{background:#555;}

.status{
color:#fff;
font-size:16px;
font-weight:700;
margin-left:15px;
}

/* Indicador de conexão Socket.io */
.sync-indicator{
display:inline-flex;
align-items:center;
gap:6px;
color:#fff;
font-size:13px;
font-weight:700;
margin-left:10px;
}
.sync-dot{
width:10px;height:10px;
border-radius:50%;
background:#555;
transition:background .3s;
}
.sync-dot.connected{background:#4caf50;}
.sync-dot.syncing{background:#ff9800;animation:pulse .6s infinite alternate;}
.sync-dot.disconnected{background:#f44336;}
@keyframes pulse{from{opacity:1}to{opacity:.3}}

.wrapper{
padding-top:70px;
padding-bottom:30px;
margin-left:180px;
}

.page{
width:793px;
height:1122px;
background:#fff;
margin:0 auto;
padding:38px 48px;
box-sizing:border-box;
position:relative;
box-shadow:0 0 12px rgba(0,0,0,.15);
overflow:hidden;
}

/* Força TODOS os inputs e textareas da fatura em maiúsculas */
.page input,
.page textarea{
  text-transform: uppercase;
}

/* ── REF FAT (só aparece pro cliente 396) ─────────────────── */
/* Posicionado no canto inferior esquerdo, alinhado verticalmente com o TOTAL.
   Ancorado pelo TOP pra que quando cresça, expanda pra baixo (não pra cima) */
.ref-fat-wrap{
  position:absolute;
  top:862px; /* alinhado verticalmente com o TOTAL (que está em bottom:232px) */
  left:48px;
  display:flex;
  flex-direction:column;
  align-items:flex-start;
  gap:4px;
  z-index:3;
  width:340px;
}
.ref-fat-label{
  font-weight:700;
  font-size:13px;
  color:#08224f;
  white-space:nowrap;
}
.ref-fat-inputs{
  display:grid;
  grid-template-columns: repeat(5, 60px); /* 5 colunas fixas */
  gap:5px;
  width:100%;
}
.ref-fat-box{
  width:60px;
  height:28px;
  border:1.4px solid #08224f;
  border-radius:3px;
  font-size:16px;
  font-family:inherit;
  font-weight:700;
  color:#c0392b; /* vermelho nos números digitados */
  text-align:center;
  padding:0 3px;
  box-sizing:border-box;
  outline:none;
  background:#fff;
}
.ref-fat-box:focus{
  border-color:#0077ff;
  background:#f0f7ff;
}

/* Na impressão física (@media print) o REF FAT não aparece.
   O PDF é gerado via html2canvas, então fica visível no PDF normalmente. */
@media print {
  .ref-fat-wrap{
    display:none !important;
  }
}
/* Esconde REF FAT na impressão e na geração do PDF */
@media print {
  .ref-fat-wrap{ display:none !important; }
}
.gerando-pdf .ref-fat-wrap{ display:none !important; }

/* ── VIA DE CLIENTE (modo especial pra vendas do e-commerce/Tiny) ─── */
/* Campo Nº NF no topo esquerdo (em vermelho) */
.vc-nf-wrap{
  position:absolute;
  top:12px;
  left:30px;
  display:none;
  align-items:center;
  gap:6px;
  z-index:4;
}
.vc-nf-label{
  font-weight:700;
  font-size:16px;
  color:#c0392b;
  white-space:nowrap;
}
.vc-nf-input{
  border:none;
  border-bottom:1px solid #333;
  background:transparent;
  font-size:16px;
  font-weight:700;
  color:#c0392b;
  width:140px;
  outline:none;
  padding:0 2px;
  font-family:inherit;
}
.vc-btn-buscar-nf{
  background:#6c5ce7;
  color:#fff;
  border:none;
  border-radius:6px;
  padding:4px 10px;
  font-size:12px;
  font-weight:700;
  cursor:pointer;
  font-family:inherit;
  margin-left:6px;
  box-shadow:0 2px 4px rgba(108,92,231,0.3);
  transition:all 0.15s ease;
}
.vc-btn-buscar-nf:hover{
  background:#5b4ecf;
  transform:translateY(-1px);
  box-shadow:0 3px 6px rgba(108,92,231,0.45);
}
.vc-btn-buscar-nf:disabled{
  background:#999;
  cursor:not-allowed;
  transform:none;
}
.vc-btn-debug-nf{
  background:#f39c12;
  color:#fff;
  border:none;
  border-radius:6px;
  padding:4px 8px;
  font-size:11px;
  font-weight:700;
  cursor:pointer;
  font-family:inherit;
  margin-left:4px;
  box-shadow:0 2px 4px rgba(243,156,18,0.3);
  transition:all 0.15s ease;
}
.vc-btn-debug-nf:hover{
  background:#e67e22;
  transform:translateY(-1px);
}
.vc-btn-debug-nf:disabled{
  background:#999;
  cursor:not-allowed;
  transform:none;
}
/* Esconde os botões na impressão e no PDF — só aparece na tela */
@media print {
  .vc-btn-buscar-nf, .vc-btn-debug-nf{ display:none !important; }
}
.gerando-pdf .vc-btn-buscar-nf,
.gerando-pdf .vc-btn-debug-nf{ display:none !important; }

/* Campo Cód Cliente no topo direito (em vermelho) */
.vc-cod-wrap{
  position:absolute;
  top:12px;
  right:70px;
  display:none;
  align-items:center;
  gap:6px;
  z-index:4;
}
.vc-cod-label{
  font-weight:700;
  font-size:16px;
  color:#c0392b;
  white-space:nowrap;
}
.vc-cod-input{
  border:none;
  border-bottom:1px solid #333;
  background:transparent;
  font-size:16px;
  font-weight:700;
  color:#c0392b;
  width:150px;
  outline:none;
  padding:0 2px;
  font-family:inherit;
}
.vc-cod-btn-confirmar{
  background:#27ae60;
  color:#fff;
  border:none;
  border-radius:50%;
  width:24px;
  height:24px;
  padding:0;
  font-size:14px;
  font-weight:900;
  cursor:pointer;
  font-family:inherit;
  margin-left:4px;
  box-shadow:0 2px 4px rgba(39,174,96,0.4);
  transition:all 0.15s ease;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  line-height:1;
}
.vc-cod-btn-confirmar:hover{
  background:#229954;
  transform:scale(1.1);
}
.vc-cod-btn-confirmar:disabled{
  background:#95a5a6;
  cursor:not-allowed;
  transform:none;
}
/* Esconde o botão quando Cód já foi confirmado */
.vc-cod-btn-confirmar.confirmado{
  display:none;
}
/* Esconde o botão na impressão e no PDF */
@media print {
  .vc-cod-btn-confirmar{ display:none !important; }
}
.gerando-pdf .vc-cod-btn-confirmar{ display:none !important; }

/* Campo OBS grande (retângulo vermelho à esquerda do TOTAL) */
.vc-obs-wrap{
  position:absolute;
  top:862px;
  left:48px;
  display:none;
  flex-direction:column;
  align-items:flex-start;
  gap:4px;
  z-index:3;
  width:300px;
}
.vc-obs-label{
  font-weight:700;
  font-size:16px;
  color:#c0392b;
  white-space:nowrap;
}
.vc-obs-textarea{
  width:100%;
  height:85px;
  border:2px solid #c0392b;
  background:transparent;
  font-size:15px;
  font-weight:600;
  font-family:inherit;
  color:#08224f;
  padding:5px 7px;
  resize:none;
  outline:none;
  box-sizing:border-box;
  text-transform:uppercase;
  line-height:1.3;
}

/* Ativa os campos quando a página está em modo "via de cliente" */
.page.via-cliente .vc-nf-wrap,
.page.via-cliente .vc-cod-wrap{
  display:flex;
}
.page.via-cliente .vc-obs-wrap{
  display:flex;
}

/* Na impressão e PDF, mostra os valores mas sem bordas dos inputs */
@media print {
  .page.via-cliente .vc-nf-input,
  .page.via-cliente .vc-cod-input{
    border-bottom:none;
  }
  /* Esconde o container inteiro quando o campo estiver vazio */
  .page.via-cliente .vc-nf-wrap.vazio,
  .page.via-cliente .vc-cod-wrap.vazio{
    display:none !important;
  }
}

/* Quando gera PDF: se o campo NF ou Cód estiver vazio, esconde tudo (label + input) */
.gerando-pdf .vc-nf-wrap.vazio,
.gerando-pdf .vc-cod-wrap.vazio{
  display:none !important;
}


/* Destaque de campo obrigatório vazio ao tentar finalizar */
.campo-obrigatorio-vazio{
  background:rgba(192,57,43,0.18) !important;
  border-bottom:2px solid #c0392b !important;
  animation: piscar-obrigatorio 1.2s ease-in-out 2;
}
@keyframes piscar-obrigatorio {
  0%, 100% { background:rgba(192,57,43,0.18); }
  50% { background:rgba(192,57,43,0.45); }
}

/* ── PAINEL LATERAL DE BUSCA E FILTRO ─────────────────────── */
.painel-busca-overlay{
  position:fixed;
  top:0; left:0; right:0; bottom:0;
  background:rgba(0,0,0,0.35);
  z-index:99995;
  display:none;
  animation: fade-in 0.2s ease;
}
.painel-busca-overlay.ativo{
  display:block;
}
.painel-busca{
  position:absolute;
  top:0; right:0; bottom:0;
  width:420px;
  max-width:95vw;
  background:#fff;
  box-shadow:-4px 0 20px rgba(0,0,0,0.2);
  display:flex;
  flex-direction:column;
  animation: slide-in 0.25s ease;
}
@keyframes slide-in {
  from { transform: translateX(100%); }
  to   { transform: translateX(0); }
}
@keyframes fade-in {
  from { opacity: 0; }
  to   { opacity: 1; }
}
.painel-busca-header{
  background:#6c5ce7;
  color:white;
  padding:14px 18px;
  display:flex;
  justify-content:space-between;
  align-items:center;
}
.painel-busca-header h3{
  margin:0;
  font-size:16px;
  font-weight:600;
}
.painel-fechar{
  background:transparent;
  border:none;
  color:white;
  font-size:20px;
  cursor:pointer;
  padding:4px 10px;
  border-radius:4px;
  transition:background 0.15s;
}
.painel-fechar:hover{ background:rgba(255,255,255,0.2); }

.painel-busca-body{
  padding:18px;
  overflow-y:auto;
  flex:1;
}
.painel-secao{ margin-bottom:4px; }
.painel-label{
  display:block;
  font-size:12px;
  font-weight:600;
  color:#333;
  margin-bottom:6px;
  text-transform:uppercase;
  letter-spacing:0.3px;
}
.painel-input{
  width:100%;
  padding:8px 10px;
  border:1.5px solid #ddd;
  border-radius:6px;
  font-size:14px;
  font-family:inherit;
  box-sizing:border-box;
  outline:none;
  transition:border-color 0.15s;
}
.painel-input:focus{ border-color:#6c5ce7; }

.btn-painel{
  padding:8px 14px;
  border:none;
  background:#6c5ce7;
  color:white;
  border-radius:6px;
  font-weight:600;
  cursor:pointer;
  font-size:13px;
  font-family:inherit;
}
.btn-painel:hover{ opacity:0.9; }

.btn-painel-pill{
  padding:5px 12px;
  border:1.5px solid #6c5ce7;
  background:white;
  color:#6c5ce7;
  border-radius:20px;
  font-weight:600;
  cursor:pointer;
  font-size:12px;
  font-family:inherit;
}
.btn-painel-pill:hover{
  background:#6c5ce7;
  color:white;
}

.painel-divider{
  height:1px;
  background:#e5e5e5;
  margin:16px 0;
}

.painel-resultados{
  max-height:50vh;
  overflow-y:auto;
  display:flex;
  flex-direction:column;
  gap:6px;
}
.resultado-item{
  padding:10px 12px;
  border:1.5px solid #e5e5e5;
  border-radius:6px;
  cursor:pointer;
  transition:all 0.15s;
  background:#fafafa;
}
.resultado-item:hover{
  border-color:#6c5ce7;
  background:#f4f1ff;
  transform:translateX(-2px);
}
.resultado-item .res-numero{
  font-weight:700;
  font-size:14px;
  color:#2d3436;
}
.resultado-item .res-info{
  font-size:12px;
  color:#636e72;
  margin-top:3px;
}
.resultado-item .res-status{
  display:inline-block;
  padding:1px 6px;
  border-radius:3px;
  font-size:10px;
  font-weight:700;
  margin-left:6px;
  text-transform:uppercase;
}
.res-status.aberto{ background:#fff3cd; color:#856404; }
.res-status.finalizada{ background:#d4edda; color:#155724; }
.res-status.conferida{ background:#cfe2ff; color:#084298; }
.res-status.via-cliente{
  background:linear-gradient(135deg,#6c5ce7,#8e7dff);
  color:#fff;
  margin-left:4px;
}

.painel-vazio{
  text-align:center;
  color:#95a5a6;
  padding:20px;
  font-size:13px;
  font-style:italic;
}

/* Marca d'água de conferência — aparece quando a fatura é conferida */
.marca-conferida{
  position:absolute;
  top:50%;
  left:50%;
  transform:translate(-50%,-50%);
  font-family:'Arial Black', 'Helvetica', sans-serif;
  font-weight:900;
  font-size:78px;
  color:rgba(40,167,69,0.22);
  text-align:center;
  white-space:nowrap;
  pointer-events:none;
  line-height:1;
  letter-spacing:4px;
  user-select:none;
  z-index:5;
  text-shadow:2px 2px 0 rgba(40,167,69,0.08);
}
.marca-conferida .mc-nome{
  display:block;
  font-size:60px;
  margin-top:10px;
  letter-spacing:6px;
}
.marca-conferida .mc-data{
  display:block;
  font-size:36px;
  margin-top:10px;
  font-family:'Arial', sans-serif;
  font-weight:700;
  letter-spacing:3px;
}

/* Marca d'água menor no topo da fatura (mesma cor, mesmo formato, menor) */
.marca-conferida-topo{
  position:absolute;
  top:160px;
  left:50%;
  transform:translateX(-50%);
  font-family:'Arial Black', 'Helvetica', sans-serif;
  font-weight:900;
  font-size:78px;
  color:rgba(40,167,69,0.22);
  text-align:center;
  white-space:nowrap;
  pointer-events:none;
  line-height:1;
  letter-spacing:4px;
  user-select:none;
  z-index:5;
  text-shadow:2px 2px 0 rgba(40,167,69,0.08);
}
.marca-conferida-topo .mc-nome{
  display:block;
  font-size:60px;
  margin-top:10px;
  letter-spacing:6px;
}
.marca-conferida-topo .mc-data{
  display:block;
  font-size:36px;
  margin-top:10px;
  font-family:'Arial', sans-serif;
  font-weight:700;
  letter-spacing:3px;
}

.row{display:flex;align-items:flex-end;gap:6px;margin:2px 0;font-size:17px;line-height:1}
.label{font-weight:700}
.line{border:none;border-bottom:1px solid #000;height:22px;font-size:17px;font-family:inherit;padding:0 2px;outline:none;color:#08224f;font-weight:600;background:transparent}
.line:focus{background:#f8f8f8}
.xs{width:42px}.sm{width:70px}.md{width:92px}.lg{width:220px}.flex{flex:1}
.topspace{margin-top:8px}
.centerTitle{position:absolute;top:38px;left:330px;font-size:24px;font-weight:700}
.client{position:absolute;top:44px;right:48px;font-size:17px;font-weight:700}
.boxInput{width:16px;height:16px;border:1px solid #000;vertical-align:middle;margin:0 5px;text-align:center;font-size:12px;padding:0;line-height:16px;font-family:inherit;color:#08224f;font-weight:600}
.obs{margin-top:8px}
.brace{font-size:72px;line-height:.6;margin-right:6px;margin-top:-8px}
.table{width:100%;border-collapse:collapse;margin-top:8px;font-size:17px;}
.table th,.table td{border:1.2px solid #000;height:29px}.table td:nth-child(2){height:auto;min-height:29px;}
.table th{font-weight:700}
.table input{width:100%;height:100%;border:none;font-size:17px;font-family:inherit;padding:0 4px;box-sizing:border-box;color:#08224f;font-weight:600;text-align:center}
.table td:nth-child(2) textarea.discArea{
width:100%;border:none;font-size:17px;font-family:inherit;
padding:2px 4px 2px 6px;box-sizing:border-box;color:#08224f;
font-weight:600;text-align:left;resize:none;overflow:hidden;
line-height:1.4;background:transparent;outline:none;
display:block;min-height:27px;
}
.table td:nth-child(2) textarea.discArea:focus{background:#f8f8f8;}
.table td:nth-child(2) textarea.discArea:disabled{background:#f3f3f3;color:#999;}


.note{position:absolute;left:58px;bottom:122px;font-size:14px;font-weight:700;width:420px}
.totalWrap{position:absolute;right:48px;bottom:232px;display:flex;align-items:center;}
.totalLbl{font-size:20px;font-weight:700;margin-right:8px;}
.signs{position:absolute;left:48px;right:48px;bottom:36px;display:flex;justify-content:space-between}
.sig{width:260px;text-align:center;font-size:17px}

/* ── AUTOCOMPLETE DE PRODUTOS ────────────────────────────────── */
.autocomplete-wrap{position:relative;}
.autocomplete-lista{
position:absolute;top:100%;left:0;right:0;
background:#fff;border:1.5px solid #0d6efd;
border-radius:0 0 6px 6px;z-index:99998;
max-height:200px;overflow-y:auto;
box-shadow:0 4px 12px rgba(0,0,0,.15);
font-family:"Times New Roman",serif;
}
.autocomplete-item{
padding:6px 10px;font-size:14px;cursor:pointer;
border-bottom:1px solid #eee;color:#08224f;font-weight:600;
}
.autocomplete-item:hover,.autocomplete-item.ativo{background:#e8f0fe;}
.autocomplete-codigo{color:#888;font-size:12px;margin-right:6px;font-weight:400;}

/* ── LISTA LATERAL DE CLIENTES ──────────────────────────────── */
.lista-clientes{
position:fixed;
top:70px;
left:0;
width:180px;
background:#f5f5f5;
color:#222;
font-family:"Times New Roman",serif;
font-size:13px;
padding:8px 0;
z-index:9999;
height:calc(100vh - 70px);
overflow-y:auto;
border-right:1px solid #ddd;
}
.lista-clientes-titulo{
font-weight:700;
font-size:11px;
color:#888;
padding:6px 12px 4px;
border-bottom:1px solid #ddd;
margin-bottom:4px;
letter-spacing:1px;
text-transform:uppercase;
}
.lista-clientes-item{
padding:4px 12px;
border-bottom:1px solid #e8e8e8;
line-height:1.3;
cursor:default;
}
.lista-clientes-item:hover{background:#eaeaea;}
.lista-clientes-cod{color:#08224f;font-weight:700;margin-right:4px;}
.lista-clientes-cidade{color:#333;}

@media print{
.lista-clientes{display:none!important;}
}

/* ── MODAL DE IMPRESSÃO (Chrome) ────────────────────────────── */
.modal-print-overlay{
display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);
z-index:999999;justify-content:center;align-items:center;
}
.modal-print-overlay.ativo{display:flex;}
.modal-print-box{
background:#fff;border-radius:12px;padding:32px 36px;
width:340px;box-shadow:0 8px 32px rgba(0,0,0,.3);
font-family:"Times New Roman",serif;text-align:center;
}
.modal-print-box h3{margin:0 0 10px;font-size:20px;color:#111;}
.modal-print-box p{font-size:14px;color:#555;margin:0 0 24px;}
.modal-print-btns{display:flex;flex-direction:column;gap:10px;}
.modal-print-btns button{
padding:12px;border:none;border-radius:8px;
font-size:15px;font-weight:700;cursor:pointer;color:#fff;
}
.btn-salvar-pdf{background:#0d6efd;}
.btn-imprimir{background:#198754;}
.btn-fechar-print{background:#888;}

@media print{.modal-print-overlay{display:none!important;}}

/* ── MODAL DE LOGIN ──────────────────────────────────────────── */
.modal-overlay{
display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);
z-index:999999;justify-content:center;align-items:center;
}
.modal-overlay.ativo{display:flex;}
.modal-box{
background:#fff;border-radius:12px;padding:32px 36px;
width:320px;box-shadow:0 8px 32px rgba(0,0,0,.3);font-family:"Times New Roman",serif;
}
.modal-box h3{margin:0 0 20px;font-size:20px;text-align:center;color:#111;}
.modal-box label{display:block;font-weight:700;font-size:14px;margin-bottom:4px;color:#333;}
.modal-box input[type=text],
.modal-box input[type=password]{
width:100%;box-sizing:border-box;padding:8px 10px;
border:1.5px solid #ccc;border-radius:6px;font-size:15px;
margin-bottom:14px;outline:none;font-family:inherit;
}
.modal-box input:focus{border-color:#0d6efd;}
.modal-erro{color:#c0392b;font-size:13px;font-weight:700;margin-bottom:10px;display:none;text-align:center;}
.modal-btns{display:flex;gap:10px;margin-top:4px;}
.modal-btns button{flex:1;padding:10px;border:none;border-radius:8px;font-size:15px;font-weight:700;cursor:pointer;color:#fff;}
.modal-confirmar{background:#0d6efd;}
.modal-cancelar{background:#888;}

@media print{
.topbar{display:none!important;}
.lista-clientes{display:none!important;}
.modal-overlay{display:none!important;}
body{background:#fff;margin:0;padding:0;}
.wrapper{padding:0;margin:0;}
.page{
    box-shadow:none;
    margin:0 auto;
    width:210mm;
    height:297mm;
    padding:10mm 13mm;
}
/* Garante texto preto nos inputs e textareas */
input, textarea{
    color:#000 !important;
    -webkit-print-color-adjust:exact;
    print-color-adjust:exact;
    background:transparent !important;
}
/* Remove borda de foco */
input:focus, textarea:focus{
    background:transparent !important;
}
}
</style>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
</head>
<body>

<!-- ── TELA DE LOGIN ── -->
<style>
@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&display=swap');

#telaLogin {
  position:fixed;inset:0;z-index:9999999;
  display:flex;align-items:stretch;
  font-family:'DM Sans',sans-serif;
  overflow:hidden;
}

/* ── LADO ESQUERDO ── */
.login-left {
  flex:1;background:#050508;
  position:relative;display:flex;flex-direction:column;
  justify-content:flex-end;padding:60px;overflow:hidden;
}

/* Grade animada */
.login-grid {
  position:absolute;inset:0;
  background-image:
    linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
  background-size:44px 44px;
  animation:gridMove 25s linear infinite;
}
@keyframes gridMove{from{background-position:0 0}to{background-position:44px 44px}}

/* Partículas flutuantes */
.login-particles {
  position:absolute;inset:0;overflow:hidden;pointer-events:none;
}
.lp {
  position:absolute;border-radius:50%;
  animation:float linear infinite;
  opacity:0;
}
@keyframes float {
  0%{transform:translateY(100vh) scale(0);opacity:0}
  10%{opacity:1}
  90%{opacity:.6}
  100%{transform:translateY(-100px) scale(1.2);opacity:0}
}

/* Orbs de luz */
.login-orb1 {
  position:absolute;width:700px;height:700px;
  background:radial-gradient(circle, rgba(13,110,253,.15) 0%, transparent 65%);
  top:-200px;right:-200px;pointer-events:none;
  animation:orbPulse 6s ease-in-out infinite;
}
.login-orb2 {
  position:absolute;width:400px;height:400px;
  background:radial-gradient(circle, rgba(99,102,241,.1) 0%, transparent 65%);
  bottom:-100px;left:-100px;pointer-events:none;
  animation:orbPulse 8s ease-in-out infinite reverse;
}
@keyframes orbPulse{0%,100%{transform:scale(1)}50%{transform:scale(1.15)}}

/* Linha decorativa animada */
.login-line {
  position:absolute;top:0;right:0;width:1px;height:100%;
  background:linear-gradient(to bottom,
    transparent 0%, rgba(13,110,253,.4) 30%,
    rgba(13,110,253,.8) 50%,
    rgba(13,110,253,.4) 70%, transparent 100%);
  animation:lineScan 4s ease-in-out infinite;
}
@keyframes lineScan{0%,100%{opacity:.3}50%{opacity:1}}

.login-brand { position:relative;z-index:1; }

.login-tag {
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(13,110,253,.12);
  border:1px solid rgba(13,110,253,.25);
  padding:6px 16px;border-radius:99px;
  font-size:10px;font-weight:600;letter-spacing:.15em;
  text-transform:uppercase;color:#6ea8fe;margin-bottom:28px;
}
.login-tag-dot {
  width:6px;height:6px;background:#6ea8fe;border-radius:50%;
  box-shadow:0 0 8px #6ea8fe;
  animation:blink 2s ease infinite;
}
@keyframes blink{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.3;transform:scale(.8)}}

.login-title {
  font-family:'Bebas Neue',sans-serif;
  font-size:88px;line-height:.88;
  color:#fff;letter-spacing:3px;margin-bottom:32px;
  text-shadow:0 0 80px rgba(13,110,253,.3);
}
.login-title .accent { color:#0d6efd;position:relative; }
.login-title .accent::after {
  content:'';position:absolute;bottom:-4px;left:0;right:0;
  height:3px;background:#0d6efd;
  box-shadow:0 0 12px #0d6efd;
  animation:underlinePulse 2s ease infinite;
}
@keyframes underlinePulse{0%,100%{opacity:.6}50%{opacity:1}}

/* Contador de versão estilo terminal */
.login-name-big {
  font-family:'Bebas Neue',sans-serif;
  font-size:96px;line-height:1;
  letter-spacing:8px;
  color:transparent;
  -webkit-text-stroke:1.5px rgba(59,130,246,.5);
  position:relative;z-index:1;
  margin-bottom:24px;
  animation:namePulse 2.5s ease-in-out infinite;
  user-select:none;
}
@keyframes namePulse{
  0%,100%{
    -webkit-text-stroke:1.5px rgba(59,130,246,.3);
    text-shadow:none;
    opacity:.5;
  }
  50%{
    -webkit-text-stroke:1.5px rgba(59,130,246,1);
    text-shadow:0 0 30px rgba(59,130,246,.8), 0 0 60px rgba(59,130,246,.4);
    opacity:1;
  }
}

.login-terminal {
  display:inline-flex;align-items:center;gap:10px;
  background:rgba(255,255,255,.04);
  border:1px solid rgba(255,255,255,.08);
  border-radius:8px;padding:10px 16px;
  font-size:12px;color:rgba(255,255,255,.4);
  font-family:monospace;letter-spacing:.05em;
}
.login-terminal .cursor {
  width:8px;height:14px;background:rgba(13,110,253,.8);
  animation:cursorBlink .8s step-end infinite;
}
@keyframes cursorBlink{0%,100%{opacity:1}50%{opacity:0}}

/* ── LADO DIREITO ── */
.login-right {
  width:440px;flex-shrink:0;
  background:#fff;
  display:flex;flex-direction:column;justify-content:center;
  padding:60px 52px;position:relative;
}

.login-right::before {
  content:'';position:absolute;top:0;left:0;bottom:0;width:1px;
  background:linear-gradient(to bottom,
    transparent, #dbeafe 25%, #bfdbfe 50%, #dbeafe 75%, transparent);
}

/* Círculo decorativo no canto */
.login-right::after {
  content:'';position:absolute;
  width:300px;height:300px;border-radius:50%;
  background:radial-gradient(circle, rgba(219,234,254,.5) 0%, transparent 70%);
  top:-100px;right:-100px;pointer-events:none;
}

.login-form-eyebrow {
  font-size:11px;font-weight:600;letter-spacing:.12em;
  text-transform:uppercase;color:#93c5fd;margin-bottom:10px;
}
.login-form-title {
  font-size:28px;font-weight:600;color:#0f172a;
  letter-spacing:-.6px;margin-bottom:4px;
  animation:slideUp .4s ease both;
}
.login-form-sub {
  font-size:14px;color:#94a3b8;margin-bottom:44px;
  animation:slideUp .4s .05s ease both;
}
@keyframes slideUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}

.login-field {
  margin-bottom:20px;position:relative;
  animation:slideUp .4s ease both;
}
.login-field:nth-child(1){animation-delay:.1s}
.login-field:nth-child(2){animation-delay:.15s}

.login-field label {
  display:block;font-size:11px;font-weight:700;
  color:#64748b;letter-spacing:.08em;
  text-transform:uppercase;margin-bottom:8px;
}
.login-field input {
  width:100%;padding:14px 16px 14px 46px;
  border:1.5px solid #e2e8f0;border-radius:12px;
  font-size:15px;font-family:'DM Sans',sans-serif;
  color:#0f172a;outline:none;box-sizing:border-box;
  background:#f8fafc;
  transition:all .2s ease;
}
.login-field input:focus {
  border-color:#3b82f6;background:#fff;
  box-shadow:0 0 0 4px rgba(59,130,246,.08);
}
.login-field input::placeholder{color:#cbd5e1;}

/* Ícone dentro do input */
.login-field-icon {
  position:absolute;left:16px;bottom:14px;
  width:18px;height:18px;color:#94a3b8;pointer-events:none;
  transition:color .2s;
}
.login-field input:focus ~ .login-field-icon { color:#3b82f6; }

#loginErroMsg {
  display:none;
  background:#fef2f2;border:1.5px solid #fecaca;
  color:#dc2626;font-size:13px;font-weight:500;
  padding:11px 14px;border-radius:10px;
  margin-bottom:16px;
  animation:shake .3s ease;
}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-6px)}75%{transform:translateX(6px)}}

.login-btn {
  width:100%;padding:15px;
  background:linear-gradient(135deg, #1d4ed8, #2563eb, #3b82f6);
  background-size:200% 200%;
  color:#fff;border:none;border-radius:12px;
  font-size:15px;font-weight:600;
  font-family:'DM Sans',sans-serif;
  cursor:pointer;letter-spacing:.3px;
  position:relative;overflow:hidden;
  transition:transform .2s, box-shadow .2s;
  box-shadow:0 4px 24px rgba(37,99,235,.4);
  animation:slideUp .4s .2s ease both;
}
.login-btn::before {
  content:'';position:absolute;inset:0;
  background:linear-gradient(rgba(255,255,255,.15),transparent 60%);
}
.login-btn::after {
  content:'';position:absolute;
  width:100px;height:100%;top:0;left:-120px;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,.2),transparent);
  animation:shimmer 3s ease infinite 1s;
}
@keyframes shimmer{to{left:120%}}
.login-btn:hover {
  transform:translateY(-2px);
  box-shadow:0 8px 32px rgba(37,99,235,.5);
}
.login-btn:active{transform:translateY(0);}

.login-footer {
  margin-top:36px;padding-top:20px;
  border-top:1px solid #f1f5f9;
  display:flex;justify-content:space-between;align-items:center;
  animation:slideUp .4s .25s ease both;
}
.login-footer-brand {
  font-size:12px;color:#94a3b8;font-weight:500;
}
.login-footer-sig {
  font-size:11px;color:#cbd5e1;
  font-family:monospace;letter-spacing:.05em;
}
.login-footer-sig span { color:#3b82f6; }

/* ── RESPONSIVO LOGIN ── */
@media(max-width:720px){
  #telaLogin{
    flex-direction:column;
    height:100dvh;
    overflow-y:auto;
  }
  .login-left{
    flex:none;
    height:auto;
    padding:24px 24px 20px;
    justify-content:flex-start;
  }
  .login-name-big{font-size:52px;margin-bottom:10px;}
  .login-title{font-size:48px;margin-bottom:10px;}
  .login-tag{margin-bottom:12px;font-size:9px;}
  .login-terminal{display:none;}
  .login-orb1,.login-orb2{display:none;}
  .login-grid{display:none;}
  .login-line{display:none;}
  /* Formulário ocupa o resto da tela */
  .login-right{
    width:100%;
    flex:1;
    padding:24px 24px 28px;
    justify-content:flex-start;
    overflow-y:auto;
  }
  .login-right::before,.login-right::after{display:none;}
  .login-form-eyebrow{margin-bottom:6px;}
  .login-form-title{font-size:22px;margin-bottom:4px;}
  .login-form-sub{font-size:13px;margin-bottom:24px;}
  .login-field{margin-bottom:14px;}
  .login-field input{padding:12px 14px 12px 42px;font-size:16px;}
  .login-btn{padding:14px;font-size:16px;}
  .login-footer{margin-top:20px;padding-top:16px;}
}
@media(max-width:400px){
  .login-title{font-size:38px;}
  .login-name-big{font-size:40px;}
  .login-left{padding:20px;}
  .login-right{padding:20px;}
}
</style>

<div id="telaLogin">
  <!-- Esquerda -->
  <div class="login-left">
    <div class="login-grid"></div>
    <div class="login-particles" id="loginParticles"></div>
    <div class="login-orb1"></div>
    <div class="login-orb2"></div>
    <div class="login-line"></div>

    <div class="login-brand">
      <div class="login-tag">
        <div class="login-tag-dot"></div>
        Sistema Online
      </div>
      <div class="login-title">
        CAUS<br><span class="accent">FATURAS</span>
      </div>

      <!-- Nome grande piscando -->
      <div class="login-name-big">R3N4N</div>

      <div class="login-terminal">
        <span>v2.0.0 · build_2026</span>
        <div class="cursor"></div>
      </div>
    </div>
  </div>

  <!-- Direita -->
  <div class="login-right">
    <div class="login-form-eyebrow">Área restrita</div>
    <div class="login-form-title">Bem-vindo de volta</div>
    <div class="login-form-sub">Informe suas credenciais para acessar</div>

    <div class="login-field">
      <label>Usuário</label>
      <input type="text" id="loginUser" placeholder="Digite seu usuário" autocomplete="off"
        onkeydown="if(event.key==='Enter') document.getElementById('loginPass').focus()">
      <svg class="login-field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
      </svg>
    </div>

    <div class="login-field">
      <label>Senha</label>
      <input type="password" id="loginPass" placeholder="••••••••"
        onkeydown="if(event.key==='Enter') fazerLogin()">
      <svg class="login-field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>
      </svg>
    </div>

    <div id="loginErroMsg">⚠️ Usuário ou senha incorretos.</div>

    <button class="login-btn" onclick="fazerLogin()">Entrar no Sistema →</button>

    <div class="login-footer">
      <span class="login-footer-brand">Caus Site Móveis</span>
      <span class="login-footer-sig">By: <span>R3N4N</span></span>
    </div>
  </div>
</div>

<script>
// Gera partículas flutuantes no lado esquerdo
(function(){
  const wrap = document.getElementById('loginParticles');
  if(!wrap) return;
  const colors = ['rgba(59,130,246,.6)','rgba(99,102,241,.5)','rgba(147,197,253,.4)'];
  for(let i=0;i<18;i++){
    const p = document.createElement('div');
    p.className = 'lp';
    const size = Math.random()*4+2;
    p.style.cssText = `
      width:${size}px;height:${size}px;
      left:${Math.random()*100}%;
      background:${colors[Math.floor(Math.random()*colors.length)]};
      animation-duration:${Math.random()*12+8}s;
      animation-delay:${Math.random()*8}s;
      box-shadow:0 0 ${size*3}px currentColor;
    `;
    wrap.appendChild(p);
  }
})();
</script>

<div id="sistemaCompleto" style="display:none"><div class="topbar">
<img src="data:image/png;base64," style="height:40px;width:40px;object-fit:contain;border-radius:8px;margin-right:6px;flex-shrink:0;" alt="Caus">
<button class="btnGray" onclick="faturaAnterior()">⬅ Anterior</button>
<button class="btnBlue" onclick="proximaFatura()">Próximo ➡</button>
<button class="btnBlue" onclick="abrirPainelBusca()" style="background:#6c5ce7;">🔎 Buscar / Filtrar</button>
<button class="btnGreen" onclick="gerarPDF()">Gerar PDF</button>
<button class="btnBlue" onclick="abrirModalEditar()" id="btnEditar" style="background:#e67e22;">✏️ Editar</button>
<button class="btnGreen" onclick="abrirModalConferencia()" id="btnConferencia" style="background:#198754;">🔍 Conferência</button>
<button class="btnGray" onclick="abrirModalReset()" style="background:#c0392b;">🗑 Zerar Tudo</button>
<div class="status" id="statusFatura"></div>
<div class="sync-indicator">
  <div class="sync-dot disconnected" id="syncDot"></div>
  <span id="syncLabel">Desconectado</span>
</div>
<span id="versaoLabel" style="font-size:10px;color:#555;margin-left:8px;font-family:monospace;"></span>
</div>

<div class="lista-clientes">
  <div class="lista-clientes-titulo">Clientes</div>
  <div id="listaClientesItens"></div>
  <div style="padding:12px 10px;border-top:2px solid #e0e0e0;margin-top:10px;">
    <button onclick="abrirCalculadora()" id="btnCalc" style="
      width:100%;
      padding:12px 8px;
      background:linear-gradient(135deg,#1a6b2e,#27ae60);
      color:#fff;
      border:none;
      border-radius:10px;
      font-size:12px;
      font-weight:700;
      cursor:pointer;
      font-family:'Times New Roman',serif;
      line-height:1.5;
      letter-spacing:0.5px;
      box-shadow:0 3px 10px rgba(26,107,46,0.35);
      transition:all 0.2s ease;
      display:flex;
      flex-direction:column;
      align-items:center;
      gap:4px;
    "
    onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 6px 16px rgba(26,107,46,0.45)'"
    onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 3px 10px rgba(26,107,46,0.35)'"
    >
      <span style="font-size:22px;line-height:1">📊</span>
      <span style="font-size:11px;letter-spacing:1px;opacity:0.85;font-weight:600">PRECIFICAÇÃO</span>
      <span style="font-size:13px;font-weight:800">Calculadora NFs</span>
    </button>

    <!-- Botão Via de Cliente (modo e-commerce) -->
    <button onclick="toggleViaCliente()" id="btnToggleViaCliente" style="
      width:100%;
      margin-top:10px;
      padding:12px 8px;
      background:linear-gradient(135deg,#6c5ce7,#8e7dff);
      color:#fff;
      border:none;
      border-radius:10px;
      font-size:12px;
      font-weight:700;
      cursor:pointer;
      font-family:'Times New Roman',serif;
      line-height:1.5;
      letter-spacing:0.5px;
      box-shadow:0 3px 10px rgba(108,92,231,0.35);
      transition:all 0.2s ease;
      display:flex;
      flex-direction:column;
      align-items:center;
      gap:4px;
    "
    onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 6px 16px rgba(108,92,231,0.45)'"
    onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 3px 10px rgba(108,92,231,0.35)'"
    >
      <span style="font-size:22px;line-height:1">📋</span>
      <span style="font-size:11px;letter-spacing:1px;opacity:0.85;font-weight:600" id="vcLabelTop">VIA DE CLIENTE</span>
      <span style="font-size:13px;font-weight:800" id="vcLabelBottom">Ativar Modo</span>
    </button>

    <!-- Botão Preenchimento Massivo (lote de NFs do Tiny) -->
    <button onclick="abrirModalMassivo()" id="btnMassivo" style="
      width:100%;
      margin-top:10px;
      padding:12px 8px;
      background:linear-gradient(135deg,#c0392b,#e74c3c);
      color:#fff;
      border:none;
      border-radius:10px;
      font-size:12px;
      font-weight:700;
      cursor:pointer;
      font-family:'Times New Roman',serif;
      line-height:1.5;
      letter-spacing:0.5px;
      box-shadow:0 3px 10px rgba(192,57,43,0.35);
      transition:all 0.2s ease;
      display:flex;
      flex-direction:column;
      align-items:center;
      gap:4px;
    "
    onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 6px 16px rgba(192,57,43,0.45)'"
    onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 3px 10px rgba(192,57,43,0.35)'"
    >
      <span style="font-size:22px;line-height:1">⚡</span>
      <span style="font-size:11px;letter-spacing:1px;opacity:0.85;font-weight:600">PREENCHIMENTO</span>
      <span style="font-size:13px;font-weight:800">Massivo por Data</span>
    </button>
  </div>
</div>

<div class="wrapper">
<div id="pages"></div>
</div>

<!-- Modal de login para edição -->
<div class="modal-overlay" id="modalLogin">
  <div class="modal-box">
    <h3>🔒 Acesso Restrito</h3>
    <label>Usuário</label>
    <input type="text" id="loginUsuario" placeholder="usuário" autocomplete="off">
    <label>Senha</label>
    <input type="password" id="loginSenha" placeholder="senha">
    <div class="modal-erro" id="loginErro">Usuário ou senha incorretos.</div>
    <div class="modal-btns">
      <button class="modal-cancelar" onclick="fecharModalEditar()">Cancelar</button>
      <button class="modal-confirmar" onclick="confirmarLogin()">Entrar</button>
    </div>
  </div>
</div>

<!-- Modal de confirmação de reset -->
<div class="modal-overlay" id="modalReset">
  <div class="modal-box">
    <h3>🗑 Zerar Todos os Dados</h3>
    <label>Usuário</label>
    <input type="text" id="resetUsuario" placeholder="usuário" autocomplete="off">
    <label>Senha</label>
    <input type="password" id="resetSenha" placeholder="senha">
    <div class="modal-erro" id="resetErro">Usuário ou senha incorretos.</div>
    <p style="font-size:13px;color:#c0392b;font-weight:700;text-align:center;margin:0 0 10px;">
      ⚠️ Isso vai apagar TODOS os dados em TODOS os dispositivos!
    </p>
    <div class="modal-btns">
      <button class="modal-cancelar" onclick="fecharModalReset()">Cancelar</button>
      <button class="modal-confirmar" style="background:#c0392b;" onclick="confirmarReset()">Zerar Tudo</button>
    </div>
  </div>
</div>

<!-- Modal de conferência de fatura -->
<div class="modal-overlay" id="modalConferencia">
  <div class="modal-box">
    <h3 id="conferenciaTitulo">🔍 Conferir Fatura</h3>
    <p id="conferenciaDesc" style="font-size:13px;color:#555;text-align:center;margin:0 0 14px;">
      Digite suas credenciais para marcar esta fatura como conferida.
    </p>
    <label>Usuário</label>
    <input type="text" id="confUsuario" placeholder="usuário" autocomplete="off">
    <label>Senha</label>
    <input type="password" id="confSenha" placeholder="senha">
    <div class="modal-erro" id="confErro">Usuário ou senha incorretos.</div>
    <div class="modal-btns">
      <button class="modal-cancelar" onclick="fecharModalConferencia()">Cancelar</button>
      <button class="modal-confirmar" style="background:#198754;" id="btnConfirmarConf" onclick="confirmarConferencia()">Conferir</button>
    </div>
  </div>
</div>

<!-- Modal de aviso customizado (substitui alert() nativo pra não bugar foco no Electron) -->
<div class="modal-overlay" id="modalAviso">
  <div class="modal-box">
    <h3 id="avisoTitulo">⚠️ Atenção</h3>
    <div id="avisoMsg" style="font-size:14px;color:#333;text-align:left;margin:6px 0 18px;white-space:pre-line;line-height:1.5;"></div>
    <div class="modal-btns" style="justify-content:center;">
      <button class="modal-confirmar" style="background:#d97706;min-width:120px;" id="btnConfirmarAviso" onclick="fecharAviso()">OK</button>
    </div>
  </div>
</div>

<!-- Painel lateral de busca e filtro de faturas -->
<div id="painelBusca" class="painel-busca-overlay">
  <div class="painel-busca">
    <div class="painel-busca-header">
      <h3>🔎 Buscar / Filtrar Faturas</h3>
      <button class="painel-fechar" onclick="fecharPainelBusca()">✕</button>
    </div>

    <div class="painel-busca-body">

      <!-- Busca por número -->
      <div class="painel-secao">
        <label class="painel-label">Buscar pelo número da fatura</label>
        <div style="display:flex;gap:6px;">
          <input type="text" id="buscaNumero" class="painel-input"
                 placeholder="ex: 6385" inputmode="numeric"
                 oninput="aplicarFiltroBusca()">
          <button class="btn-painel" onclick="document.getElementById('buscaNumero').value=''; aplicarFiltroBusca();"
                  style="background:#95a5a6;">Limpar</button>
        </div>
      </div>

      <div class="painel-divider"></div>

      <!-- Filtro por período (data) -->
      <div class="painel-secao">
        <label class="painel-label">Filtrar por período (data da fatura)</label>
        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
          <div style="flex:1;min-width:130px;">
            <div style="font-size:11px;color:#777;margin-bottom:2px;">De:</div>
            <input type="date" id="buscaDataInicio" class="painel-input" onchange="aplicarFiltroBusca()">
          </div>
          <div style="flex:1;min-width:130px;">
            <div style="font-size:11px;color:#777;margin-bottom:2px;">Até:</div>
            <input type="date" id="buscaDataFim" class="painel-input" onchange="aplicarFiltroBusca()">
          </div>
        </div>
        <div style="display:flex;gap:6px;margin-top:8px;flex-wrap:wrap;">
          <button class="btn-painel-pill" onclick="aplicarPeriodo('hoje')">Hoje</button>
          <button class="btn-painel-pill" onclick="aplicarPeriodo('ontem')">Ontem</button>
          <button class="btn-painel-pill" onclick="aplicarPeriodo('7dias')">7 dias</button>
          <button class="btn-painel-pill" onclick="aplicarPeriodo('mes')">Este mês</button>
          <button class="btn-painel-pill" onclick="aplicarPeriodo('limpar')" style="background:#95a5a6;">Limpar</button>
        </div>
      </div>

      <div class="painel-divider"></div>

      <!-- Filtro rápido por tipo -->
      <div class="painel-secao">
        <label class="painel-label">Filtro rápido</label>
        <div style="display:flex;gap:6px;flex-wrap:wrap;">
          <button class="btn-painel-pill" id="btnFiltroTodas" onclick="aplicarFiltroTipo('todas')"
                  style="background:#3498db;">Todas</button>
          <button class="btn-painel-pill" id="btnFiltroVC" onclick="aplicarFiltroTipo('via-cliente')"
                  style="background:#6c5ce7;">📋 Via de Cliente</button>
        </div>
      </div>

      <div class="painel-divider"></div>

      <div class="painel-secao">
        <div id="buscaResumo" style="font-size:12px;color:#555;margin-bottom:8px;"></div>
        <div id="buscaResultados" class="painel-resultados"></div>
      </div>

    </div>
  </div>
</div>

<!-- Modal de impressão para Chrome -->
<div class="modal-print-overlay" id="modalImpressao">
  <div class="modal-print-box">
    <h3>🖨️ Fatura Finalizada!</h3>
    <p id="modalImpressaoNumero"></p>
    <p style="font-size:12px;color:#555;margin:0 0 16px;">Imagem salva automaticamente na pasta FaturasPDF.</p>
    <div class="modal-print-btns">
      <button class="btn-imprimir" onclick="imprimirImpressora()">🖨️ Imprimir</button>
    </div>
  </div>
</div>

<!-- Modal de impressora (após salvar PDF) -->
<div class="modal-print-overlay" id="modalImprimir">
  <div class="modal-print-box">
    <h3>🖨️ Deseja imprimir?</h3>
    <p>PDF salvo! Quer enviar para a impressora agora?</p>
    <div class="modal-print-btns">
      <button class="btn-imprimir" onclick="confirmarImprimir()">🖨️ Sim, Imprimir</button>
      <button class="btn-fechar-print" onclick="fecharModalImprimirSemImprimir()">Não, Fechar</button>
    </div>
  </div>
</div>

<!-- Modal de Preenchimento Massivo por data -->
<div class="modal-overlay" id="modalMassivo" style="display:none;">
  <div class="modal-box" style="max-width:520px;">
    <h3>⚡ Preenchimento Massivo</h3>
    <p style="font-size:13px;color:#555;line-height:1.4;margin:0 0 14px;">
      Busca todas as NFs de <strong>marketplace</strong> no período e preenche as faturas
      em aberto automaticamente (ativando o modo Via de Cliente, finalizando e arquivando cada uma).
    </p>

    <div id="massivoEtapaDatas">
      <label style="display:block;font-weight:600;margin-bottom:4px;font-size:13px;">Data inicial:</label>
      <input type="date" id="massivoDataInicial" style="width:100%;padding:8px;font-size:14px;margin-bottom:10px;border:1px solid #ccc;border-radius:6px;">

      <label style="display:block;font-weight:600;margin-bottom:4px;font-size:13px;">Data final:</label>
      <input type="date" id="massivoDataFinal" style="width:100%;padding:8px;font-size:14px;margin-bottom:14px;border:1px solid #ccc;border-radius:6px;">

      <div style="background:#fff3cd;border-left:3px solid #f39c12;padding:8px 10px;border-radius:4px;font-size:11.5px;color:#856404;margin-bottom:14px;line-height:1.4;">
        ⚠️ <strong>Atenção:</strong> NFs com mais de 14 itens ou SKUs não cadastrados serão puladas.
        Um relatório com tudo que foi feito aparece no final.
      </div>

      <div style="display:flex;gap:8px;">
        <button onclick="fecharModalMassivo()" style="flex:1;padding:10px;background:#95a5a6;color:#fff;border:none;border-radius:6px;font-weight:600;cursor:pointer;font-size:13px;">Cancelar</button>
        <button onclick="iniciarPrevia()" id="btnPreviaMassivo" style="flex:2;padding:10px;background:#3498db;color:#fff;border:none;border-radius:6px;font-weight:700;cursor:pointer;font-size:13px;">🔍 Buscar NFs do Período</button>
      </div>
    </div>

    <!-- Etapa 2: confirmação com prévia -->
    <div id="massivoEtapaPrevia" style="display:none;">
      <div id="massivoPreviaInfo" style="font-size:13px;line-height:1.5;margin-bottom:12px;"></div>
      <div id="massivoPreviaLista" style="max-height:200px;overflow-y:auto;border:1px solid #e0e0e0;border-radius:6px;padding:6px 8px;margin-bottom:14px;font-size:12px;background:#fafafa;"></div>
      <div style="display:flex;gap:8px;">
        <button onclick="voltarMassivoEtapaDatas()" style="flex:1;padding:10px;background:#95a5a6;color:#fff;border:none;border-radius:6px;font-weight:600;cursor:pointer;font-size:13px;">← Voltar</button>
        <button onclick="executarMassivo()" id="btnExecMassivo" style="flex:2;padding:10px;background:linear-gradient(135deg,#27ae60,#2ecc71);color:#fff;border:none;border-radius:6px;font-weight:700;cursor:pointer;font-size:13px;">⚡ Executar Preenchimento</button>
      </div>
    </div>

    <!-- Etapa 3: execução com barra de progresso -->
    <div id="massivoEtapaProgresso" style="display:none;">
      <div style="font-size:14px;margin-bottom:6px;"><strong id="massivoProgTexto">Preparando...</strong></div>
      <div style="background:#e0e0e0;border-radius:10px;overflow:hidden;height:22px;margin-bottom:10px;">
        <div id="massivoBarraProgresso" style="background:linear-gradient(135deg,#27ae60,#2ecc71);height:100%;width:0%;transition:width 0.3s ease;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:12px;">0%</div>
      </div>
      <div id="massivoProgDetalhe" style="font-size:11.5px;color:#666;margin-bottom:10px;max-height:140px;overflow-y:auto;background:#fafafa;padding:6px 8px;border-radius:4px;border:1px solid #e0e0e0;font-family:monospace;line-height:1.4;"></div>
      <div style="text-align:center;font-size:11px;color:#999;">⏳ Não feche esta janela enquanto o processamento estiver em andamento</div>
    </div>

    <!-- Etapa 4: relatório final -->
    <div id="massivoEtapaRelatorio" style="display:none;">
      <div id="massivoRelatorio" style="font-size:13px;line-height:1.5;"></div>
      <button onclick="fecharModalMassivo()" style="width:100%;margin-top:12px;padding:10px;background:#27ae60;color:#fff;border:none;border-radius:6px;font-weight:700;cursor:pointer;font-size:13px;">✓ Fechar</button>
    </div>
  </div>
</div>

<!-- Socket.io client carregado do próprio servidor Electron/Express -->
<script src="/produtos.js"></script>
<script src="/clientes.js"></script>
<script src="/socket.io/socket.io.js"></script>

<script>
const faturaInicial = 6383;
const totalFaturas = 50;
let faturaAtual = 0;
let _ignorarInput = false; // evita loop: quando recebo dados do socket, não reenvio

const container = document.getElementById("pages");

/* ── TEMPLATE (idêntico ao original) ─────────────────────────── */
const template = `
<div class="page">

<div class='ref-fat-wrap' style='display:none;'>
  <span class='ref-fat-label'>REF FAT:</span>
  <div class='ref-fat-inputs'>
    <input class='ref-fat-box' type='text' inputmode='numeric' maxlength='6'>
  </div>
</div>

<!-- VIA DE CLIENTE: Nº NF (topo esquerdo) -->
<div class='vc-nf-wrap'>
  <span class='vc-nf-label'>Nº NF:</span>
  <input class='vc-nf-input' type='text' maxlength='20'>
  <button class='vc-btn-buscar-nf' type='button' onclick='buscarNFTiny(this)'>🔍 Buscar</button>
</div>

<!-- VIA DE CLIENTE: Cód Cliente (topo direito) -->
<div class='vc-cod-wrap'>
  <span class='vc-cod-label'>CÓD CLIENTE:</span>
  <input class='vc-cod-input' type='text' maxlength='20'>
  <button class='vc-cod-btn-confirmar' type='button' onclick='confirmarCodCliente(this)' title='Confirmar e bloquear edição'>✓</button>
</div>

<!-- VIA DE CLIENTE: OBS grande (à esquerda do TOTAL) -->
<div class='vc-obs-wrap'>
  <span class='vc-obs-label'>OBS:</span>
  <textarea class='vc-obs-textarea' rows='4'></textarea>
</div>


<div class='row'><span class='label'>Data,</span><input class='line' style='width:28px;text-align:center;' maxlength='2' oninput='if(this.value.length===2)this.closest(".row").querySelectorAll("input")[1].focus()'><span>/</span><input class='line' style='width:28px;text-align:center;' maxlength='2' oninput='if(this.value.length===2)this.closest(".row").querySelectorAll("input")[2].focus()'><span>/</span><input class='line' style='width:48px;text-align:center;' maxlength='4'></div>
<div class='centerTitle'>Nº <span class="numeroFatura"></span></div>
<div class='client'>É Cliente? <input class='boxInput' maxlength='1'> Sim <input class='boxInput' maxlength='1'> Não</div>

<div class='row topspace'><span class='label'>Nome:</span><input class='line flex'><span class='label'>Cel.:</span><input class='line lg'></div>
<div class='row'><span class='label'>Rua:</span><input class='line flex'><span class='label'>N°:</span><input class='line xs'><span class='label'>Fone:</span><input class='line lg'></div>
<div class='row'><span class='label'>Localidade:</span><input class='line flex'><span class='label'>Bairro:</span><input class='line lg'></div>
<div class='row'><span class='label'>Cidade:</span><input class='line flex'><span class='label'>Estado:</span><input class='line sm'></div>
<div class='row'><span class='label'>Ref. Comercial:</span><input class='line flex'></div>
<div class='row'><span class='label'>Profissão:</span><input class='line flex'><span class='label'>Data Nasc.:</span><input class='line xs'><span>/</span><input class='line xs'><span>/</span><input class='line sm'></div>
<div class='row'><span class='label'>CPF:</span><input class='line flex'><span class='label'>RG:</span><input class='line flex'></div>
<div class='row'><span class='label'>Cônjuge:</span><input class='line flex'></div>

<div class='row obs'>
<span class='label'>Filiação:</span>
<span class='brace'>{</span>
<div class='flex'>
<div class='row'><span class='label'>Pai:</span><input class='line flex'></div>
<div class='row'><span class='label'>Mãe:</span><input class='line flex'></div>
</div>
</div>

<div class='row'><span class='label'>Obs.:</span><input class='line flex'></div>

<div style='position:absolute;right:70px;top:248px;display:flex;align-items:center;gap:6px;'>
<div style='font-weight:700;font-size:14px;'>SOMA</div>
<input class='somaBox' readonly style='width:98px;height:18px;border:1px solid #000;font-size:14px;font-weight:700;text-align:center;'>
</div>

<table class='table'>
<tr><th style='width:11%'>Quant.</th><th>Discriminação</th><th style='width:27%'>Valor</th></tr>
${"<tr><td><input></td><td><textarea class='discArea' rows='1' spellcheck='false'></textarea></td><td><input></td></tr>".repeat(14)}
</table>

<div class='totalWrap'>
<div class='totalLbl'>TOTAL</div>
<input class='line totalBox' style='width:188px;height:29px;border:1.2px solid #000;font-size:17px;font-family:inherit;color:#08224f;font-weight:600;text-align:center;padding:0 4px;box-sizing:border-box;'>
</div>

<div class='note'>Este fatura não pode ser cancelado, caso ocorra o cancelamento, implicará para o freguês despesa de 10%</div>

<div class='signs'>
<div class='sig'><input class='line' style='width:240px;display:block;margin:0 auto 6px;'>Comprador</div>
<div class='sig'><input class='line' style='width:240px;display:block;margin:0 auto 6px;'>Vendedor</div>
</div>

</div>
`;

for(let i=0;i<totalFaturas;i++){
    container.insertAdjacentHTML("beforeend", template);
}

const pages = [...document.querySelectorAll(".page")];

pages.forEach((page,i)=>{
    page.querySelector(".numeroFatura").textContent =
    String(faturaInicial+i).padStart(6,"0");
});

/* ── FINALIZADOS ─────────────────────────────────────────────── */
let finalizadas =
JSON.parse(localStorage.getItem("faturasFinalizadas") || "[]");

/* ── CONFERÊNCIA ─────────────────────────────────────────────── */
// Array de objetos: [{indice, usuario, data}, ...]
let conferidas =
JSON.parse(localStorage.getItem("faturasConferidas") || "[]");

/* ── VIA DE CLIENTE ───────────────────────────────────────────── */
// Array de objetos: [{indice, nf, codCliente, obs}, ...]
// Cada objeto representa uma fatura que está em modo "via de cliente"
let viasCliente =
JSON.parse(localStorage.getItem("faturasViasCliente") || "[]");

/* Adiciona (ou atualiza) a marca d'água na página conferida */
function atualizarMarcaConferencia(indice){
    const page = pages[indice];
    if(!page) return;
    // Remove as marcas antigas se existirem
    const marcaAntiga = page.querySelector(".marca-conferida");
    if(marcaAntiga) marcaAntiga.remove();
    const marcaTopoAntiga = page.querySelector(".marca-conferida-topo");
    if(marcaTopoAntiga) marcaTopoAntiga.remove();
    // Procura se essa fatura está na lista de conferidas
    const conf = conferidas.find(c => c.indice === indice);
    if(!conf) return;
    const nome = (conf.usuario || "").toUpperCase();
    const data = conf.data || "";
    // Marca d'água grande (centro)
    const marca = document.createElement("div");
    marca.className = "marca-conferida";
    marca.innerHTML = `
      CONFERIDO
      <span class="mc-nome">${nome}</span>
      <span class="mc-data">${data}</span>
    `;
    page.appendChild(marca);
    // Marca d'água pequena (topo)
    const marcaTopo = document.createElement("div");
    marcaTopo.className = "marca-conferida-topo";
    marcaTopo.innerHTML = `
      CONFERIDO
      <span class="mc-nome">${nome}</span>
      <span class="mc-data">${data}</span>
    `;
    page.appendChild(marcaTopo);
}

/* Renderiza todas as marcas d'água (usado após carregar dados do servidor) */
function renderizarTodasMarcas(){
    pages.forEach((_, i) => atualizarMarcaConferencia(i));
}

/* ── BOTÃO FINALIZAR ─────────────────────────────────────────── */
document.querySelector(".topbar").insertAdjacentHTML(
"beforeend",
`<button class="btnGreen" onclick="finalizarFatura()">Finalizar Fatura</button>`
);

/* ── SOCKET.IO ───────────────────────────────────────────────── */
const syncDot   = document.getElementById("syncDot");
const syncLabel = document.getElementById("syncLabel");

// Mostra versão do programa
try{
  const {ipcRenderer} = require('electron');
  ipcRenderer.invoke('get-version').then(v => {
    const el = document.getElementById('versaoLabel');
    if(el) el.textContent = 'v'+v;
  }).catch(()=>{});
}catch(e){}

// Conecta direto ao VPS
const VPS_URL = (location.protocol === 'https:' || location.protocol === 'http:') && location.host && location.host !== '' ? location.protocol + '//' + location.host : 'https://appcaus.com.br';
const socket = io(VPS_URL, {
  reconnection: true,
  reconnectionDelay: 1000,
  reconnectionAttempts: Infinity,
  timeout: 5000
});

socket.on("connect", () => {
    syncDot.className   = "sync-dot connected";
    syncLabel.textContent = "Sincronizado";

    // Verifica se tem dados pendentes para sincronizar
    const pendente = localStorage.getItem("faturasPendente");
    if(pendente){
        try{
            const payload = JSON.parse(pendente);
            syncDot.className = "sync-dot syncing";
            syncLabel.textContent = "Sincronizando...";
            socket.emit("update-data", payload);
            localStorage.removeItem("faturasPendente");
            console.log("Dados pendentes sincronizados!");
        }catch(e){
            console.warn("Erro ao sincronizar pendentes:", e);
        }
    }
});

socket.on("disconnect", () => {
    syncDot.className   = "sync-dot disconnected";
    syncLabel.textContent = "Desconectado";
});

// Recebe dados do servidor (enviado por qualquer cliente conectado)
socket.on("load-data", (payload) => {
    // Suporta formato novo {dados, finalizadas, conferidas, refFats, viasCliente} e formato antigo (array direto)
    const serverDados     = Array.isArray(payload) ? payload : payload.dados;
    const serverFinaliz   = Array.isArray(payload) ? [] : (payload.finalizadas || []);
    const serverConferid  = Array.isArray(payload) ? [] : (payload.conferidas || []);
    const serverRefFats   = Array.isArray(payload) ? [] : (payload.refFats || []);
    const serverViasCli   = Array.isArray(payload) ? [] : (payload.viasCliente || []);

    if (!serverDados || !serverDados.length) return;

    // Campo com foco ativo — não sobrescreve enquanto usuário está digitando
    const campoAtivo = document.activeElement;

    _ignorarInput = true;

    pages.forEach((page, p) => {
        const inputs = inputsEditaveis(page);
        if (serverDados[p]) {
            inputs.forEach((inp, i) => {
                // Pula o campo que está sendo digitado agora
                if (inp === campoAtivo) return;
                if (serverDados[p][i] !== undefined) {
                    inp.value = serverDados[p][i];
                }
            });
        }
    });

    // Sincroniza finalizadas vindas do servidor
    if (serverFinaliz.length > 0 || !Array.isArray(payload)) {
        finalizadas = serverFinaliz;
        localStorage.setItem("faturasFinalizadas", JSON.stringify(finalizadas));
    }

    // Sincroniza conferidas vindas do servidor
    if (!Array.isArray(payload)) {
        conferidas = serverConferid;
        localStorage.setItem("faturasConferidas", JSON.stringify(conferidas));
        renderizarTodasMarcas();
    }

    // Sincroniza refFats vindas do servidor — mas não sobrescreve se o campo ativo for uma ref-fat-box
    if(serverRefFats && serverRefFats.length){
        const campoAtivoEhRefFat = campoAtivo && campoAtivo.classList && campoAtivo.classList.contains("ref-fat-box");
        if(!campoAtivoEhRefFat){
            pages.forEach((page, p) => {
                if(serverRefFats[p] !== undefined){
                    setRefFatValores(page, serverRefFats[p]);
                }
            });
        }
        localStorage.setItem("faturasRefFats", JSON.stringify(serverRefFats));
    }

    // Sincroniza viasCliente vindas do servidor — não sobrescreve se o campo ativo for input do VC
    if(!Array.isArray(payload)){
        const campoAtivoEhVC = campoAtivo && campoAtivo.classList && (
            campoAtivo.classList.contains("vc-nf-input") ||
            campoAtivo.classList.contains("vc-cod-input") ||
            campoAtivo.classList.contains("vc-obs-textarea")
        );
        if(!campoAtivoEhVC){
            viasCliente = serverViasCli;
            localStorage.setItem("faturasViasCliente", JSON.stringify(viasCliente));
            aplicarViaClienteEmTodasPaginas();
            atualizarBotaoViaCliente();
        }
    }

    localStorage.setItem("faturasDados", JSON.stringify(serverDados));

    _ignorarInput = false;
    recalcularTodos();
    // Redimensiona textareas e ajusta linhas após carregar
    pages.forEach(page => {
        page.querySelectorAll("textarea.discArea").forEach(ta => autoResizeTextarea(ta));
        ajustarLinhasTabela(page);
    });
    mostrarFatura(); // atualiza status e bloqueios em todos os dispositivos
});

// Recebe comando de reset de qualquer dispositivo
socket.on("reset-all", () => {
    _ignorarInput = true;
    // Limpa localStorage
    localStorage.removeItem("faturasDados");
    localStorage.removeItem("faturaAtual");
    localStorage.removeItem("faturasFinalizadas");
    localStorage.removeItem("faturasConferidas");
    localStorage.removeItem("faturasRefFats");
    localStorage.removeItem("faturasViasCliente");
    // Limpa todos os inputs
    finalizadas = [];
    conferidas = [];
    viasCliente = [];
    faturaAtual = 0;
    pages.forEach(page => {
        inputsEditaveis(page).forEach(inp => {
            inp.value = "";
            if(inp.tagName === "TEXTAREA") autoResizeTextarea(inp);
        });
        const soma = page.querySelector(".somaBox");
        if(soma) soma.value = "";
        // Remove qualquer marca d'água de conferência (grande e pequena)
        const marca = page.querySelector(".marca-conferida");
        if(marca) marca.remove();
        const marcaTopo = page.querySelector(".marca-conferida-topo");
        if(marcaTopo) marcaTopo.remove();
        // Limpa REF FAT e esconde o container
        atualizarRefFatVisibilidade(page, "");
        // Limpa campos de Via de Cliente e remove a classe
        page.classList.remove("via-cliente");
        const vcNF = page.querySelector(".vc-nf-input");
        const vcCod = page.querySelector(".vc-cod-input");
        const vcObs = page.querySelector(".vc-obs-textarea");
        if(vcNF) vcNF.value = "";
        if(vcCod) vcCod.value = "";
        if(vcObs) vcObs.value = "";
    });
    atualizarBotaoViaCliente();
    _ignorarInput = false;
    mostrarFatura();
});

/* ── MODAL RESET ─────────────────────────────────────────────── */
function abrirModalReset(){
    document.getElementById("resetUsuario").value = "";
    document.getElementById("resetSenha").value   = "";
    document.getElementById("resetErro").style.display = "none";
    document.getElementById("modalReset").classList.add("ativo");
    setTimeout(() => document.getElementById("resetUsuario").focus(), 150);
}

function fecharModalReset(){
    document.getElementById("modalReset").classList.remove("ativo");
}

function confirmarReset(){
    const u = document.getElementById("resetUsuario").value.trim();
    const s = document.getElementById("resetSenha").value.trim();
    if(u === USUARIO_EDIT && s === SENHA_EDIT){
        fecharModalReset();
        // Envia reset para o servidor — propaga para TODOS os dispositivos
        socket.emit("reset-all");
    } else {
        document.getElementById("resetErro").style.display = "block";
        document.getElementById("resetSenha").value = "";
        setTimeout(() => document.getElementById("resetUsuario").focus(), 50);
    }
}

/* ── MODAL CONFERÊNCIA ───────────────────────────────────────── */
function abrirModalConferencia(){
    // Só permite conferir fatura finalizada
    const jaFinalizada = finalizadas.includes(faturaAtual);
    if(!jaFinalizada){
        alert("⚠️ Só é possível conferir faturas finalizadas.\n\nFinalize a fatura primeiro e depois volte para conferir.");
        return;
    }
    // Verifica se já está conferida para mudar o texto do modal
    const jaConferida = conferidas.find(c => c.indice === faturaAtual);
    const titulo = document.getElementById("conferenciaTitulo");
    const desc = document.getElementById("conferenciaDesc");
    const btn = document.getElementById("btnConfirmarConf");
    if(jaConferida){
        titulo.textContent = "🔓 Desconferir Fatura";
        desc.textContent = "Esta fatura já foi conferida. Digite suas credenciais para remover a conferência.";
        btn.textContent = "Desconferir";
        btn.style.background = "#e67e22";
    } else {
        titulo.textContent = "🔍 Conferir Fatura";
        desc.textContent = "Digite suas credenciais para marcar esta fatura como conferida.";
        btn.textContent = "Conferir";
        btn.style.background = "#198754";
    }
    // Limpa campos
    document.getElementById("confUsuario").value = "";
    document.getElementById("confSenha").value   = "";
    document.getElementById("confErro").style.display = "none";
    document.getElementById("modalConferencia").classList.add("ativo");
    setTimeout(() => document.getElementById("confUsuario").focus(), 150);
}

function fecharModalConferencia(){
    document.getElementById("modalConferencia").classList.remove("ativo");
}

function confirmarConferencia(){
    const u = document.getElementById("confUsuario").value.trim();
    const s = document.getElementById("confSenha").value.trim();
    if(u !== USUARIO_EDIT || s !== SENHA_EDIT){
        document.getElementById("confErro").style.display = "block";
        document.getElementById("confSenha").value = "";
        setTimeout(() => document.getElementById("confUsuario").focus(), 50);
        return;
    }
    const jaConferida = conferidas.find(c => c.indice === faturaAtual);
    if(jaConferida){
        // Desconferir → remove do array
        conferidas = conferidas.filter(c => c.indice !== faturaAtual);
    } else {
        // Conferir → adiciona ao array com data atual
        const hoje = new Date();
        const dataStr = `${String(hoje.getDate()).padStart(2,"0")}/${String(hoje.getMonth()+1).padStart(2,"0")}/${hoje.getFullYear()}`;
        conferidas.push({
            indice: faturaAtual,
            usuario: u,
            data: dataStr
        });
    }
    // Atualiza a marca visual na página
    atualizarMarcaConferencia(faturaAtual);
    // Salva e sincroniza
    salvar();
    fecharModalConferencia();
}

// Permite Enter para confirmar conferência
document.addEventListener("keydown", (e) => {
    if(e.key === "Enter" && document.getElementById("modalConferencia").classList.contains("ativo")){
        confirmarConferencia();
    }
});

/* Retorna apenas inputs/textareas editáveis (exclui somaBox) */
function inputsEditaveis(page){
    // Exclui .somaBox e .ref-fat-box — esses são salvos à parte
    return [...page.querySelectorAll("input:not(.somaBox):not(.ref-fat-box), textarea.discArea")];
}

/* Lê valores do REF FAT de uma página (string "a,b,c") */
function getRefFatValores(page){
    const boxes = [...page.querySelectorAll(".ref-fat-box")];
    return boxes.map(b => b.value.trim()).filter(v => v).join(",");
}

/* Aplica valores do REF FAT em uma página (recria caixinhas conforme necessário) */
function setRefFatValores(page, valorStr){
    const wrap = page.querySelector(".ref-fat-wrap");
    const cont = page.querySelector(".ref-fat-inputs");
    if(!wrap || !cont) return;
    const valores = (valorStr || "").split(",").map(v => v.trim()).filter(v => v);
    // Remove todas menos a primeira
    const boxes = [...cont.querySelectorAll(".ref-fat-box")];
    boxes.slice(1).forEach(b => b.remove());
    // Se a primeira existe, define o valor dela ou limpa
    const primeira = cont.querySelector(".ref-fat-box");
    if(primeira){
        primeira.value = valores[0] || "";
        vincularRefFatBox(primeira);
    }
    // Cria as restantes
    for(let i = 1; i < valores.length; i++){
        const novaBox = criarRefFatBox(valores[i]);
        cont.appendChild(novaBox);
    }
}

/* Cria um novo input .ref-fat-box */
function criarRefFatBox(valor){
    const inp = document.createElement("input");
    inp.className = "ref-fat-box";
    inp.type = "text";
    inp.inputMode = "numeric";
    inp.maxLength = 6;
    inp.value = valor || "";
    vincularRefFatBox(inp);
    // Aplica o filtro de maiúsculas na caixinha nova
    inp.dataset.maiusculas = "1";
    inp.addEventListener("input", () => {
        const start = inp.selectionStart;
        const end = inp.selectionEnd;
        const upper = inp.value.toUpperCase();
        if(inp.value !== upper){
            inp.value = upper;
            try { inp.setSelectionRange(start, end); } catch(e){}
        }
    });
    return inp;
}

/* Vincula eventos numa caixinha REF FAT */
function vincularRefFatBox(inp){
    if(inp.dataset.refFatBind) return;
    inp.dataset.refFatBind = "1";

    // TAB cria próxima caixinha se a atual tem conteúdo
    inp.addEventListener("keydown", (e) => {
        const cont = inp.parentElement;
        if(!cont) return;
        const boxes = [...cont.querySelectorAll(".ref-fat-box")];
        const idx = boxes.indexOf(inp);

        if(e.key === "Tab" && !e.shiftKey){
            // Só cria nova se a caixa atual tem valor e é a última
            if(inp.value.trim() && idx === boxes.length - 1){
                e.preventDefault();
                const nova = criarRefFatBox();
                cont.appendChild(nova);
                nova.focus();
                // Dispara salvamento (evento input propaga pro listener global)
                inp.dispatchEvent(new Event("input", { bubbles: true }));
            }
        } else if(e.key === "Backspace"){
            // Se caixa vazia e não é a primeira, remove e foca a anterior
            if(inp.value === "" && idx > 0){
                e.preventDefault();
                inp.remove();
                boxes[idx - 1].focus();
                // Cursor no final
                const ant = boxes[idx - 1];
                try {
                    const pos = ant.value.length;
                    ant.setSelectionRange(pos, pos);
                } catch(_){}
                // Dispara salvamento
                ant.dispatchEvent(new Event("input", { bubbles: true }));
            }
        }
    });
    // O evento "input" é capturado pelo listener global que já salva automaticamente
}

/* Mostra/esconde wrapper REF FAT baseado em se o cliente é 396 */
function atualizarRefFatVisibilidade(page, codigoCliente){
    const wrap = page.querySelector(".ref-fat-wrap");
    if(!wrap) return;
    if(codigoCliente === "396"){
        wrap.style.display = "flex";
        page.classList.add("com-ref-fat");
    } else {
        wrap.style.display = "none";
        page.classList.remove("com-ref-fat");
        // Limpa valores e volta só com uma caixa vazia
        const cont = page.querySelector(".ref-fat-inputs");
        if(cont){
            const boxes = [...cont.querySelectorAll(".ref-fat-box")];
            boxes.slice(1).forEach(b => b.remove());
            const primeira = cont.querySelector(".ref-fat-box");
            if(primeira) primeira.value = "";
        }
    }
}

/* Vincula caixinha inicial em todas as pages */
function vincularRefFatInicial(){
    pages.forEach(page => {
        const primeira = page.querySelector(".ref-fat-box");
        if(primeira) vincularRefFatBox(primeira);
    });
}

/* ── VIA DE CLIENTE (modo e-commerce) ─────────────────────────── */
/* Retorna o objeto da via de cliente pra uma fatura (ou null) */
function getViaCliente(indice){
    return viasCliente.find(v => v.indice === indice) || null;
}

/* Verifica se a fatura está em modo via de cliente ATIVO (não arquivado).
   Usado pelo botão "Ativar/Desativar". */
function isViaClienteAtiva(indice){
    const vc = getViaCliente(indice);
    return vc !== null && !vc.arquivada;
}

/* Verifica se a fatura TEM ou TEVE registro de via de cliente (inclui arquivadas).
   Usado pela tag no painel de filtros e pra mostrar os campos na impressão. */
function foiViaCliente(indice){
    return getViaCliente(indice) !== null;
}

/* Aplica visualmente o modo via de cliente numa página.
   Os campos ficam visíveis tanto quando ATIVA quanto quando ARQUIVADA
   (pra manter impressão/conferência de faturas finalizadas). */
function aplicarViaClienteNaPagina(indice){
    const page = pages[indice];
    if(!page) return;
    const vc = getViaCliente(indice);
    const btnCodConfirmar = page.querySelector(".vc-cod-btn-confirmar");
    if(vc){
        // Mostra os campos em ambos os casos (ativa ou arquivada)
        page.classList.add("via-cliente");
        // Preenche os valores salvos
        const inpNF = page.querySelector(".vc-nf-input");
        const inpCod = page.querySelector(".vc-cod-input");
        const taObs = page.querySelector(".vc-obs-textarea");
        if(inpNF) inpNF.value = vc.nf || "";
        if(inpCod) inpCod.value = vc.codCliente || "";
        if(taObs) taObs.value = vc.obs || "";

        // Regras de bloqueio:
        // - Se ATIVA: tudo liberado pra edição
        // - Se ARQUIVADA (finalizada): NF e OBS travados, mas CÓD CLIENTE
        //   fica editável ATÉ ser confirmado pelo botão ✓
        const estaArquivada = !!vc.arquivada;
        const codJaConfirmado = !!vc.codConfirmado;

        if(inpNF) inpNF.readOnly = estaArquivada;
        if(taObs) taObs.readOnly = estaArquivada;
        // Cód Cliente: só trava se arquivada E já confirmado
        if(inpCod) inpCod.readOnly = estaArquivada && codJaConfirmado;

        // Botão ✓: aparece só se arquivada E ainda não confirmado
        if(btnCodConfirmar){
            if(estaArquivada && !codJaConfirmado){
                btnCodConfirmar.classList.remove("confirmado");
            } else {
                btnCodConfirmar.classList.add("confirmado");
            }
        }
    } else {
        page.classList.remove("via-cliente");
        // Limpa os valores
        const inpNF = page.querySelector(".vc-nf-input");
        const inpCod = page.querySelector(".vc-cod-input");
        const taObs = page.querySelector(".vc-obs-textarea");
        if(inpNF) { inpNF.value = ""; inpNF.readOnly = false; }
        if(inpCod) { inpCod.value = ""; inpCod.readOnly = false; }
        if(taObs) { taObs.value = ""; taObs.readOnly = false; }
        if(btnCodConfirmar) btnCodConfirmar.classList.add("confirmado");
    }
}

/* Aplica via de cliente em todas as páginas (usado ao carregar dados do servidor) */
function aplicarViaClienteEmTodasPaginas(){
    pages.forEach((page, indice) => {
        aplicarViaClienteNaPagina(indice);
    });
}

/* Atualiza os dados da via de cliente atual (pega valores dos inputs) */
function atualizarDadosViaClienteAtual(){
    const page = pages[faturaAtual];
    if(!page) return;
    const vc = viasCliente.find(v => v.indice === faturaAtual);
    if(!vc) return; // nenhum registro VC pra atualizar
    // Só lê os valores dos inputs se os campos estiverem visíveis (tem classe via-cliente)
    if(!page.classList.contains("via-cliente")) return;
    const inpNF = page.querySelector(".vc-nf-input");
    const inpCod = page.querySelector(".vc-cod-input");
    const taObs = page.querySelector(".vc-obs-textarea");
    vc.nf = inpNF ? inpNF.value : "";
    vc.codCliente = inpCod ? inpCod.value : "";
    vc.obs = taObs ? taObs.value : "";
}

/* Toggle: liga/desliga o modo via de cliente pra fatura atual */
function toggleViaCliente(){
    const page = pages[faturaAtual];
    if(!page){
        alert("Nenhuma fatura selecionada.");
        return;
    }
    const jaAtivo = isViaClienteAtiva(faturaAtual);
    const estaFinalizada = finalizadas.includes(faturaAtual);

    if(jaAtivo){
        // Desligar
        if(estaFinalizada){
            // Fatura finalizada: PRESERVA os dados pra manter impressão/conferência
            // Apenas marca como "arquivada" — os campos continuam visíveis e salvos
            const vc = viasCliente.find(v => v.indice === faturaAtual);
            if(vc){
                // Salva os valores atuais dos inputs antes de "arquivar"
                atualizarDadosViaClienteAtual();
                vc.arquivada = true; // marca que foi desativada mas é finalizada (mantém visual)
            }
            alert("ℹ️ Fatura já finalizada — modo Via de Cliente arquivado mas os dados foram preservados.\n\nO Nº NF, Cód Cliente e OBS continuam salvos na fatura e aparecerão na impressão/conferência.");
        } else {
            // Fatura não finalizada: comportamento antigo (apaga tudo)
            if(!confirm("Desativar o modo Via de Cliente?\nOs valores de Nº NF, Cód Cliente e OBS serão apagados.\n\n(Se quiser preservar os dados, finalize a fatura antes de desativar.)")) return;
            viasCliente = viasCliente.filter(v => v.indice !== faturaAtual);
            aplicarViaClienteNaPagina(faturaAtual);
        }
    } else {
        // Ligar — verifica se tem registro arquivado pra restaurar
        const vcArquivada = viasCliente.find(v => v.indice === faturaAtual && v.arquivada);
        if(vcArquivada){
            // Reativa o registro arquivado
            delete vcArquivada.arquivada;
        } else {
            // Cria novo registro
            viasCliente.push({
                indice: faturaAtual,
                nf: "",
                codCliente: "",
                obs: ""
            });
        }
        aplicarViaClienteNaPagina(faturaAtual);
    }
    atualizarBotaoViaCliente();
    salvar();
}

/* Atualiza o label/cor do botão no painel baseado na fatura atual */
function atualizarBotaoViaCliente(){
    const btn = document.getElementById("btnToggleViaCliente");
    const labelTop = document.getElementById("vcLabelTop");
    const labelBottom = document.getElementById("vcLabelBottom");
    if(!btn) return;

    const vc = getViaCliente(faturaAtual);
    const estaAtivo = isViaClienteAtiva(faturaAtual);
    const estaArquivado = vc && vc.arquivada;

    if(estaAtivo){
        // Modo ATIVO — gradiente laranja
        btn.style.background = "linear-gradient(135deg,#e67e22,#f39c12)";
        btn.style.boxShadow = "0 3px 10px rgba(230,126,34,0.45)";
        btn.setAttribute("onmouseover",
            "this.style.transform='translateY(-2px)';this.style.boxShadow='0 6px 16px rgba(230,126,34,0.55)'");
        btn.setAttribute("onmouseout",
            "this.style.transform='translateY(0)';this.style.boxShadow='0 3px 10px rgba(230,126,34,0.45)'");
        if(labelTop)    labelTop.textContent    = "VIA DE CLIENTE";
        if(labelBottom) labelBottom.textContent = "✓ ATIVO (Desativar)";
    } else if(estaArquivado){
        // Modo ARQUIVADO — gradiente verde (fatura finalizada mantendo dados)
        btn.style.background = "linear-gradient(135deg,#27ae60,#2ecc71)";
        btn.style.boxShadow = "0 3px 10px rgba(39,174,96,0.45)";
        btn.setAttribute("onmouseover",
            "this.style.transform='translateY(-2px)';this.style.boxShadow='0 6px 16px rgba(39,174,96,0.55)'");
        btn.setAttribute("onmouseout",
            "this.style.transform='translateY(0)';this.style.boxShadow='0 3px 10px rgba(39,174,96,0.45)'");
        if(labelTop)    labelTop.textContent    = "VIA DE CLIENTE";
        if(labelBottom) labelBottom.textContent = "📋 ARQUIVADA (Reativar)";
    } else {
        // Modo INATIVO — gradiente roxo original
        btn.style.background = "linear-gradient(135deg,#6c5ce7,#8e7dff)";
        btn.style.boxShadow = "0 3px 10px rgba(108,92,231,0.35)";
        btn.setAttribute("onmouseover",
            "this.style.transform='translateY(-2px)';this.style.boxShadow='0 6px 16px rgba(108,92,231,0.45)'");
        btn.setAttribute("onmouseout",
            "this.style.transform='translateY(0)';this.style.boxShadow='0 3px 10px rgba(108,92,231,0.35)'");
        if(labelTop)    labelTop.textContent    = "VIA DE CLIENTE";
        if(labelBottom) labelBottom.textContent = "Ativar Modo";
    }
}

/* Vincula listeners aos inputs de via de cliente em todas as páginas */
function vincularViaClienteInputs(){
    pages.forEach((page, indice) => {
        const inpNF = page.querySelector(".vc-nf-input");
        const inpCod = page.querySelector(".vc-cod-input");
        const taObs = page.querySelector(".vc-obs-textarea");
        [inpNF, inpCod, taObs].forEach(inp => {
            if(!inp) return;
            inp.addEventListener("input", () => {
                const vc = viasCliente.find(v => v.indice === indice);
                if(vc){
                    // Pra campos de fatura ARQUIVADA, só aceita alteração do Cód Cliente
                    // (os outros ficam readonly mesmo, então esse if nem executa pra eles)
                    if(vc.arquivada){
                        // Só atualiza o Cód Cliente (os outros estão readonly)
                        vc.codCliente = inpCod ? inpCod.value : "";
                    } else {
                        // Modo ATIVO — atualiza tudo
                        vc.nf = inpNF ? inpNF.value : "";
                        vc.codCliente = inpCod ? inpCod.value : "";
                        vc.obs = taObs ? taObs.value : "";
                    }
                    salvar();
                }
            });
        });
    });
}

/* Confirma o Cód Cliente da fatura arquivada — trava o campo após confirmação.
   Depois que clicar em ✓, só o botão Editar (com senha) libera de novo. */
function confirmarCodCliente(btn){
    const page = btn.closest(".page");
    if(!page) return;
    const indice = pages.indexOf(page);
    if(indice < 0) return;
    const vc = viasCliente.find(v => v.indice === indice);
    if(!vc) return;

    const inpCod = page.querySelector(".vc-cod-input");
    const valorAtual = (inpCod?.value || "").trim();

    if(!valorAtual){
        alert("⚠️ Preencha o Cód Cliente antes de confirmar.");
        inpCod?.focus();
        return;
    }

    if(!confirm(`Confirmar Cód Cliente "${valorAtual}"?\n\nApós confirmar, o campo ficará bloqueado. Só será possível destravar pelo botão Editar (com senha).`)){
        return;
    }

    // Grava o valor final e marca como confirmado
    vc.codCliente = valorAtual;
    vc.codConfirmado = true;

    // Aplica visual: trava o campo e esconde o botão
    if(inpCod) inpCod.readOnly = true;
    btn.classList.add("confirmado");

    salvar();
}

/* ── INTEGRAÇÃO TINY ERP (puxar dados de NF) ─────────────────── */
const TINY_TOKEN = "018e68d029d67390d34804439cf22815f369f37d";
const TINY_API_URL = "/tiny-api"; // proxy no VPS (já existe no server-vps.js)

/* Helper: chama a API Tiny via proxy do VPS */
async function chamarTinyAPI(action, params){
    try{
        const resp = await fetch(TINY_API_URL, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ action, token: TINY_TOKEN, params })
        });
        if(!resp.ok) throw new Error("HTTP " + resp.status);
        return await resp.json();
    }catch(e){
        console.error("[Tiny API] Erro:", e);
        return { erro: e.message };
    }
}

/* Botão "Buscar NF" — puxa os dados do Tiny e preenche a fatura */
async function buscarNFTiny(btn){
    const page = btn.closest(".page");
    if(!page) return;
    const inpNF = page.querySelector(".vc-nf-input");
    const numero = (inpNF?.value || "").trim();

    if(!numero){
        alert("⚠️ Digite o número da NF antes de buscar.");
        inpNF?.focus();
        return;
    }

    // SEGURANÇA: verifica se o número da NF já existe em outra fatura
    // (ignora a fatura atual, pra permitir re-buscar dados da própria)
    const indiceAtual = pages.indexOf(page);
    const faturaDuplicada = buscarFaturaPorNumeroNF(numero, indiceAtual);
    if(faturaDuplicada >= 0){
        const numFaturaDup = String(faturaInicial + faturaDuplicada).padStart(6, "0");
        alert("❌ NF " + numero + " JÁ ESTÁ CADASTRADA!\n\n" +
              "Essa NF já foi preenchida na Fatura " + numFaturaDup + ".\n\n" +
              "Não é permitido preencher a mesma NF em duas faturas diferentes.\n" +
              "Se precisar corrigir, vá até a Fatura " + numFaturaDup + " e use o botão Editar.");
        // Limpa o campo Nº NF da fatura atual pra não deixar dado errado
        if(inpNF) inpNF.value = "";
        return;
    }

    // Estado visual: desativa botão e muda label
    const labelOriginal = btn.textContent;
    btn.disabled = true;
    btn.textContent = "⏳ Buscando...";

    try{
        // Passo 1: pesquisa a NF pelo número pra obter o ID
        const resp1 = await chamarTinyAPI("listar_nf", { numero });
        if(resp1.erro){
            alert("❌ Erro ao conectar no Tiny:\n" + resp1.erro);
            return;
        }
        const retorno1 = resp1.retorno || {};
        if(retorno1.status === "Erro"){
            const erros = (retorno1.erros || []).map(e => e.erro || e).join("\n");
            alert("❌ Tiny retornou erro:\n" + erros);
            return;
        }
        const notas = retorno1.notas_fiscais || [];
        if(notas.length === 0){
            alert("❌ NF nº " + numero + " não encontrada no Tiny.");
            return;
        }

        // Pega a primeira NF da lista (geralmente é a correta)
        const idNF = notas[0].nota_fiscal?.id;
        if(!idNF){
            alert("❌ ID da NF não encontrado na resposta do Tiny.");
            return;
        }

        // Passo 2: obtém os detalhes completos da NF pelo ID
        const resp2 = await chamarTinyAPI("detalhe_nf", { id: idNF });
        if(resp2.erro){
            alert("❌ Erro ao obter detalhes da NF:\n" + resp2.erro);
            return;
        }
        const retorno2 = resp2.retorno || {};
        if(retorno2.status === "Erro"){
            const erros = (retorno2.erros || []).map(e => e.erro || e).join("\n");
            alert("❌ Erro ao obter NF:\n" + erros);
            return;
        }

        const nf = retorno2.nota_fiscal;
        if(!nf){
            alert("❌ Dados da NF não retornados pelo Tiny.");
            return;
        }

        // Validação: limite de 14 itens (linhas da fatura)
        const itens = nf.itens || [];
        if(itens.length > 14){
            alert("⚠️ Esta NF tem " + itens.length + " produtos.\n" +
                  "A fatura suporta no máximo 14 itens.\n\n" +
                  "Nada foi preenchido. Edite manualmente ou divida a venda em duas faturas.");
            return;
        }

        // Tudo OK — preenche a fatura
        const resultado = await preencherFaturaComNF(page, nf);
        const skusNaoCad = resultado?.skusNaoEncontrados || [];
        const marketplace = resultado?.marketplace || "";

        let msg = "✅ NF " + numero + " preenchida com sucesso!\n" +
                  "Cliente: " + (nf.cliente?.nome || "-") + "\n" +
                  "Itens: " + itens.length + "\n" +
                  "Total: R$ " + formatarValorBR(nf.valor_nota || nf.total_nota || 0);

        if(marketplace){
            msg += "\nVendedor: " + marketplace;
        } else {
            msg += "\n⚠️ Marketplace não identificado (preencha Vendedor manualmente)";
        }

        if(skusNaoCad.length > 0){
            msg += "\n\n⚠️ ATENÇÃO: " + skusNaoCad.length + " SKU(s) não estão cadastrados no sistema:\n"
                 + skusNaoCad.join(", ")
                 + "\n\n(Foi usada a descrição do Tiny como fallback. Cadastre esses produtos no sistema pra padronizar.)";
        }
        alert(msg);

    }catch(e){
        console.error("[Buscar NF]", e);
        alert("❌ Erro inesperado:\n" + e.message);
    }finally{
        btn.disabled = false;
        btn.textContent = labelOriginal;
    }
}

/* Preenche a página da fatura com os dados vindos do Tiny */
/* Botão "🔬 Debug" — baixa JSON bruto da resposta do Tiny pra análise */
async function debugNFTiny(btn){
    const page = btn.closest(".page");
    if(!page) return;
    const inpNF = page.querySelector(".vc-nf-input");
    const numero = (inpNF?.value || "").trim();

    if(!numero){
        alert("⚠️ Digite o número da NF antes de usar o Debug.");
        inpNF?.focus();
        return;
    }

    const labelOriginal = btn.textContent;
    btn.disabled = true;
    btn.textContent = "⏳";

    try{
        // Passo 1: pesquisa
        const resp1 = await chamarTinyAPI("listar_nf", { numero });

        // Passo 2: detalhes (só se achou)
        let resp2 = null;
        const idNF = resp1?.retorno?.notas_fiscais?.[0]?.nota_fiscal?.id;
        if(idNF){
            resp2 = await chamarTinyAPI("detalhe_nf", { id: idNF });
        }

        // Monta o pacote completo
        const debugData = {
            numero_buscado: numero,
            timestamp: new Date().toISOString(),
            passo_1_pesquisa: resp1,
            passo_2_detalhe: resp2,
            // Atalhos pra análise rápida
            analise: {
                id_encontrado: idNF || null,
                campos_da_nf: resp2?.retorno?.nota_fiscal ? Object.keys(resp2.retorno.nota_fiscal).sort() : null,
                campos_do_cliente: resp2?.retorno?.nota_fiscal?.cliente ? Object.keys(resp2.retorno.nota_fiscal.cliente).sort() : null,
                primeiro_item_campos: resp2?.retorno?.nota_fiscal?.itens?.[0]?.item ? Object.keys(resp2.retorno.nota_fiscal.itens[0].item).sort() : null
            }
        };

        // Gera e baixa o arquivo JSON
        const json = JSON.stringify(debugData, null, 2);
        const blob = new Blob([json], { type: "application/json" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = `debug-nf-${numero}-${Date.now()}.json`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);

        alert("✅ Arquivo de debug baixado!\n\n" +
              "Arquivo: debug-nf-" + numero + ".json\n\n" +
              "Agora você pode abrir esse arquivo e ver todos os campos que o Tiny retorna, " +
              "ou me enviar ele pra eu analisar e implementar o marketplace.");
    }catch(e){
        console.error("[Debug NF]", e);
        alert("❌ Erro: " + e.message);
    }finally{
        btn.disabled = false;
        btn.textContent = labelOriginal;
    }
}


/* Preenche a página da fatura com os dados vindos do Tiny */
async function preencherFaturaComNF(page, nf){
    const cli = nf.cliente || {};
    const itens = nf.itens || [];

    // ── DADOS DO CLIENTE ──
    // Busca todos os inputs editáveis da página pra mapear por label
    const rows = page.querySelectorAll(".row");
    rows.forEach(row => {
        const label = (row.querySelector(".label")?.textContent || "").trim().toLowerCase();
        const inputs = row.querySelectorAll("input.line");

        if(label === "nome:" && inputs[0]){
            inputs[0].value = (cli.nome || "").toUpperCase();
            // Campo "Cel.:" é o segundo input da mesma linha
            if(inputs[1]) inputs[1].value = cli.fone || "";
        }
        else if(label === "rua:" && inputs[0]){
            inputs[0].value = (cli.endereco || "").toUpperCase();
            if(inputs[1]) inputs[1].value = cli.numero || "";
            if(inputs[2]) inputs[2].value = cli.fone || ""; // Fone da linha Rua
        }
        else if(label === "localidade:" && inputs[0]){
            inputs[0].value = (cli.cidade || "").toUpperCase();
            if(inputs[1]) inputs[1].value = (cli.bairro || "").toUpperCase();
        }
        else if(label === "cidade:" && inputs[0]){
            inputs[0].value = (cli.cidade || "").toUpperCase();
            if(inputs[1]) inputs[1].value = (cli.uf || "").toUpperCase();
        }
        else if(label === "cpf:" && inputs[0]){
            inputs[0].value = cli.cpf_cnpj || "";
            if(inputs[1]) inputs[1].value = cli.ie || cli.rg || "";
        }
    });

    // ── DATA DA NF (se estiver em dd/mm/yyyy) ──
    const dataEmissao = nf.data_emissao || ""; // formato "dd/mm/yyyy"
    if(dataEmissao){
        const [dd, mm, yyyy] = dataEmissao.split("/");
        const rowData = [...page.querySelectorAll(".row")].find(r => {
            const lbl = r.querySelector(".label");
            return lbl && lbl.textContent.trim().toLowerCase() === "data,";
        });
        if(rowData){
            const dtInputs = rowData.querySelectorAll("input");
            if(dtInputs[0]) dtInputs[0].value = dd || "";
            if(dtInputs[1]) dtInputs[1].value = mm || "";
            if(dtInputs[2]) dtInputs[2].value = yyyy || "";
        }
    }

    // ── ITENS (linhas da tabela) ──
    // Antes do forEach, resolve TODOS os valores de livro em paralelo (mais rápido).
    // Pra cada item, segue a cadeia de fallback: tabela → cache → API Tiny → valor da NF.
    const valoresLivroPorIdx = await Promise.all(
        itens.map(async (it) => {
            const item = it.item || {};
            const sku = (item.codigo || "").trim();
            const valUnitTiny = parseFloat(item.valor_unitario || "0") || 0;
            return await obterValorLivro(sku, valUnitTiny);
        })
    );

    const tableRows = page.querySelectorAll(".table tr");
    // A primeira tr é o cabeçalho (th), as próximas são os itens
    let linhaIdx = 0;
    const skusNaoEncontrados = []; // pra avisar no final se algum SKU não estiver cadastrado
    tableRows.forEach(tr => {
        if(tr.querySelector("th")) return; // pula cabeçalho
        const tdQuant = tr.querySelectorAll("td input")[0];
        const tdDescTa = tr.querySelector("td textarea.discArea");
        const tdValor = tr.querySelectorAll("td input")[1];

        if(linhaIdx < itens.length){
            const item = itens[linhaIdx].item || {};
            const qtde = parseFloat(item.quantidade || "0");
            const sku = (item.codigo || "").trim();
            // Valor de livro já resolvido em paralelo acima
            const valLivro = valoresLivroPorIdx[linhaIdx];

            if(tdQuant) tdQuant.value = formatarQuantidade(qtde);
            if(tdDescTa){
                // Busca a descrição no banco de produtos do sistema (PRODUTOS do produtos.js)
                // usando o SKU como chave — essa é a descrição padronizada pra fatura
                let descricaoFinal = "";
                if(sku && typeof PRODUTOS !== "undefined" && PRODUTOS[sku]){
                    // Formato: "SKU - DESCRIÇÃO DO SISTEMA"
                    descricaoFinal = sku + " - " + PRODUTOS[sku];
                } else {
                    // SKU não cadastrado no sistema — usa a descrição do Tiny como fallback
                    // e registra pra avisar depois
                    const descTiny = (item.descricao || "").toUpperCase();
                    descricaoFinal = sku ? (sku + " - " + descTiny) : descTiny;
                    if(sku) skusNaoEncontrados.push(sku);
                }
                tdDescTa.value = descricaoFinal;
                // Dispara auto-resize pra acomodar o texto
                if(typeof autoResizeTextarea === "function") autoResizeTextarea(tdDescTa);
            }
            if(tdValor) tdValor.value = formatarValorBR(valLivro);
        } else {
            // Limpa linhas restantes pra não ficar lixo de outras faturas
            if(tdQuant) tdQuant.value = "";
            if(tdDescTa) tdDescTa.value = "";
            if(tdValor) tdValor.value = "";
        }
        linhaIdx++;
    });

    // ── TOTAL ──
    const total = parseFloat(nf.valor_nota || nf.total_nota || 0);
    const inpTotal = page.querySelector(".totalBox");
    if(inpTotal) inpTotal.value = formatarValorBR(total);

    // ── VENDEDOR (marketplace identificado) ──
    const marketplace = identificarMarketplace(nf);
    if(marketplace){
        // Campo Vendedor é o segundo input dentro de .signs
        const sigs = page.querySelectorAll(".signs .line");
        if(sigs[1]) sigs[1].value = marketplace;
    }

    // ── RECALCULA A SOMA AUTOMÁTICA ──
    if(typeof recalcularPagina === "function") recalcularPagina(page);

    // ── GARANTE QUE O Nº NF ESTÁ SALVO NO REGISTRO VC ──
    // Pega o índice desta página
    const indicePage = pages.indexOf(page);
    if(indicePage >= 0){
        const vc = viasCliente.find(v => v.indice === indicePage);
        if(vc){
            const inpNF = page.querySelector(".vc-nf-input");
            const inpCod = page.querySelector(".vc-cod-input");
            const taObs = page.querySelector(".vc-obs-textarea");

            // Extrai a forma de pagamento da NF (ex: "CARTÃO 4X", "PIX", "DINHEIRO")
            const formaPgto = extrairFormaPagamento(nf);

            // Calcula linha de taxa do marketplace usando valor de livro.
            // Se algum SKU não tiver valor de livro na tabela, busca o preço de venda
            // no cadastro do Tiny (com cache em localStorage). Se nem isso existir,
            // cai pro item.valor_unitario da NF como último fallback.
            const linhaMkt = await calcularObsMarketplace(nf, marketplace);

            // Monta a OBS preservando conteúdo do usuário, sem duplicar linhas que a gente
            // mesmo geraria (forma de pagamento e taxa de marketplace). Isso permite
            // re-buscar a mesma NF sem empilhar duplicatas.
            let obsAtual = taObs ? taObs.value : "";
            obsAtual = removerLinhaSeBateRegex(obsAtual, regexFormaPgto());
            obsAtual = removerLinhaSeBateRegex(obsAtual, regexTaxaMarketplace());

            const partes = [];
            if(formaPgto) partes.push(formaPgto);
            if(linhaMkt)  partes.push(linhaMkt);
            if(obsAtual.trim()) partes.push(obsAtual.trim());
            const obsFinal = partes.join("\n");

            // Atualiza o textarea visualmente + redimensiona
            if(taObs){
                taObs.value = obsFinal;
                if(typeof autoResizeTextarea === "function") autoResizeTextarea(taObs);
            }

            vc.nf = inpNF ? inpNF.value : "";
            vc.codCliente = inpCod ? inpCod.value : vc.codCliente;
            vc.obs = obsFinal;
        }
    }

    // ── SALVA NO SERVIDOR/MONGODB ──
    salvar();

    // Retorna info pros alertas finais
    return { skusNaoEncontrados, marketplace };
}

/* ════════════════════════════════════════════════════════════════
   CÁLCULO DA OBS DE MARKETPLACE (Vias de Cliente)
   ════════════════════════════════════════════════════════════════
   Fórmula:
     ValorAposPercentual = totalLivro × (1 - %marketplace)
     TaxaEmReais         = totalProdutos − ValorAposPercentual
     OBS = "{X}% + R$ {TaxaEmReais} Taxa[ + R$ {Frete} Frete][ - R$ {Desc} Desconto {Mkt}]"

   "Valor de livro" de cada item:
     1. VALORES_LIVRO[sku] (tabela fixa em produtos.js)
     2. Cache local de preços do Tiny (localStorage)
     3. Busca no Tiny via API (produtos.pesquisa) e cacheia
     4. item.valor_unitario da NF (fallback final)

   Só funciona pros 4 marketplaces conhecidos. Outros (Shopee, Amazon...) não emitem OBS.
   ════════════════════════════════════════════════════════════════ */
const PERCENTUAIS_MARKETPLACE = {
    "MAGALU":          21,
    "VIA VAREJO":      17,
    "MERCADO LIVRE":   25,
    "MADEIRA MADEIRA": 15
};

/* Nome curto pra exibir na OBS (ex: "Magalu" em vez de "MAGALU") */
const NOMES_CURTOS_MARKETPLACE = {
    "MAGALU":          "Magalu",
    "VIA VAREJO":      "Via Varejo",
    "MERCADO LIVRE":   "ML",
    "MADEIRA MADEIRA": "MM"
};

/* Cache local de preços do Tiny (persistente em localStorage).
   Estrutura: { "sku": precoVenda, ... }
   Não expira automaticamente — o usuário pode limpar manualmente se preço mudar. */
const CACHE_TINY_KEY = "cacheTinyPrecos";

function cacheTinyGet(sku){
    try{
        const raw = localStorage.getItem(CACHE_TINY_KEY);
        if(!raw) return null;
        const obj = JSON.parse(raw);
        return obj && obj[sku] != null ? obj[sku] : null;
    }catch(e){
        return null;
    }
}

function cacheTinySet(sku, preco){
    try{
        const raw = localStorage.getItem(CACHE_TINY_KEY);
        const obj = raw ? JSON.parse(raw) : {};
        obj[sku] = preco;
        localStorage.setItem(CACHE_TINY_KEY, JSON.stringify(obj));
    }catch(e){
        console.warn("[Cache Tiny] Falha ao salvar:", e);
    }
}

/* Busca o preço de venda de um SKU na API do Tiny (produtos.pesquisa).
   Retorna o preço (number) ou null se não encontrar. Não usa cache (chamador faz). */
async function buscarPrecoTinyPorSKU(sku){
    try{
        // Pequeno delay pra ser educado com a API do Tiny (rate limit ~60/min)
        await new Promise(r => setTimeout(r, 200));
        const resp = await chamarTinyAPI("pesquisar_produto", { pesquisa: sku });
        const produtos = resp?.retorno?.produtos || [];
        // produtos.pesquisa retorna lista. Pegamos o item com codigo == sku exato.
        for(const p of produtos){
            const cod = String(p?.produto?.codigo || "").trim();
            if(cod === String(sku).trim()){
                const preco = parseFloat(p.produto.preco);
                if(!isNaN(preco) && preco > 0) return preco;
            }
        }
        return null;
    }catch(e){
        console.warn("[Tiny] Falha ao buscar SKU " + sku + ":", e);
        return null;
    }
}

/* Obtém o "valor de livro" de um SKU seguindo a cadeia de fallback:
     1. VALORES_LIVRO[sku]
     2. Cache localStorage
     3. API do Tiny (produtos.pesquisa) — cacheia se achar
     4. fallbackValorUnitario (item.valor_unitario da NF) — último recurso */
async function obterValorLivro(sku, fallbackValorUnitario){
    if(!sku) return fallbackValorUnitario || 0;

    // 1. Tabela fixa
    if(typeof VALORES_LIVRO !== "undefined" && VALORES_LIVRO[sku] != null){
        return parseFloat(VALORES_LIVRO[sku]);
    }

    // 2. Cache local
    const cached = cacheTinyGet(sku);
    if(cached != null) return parseFloat(cached);

    // 3. Busca no Tiny
    const preco = await buscarPrecoTinyPorSKU(sku);
    if(preco != null){
        cacheTinySet(sku, preco);
        return preco;
    }

    // 4. Fallback final: o valor da NF
    return parseFloat(fallbackValorUnitario) || 0;
}

/* ════════════════════════════════════════════════════════════════
   PREÇO DE CUSTO DO TINY — usado nas FATURAS NORMAIS
   ════════════════════════════════════════════════════════════════
   Diferente do "valor de livro" (preço de venda) usado nas Vias
   de Cliente, aqui buscamos o `preco_custo` do cadastro do Tiny.
   Cache separado pra não misturar com o cache de preços de venda.
   ════════════════════════════════════════════════════════════════ */
const CACHE_CUSTO_KEY = "cacheTinyCusto";

function cacheCustoGet(sku){
    try{
        const raw = localStorage.getItem(CACHE_CUSTO_KEY);
        if(!raw) return null;
        const obj = JSON.parse(raw);
        return obj && obj[sku] != null ? obj[sku] : null;
    }catch(e){
        return null;
    }
}

function cacheCustoSet(sku, preco){
    try{
        const raw = localStorage.getItem(CACHE_CUSTO_KEY);
        const obj = raw ? JSON.parse(raw) : {};
        obj[sku] = preco;
        localStorage.setItem(CACHE_CUSTO_KEY, JSON.stringify(obj));
    }catch(e){
        console.warn("[Cache Custo] Falha ao salvar:", e);
    }
}

/* Busca o preço de CUSTO de um SKU na API do Tiny.
   Fluxo: pesquisar_produto → pega ID → obter_produto → pega preco_custo.
   Retorna o preço (number) ou null se não encontrar. */
async function buscarPrecoCustoTiny(sku){
    if(!sku) return null;
    try{
        // 1. Pesquisa pra pegar o ID
        await new Promise(r => setTimeout(r, 200));
        const respPesq = await chamarTinyAPI("pesquisar_produto", { pesquisa: sku });
        const produtos = respPesq?.retorno?.produtos || [];
        let idProduto = null;
        for(const p of produtos){
            const cod = String(p?.produto?.codigo || "").trim();
            if(cod === String(sku).trim()){
                idProduto = p.produto.id;
                break;
            }
        }
        if(!idProduto) return null;

        // 2. Busca detalhes (que tem o preco_custo)
        await new Promise(r => setTimeout(r, 200));
        const respDet = await chamarTinyAPI("obter_produto", { id: idProduto });
        const det = respDet?.retorno?.produto;
        if(!det) return null;

        const custo = parseFloat(det.preco_custo);
        if(!isNaN(custo) && custo > 0) return custo;
        return null;
    }catch(e){
        console.warn("[Custo Tiny] Falha pra SKU " + sku + ":", e);
        return null;
    }
}

/* Obtém o preço de custo de um SKU usando cache local primeiro, depois Tiny.
   Usado nas faturas NORMAIS (não Vias de Cliente). Retorna number ou null. */
async function obterPrecoCustoTiny(sku){
    if(!sku) return null;
    // Cache primeiro
    const cached = cacheCustoGet(sku);
    if(cached != null) return parseFloat(cached);
    // Busca no Tiny
    const custo = await buscarPrecoCustoTiny(sku);
    if(custo != null){
        cacheCustoSet(sku, custo);
        return custo;
    }
    return null;
}

/* Calcula a linha de OBS de marketplace pra uma NF. Async porque pode buscar API.
   Retorna string vazia se o marketplace não é conhecido. */
async function calcularObsMarketplace(nf, marketplace){
    if(!marketplace) return "";

    const percentual = PERCENTUAIS_MARKETPLACE[marketplace];
    if(percentual == null) return ""; // marketplace desconhecido (Shopee, Amazon, etc)

    const nomeCurto = NOMES_CURTOS_MARKETPLACE[marketplace] || marketplace;
    const itens = nf.itens || [];

    // Soma dos (valorLivro × qtde) de todos os itens — base do cálculo
    let totalLivro = 0;
    for(const it of itens){
        const item = it.item || {};
        const sku = (item.codigo || "").trim();
        const qtde = parseFloat(item.quantidade || "0") || 0;
        const valUnitTiny = parseFloat(item.valor_unitario || "0") || 0;
        const valLivro = await obterValorLivro(sku, valUnitTiny);
        totalLivro += valLivro * qtde;
    }
    if(totalLivro <= 0) return "";

    // Total de produtos: valor que o cliente VIU no marketplace (ANTES de desconto e frete).
    // Se faltar, cai no valor_nota.
    const totalProdutos = parseFloat(
        nf.valor_produtos || nf.total_produtos || nf.valor_nota || nf.total_nota || 0
    );

    // Desconto e frete
    const desconto = parseFloat(nf.valor_desconto || nf.desconto || nf.valor_desc || 0) || 0;
    const frete    = parseFloat(nf.valor_frete    || nf.frete    || 0) || 0;

    // ValorAposPerc é a "linha base" do que o livro renderia depois de aplicar o %
    const valorAposPerc = totalLivro * (1 - percentual / 100);
    // Taxa = quanto o valor de venda passou do valorAposPerc
    const taxaEmReais = totalProdutos - valorAposPerc;

    // Monta a string final na ordem: % + Taxa [+ Frete] [- Desconto Mkt]
    let linha = `${percentual}% + R$ ${formatarValorBR(taxaEmReais)} Taxa`;
    if(frete > 0){
        linha += ` + R$ ${formatarValorBR(frete)} Frete`;
    }
    if(desconto > 0){
        linha += ` - R$ ${formatarValorBR(desconto)} Desconto ${nomeCurto}`;
    }
    return linha;
}

/* Remove de um texto (multilinha) a primeira linha que casa com a regex.
   Usado pra evitar duplicação quando a OBS é regerada (ex: re-busca da mesma NF). */
function removerLinhaSeBateRegex(texto, regex){
    if(!texto) return "";
    const linhas = texto.split(/\r?\n/);
    const idx = linhas.findIndex(l => regex.test(l.trim()));
    if(idx >= 0) linhas.splice(idx, 1);
    return linhas.join("\n");
}

/* Regex que casa com uma linha de forma de pagamento gerada pelo sistema:
   "PIX", "DINHEIRO", "BOLETO", "CARTÃO 4X", "CARTÃO 1X/4X" etc. */
function regexFormaPgto(){
    return /^(PIX|DINHEIRO|BOLETO|CART[ÃA]O[\s\d/X]*)$/i;
}

/* Regex que casa com a linha de taxa de marketplace gerada por este código:
   "21% + R$ 22,95 Taxa", com ou sem " + Frete" e/ou " - Desconto X" no final. */
function regexTaxaMarketplace(){
    return /^\d+%\s*\+\s*R\$\s*[\d.,]+\s*Taxa(\s*\+\s*R\$\s*[\d.,]+\s*Frete)?(\s*-\s*R\$\s*[\d.,]+\s*Desconto\s+\w+)?$/i;
}

/* Helpers de formatação BR */
function formatarValorBR(valor){
    const n = parseFloat(valor) || 0;
    return n.toLocaleString("pt-BR", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}
function formatarQuantidade(q){
    const n = parseFloat(q) || 0;
    // Se for inteiro, mostra sem decimais; se tiver decimais, mostra até 2
    return n % 1 === 0 ? String(n) : n.toLocaleString("pt-BR", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

/* Identifica o marketplace (vendedor) a partir dos dados da NF do Tiny.
   Procura em várias fontes por ordem de confiabilidade e retorna o nome
   padronizado, ou string vazia se não achar. */
/* Verifica se um número de NF já está cadastrado em alguma fatura (Via de Cliente).
   Retorna o índice da fatura que já tem esse NF, ou -1 se não tiver.
   Normaliza o número removendo zeros à esquerda pra evitar falhas por formato
   (ex: "012087" e "12087" devem bater como duplicata). */
function buscarFaturaPorNumeroNF(numeroNF, indiceAIgnorar){
    if(!numeroNF) return -1;
    // Normaliza: remove zeros à esquerda e espaços
    const norm = (s) => String(s || "").trim().replace(/^0+/, "");
    const numeroBuscado = norm(numeroNF);
    if(!numeroBuscado) return -1;

    for(const vc of viasCliente){
        if(vc.indice === indiceAIgnorar) continue; // ignora a própria fatura (útil em edição)
        if(norm(vc.nf) === numeroBuscado) return vc.indice;
    }
    return -1;
}

/* Extrai a forma de pagamento da NF do Tiny e formata pra OBS.
   Formato: "CARTÃO 4X", "PIX", "DINHEIRO", etc. */
function extrairFormaPagamento(nf){
    if(!nf) return "";

    const formaPgto = (nf.forma_pagamento || "").toLowerCase().trim();
    const parcelas = nf.parcelas || [];

    // Mapeia código Tiny → texto amigável (formato simples)
    const mapaFormas = {
        "credito":  "CARTÃO",
        "debito":   "CARTÃO DÉBITO",
        "dinheiro": "DINHEIRO",
        "pix":      "PIX",
        "boleto":   "BOLETO",
        "cheque":   "CHEQUE",
        "transferencia": "TRANSFERÊNCIA",
        "a_vista":  "À VISTA"
    };

    // Caso 1: forma_pagamento simples (não múltipla)
    if(formaPgto !== "multiplas" && mapaFormas[formaPgto]){
        // Crédito com parcelamento
        if(formaPgto === "credito" && parcelas.length > 1){
            return `CARTÃO ${parcelas.length}X`;
        }
        // Crédito 1x
        if(formaPgto === "credito"){
            return "CARTÃO 1X";
        }
        // Outros casos (débito, pix, dinheiro, etc.)
        return mapaFormas[formaPgto];
    }

    // Caso 2: multiplas — olha as parcelas pra detectar o tipo
    if(formaPgto === "multiplas" && parcelas.length > 0){
        // Pega a forma da primeira parcela (geralmente todas são iguais)
        const tipoParcela = (parcelas[0].parcela?.forma_pagamento || "").toLowerCase();
        if(tipoParcela === "credito"){
            return `CARTÃO ${parcelas.length}X`;
        }
        if(tipoParcela === "debito"){
            return parcelas.length > 1 ? `CARTÃO DÉBITO ${parcelas.length}X` : "CARTÃO DÉBITO";
        }
        // Outros tipos com parcelas
        const nomeTipo = mapaFormas[tipoParcela] || tipoParcela.toUpperCase();
        return parcelas.length > 1 ? `${nomeTipo} ${parcelas.length}X` : nomeTipo;
    }

    // Fallback
    if(formaPgto){
        return formaPgto.toUpperCase();
    }

    return "";
}

function identificarMarketplace(nf){
    if(!nf) return "";

    // Coleta todos os textos que podem conter o nome do marketplace
    const fontes = [
        nf.intermediador?.nome || "",           // MELHOR fonte (obrigatório por lei em venda marketplace)
        nf.forma_envio?.descricao || "",        // Ex: "Via Varejo Envvias", "Mercado Envios"
        nf.cliente?.email || "",                // Ex: "...@mktp.extra.com.br"
        nf.obs || "",                           // Texto livre
        nf.natureza_operacao || ""              // Às vezes "Venda Mercado Livre"
    ].join(" | ").toLowerCase();

    // Padrões em ordem de prioridade (mais específico primeiro)
    // Cada marketplace tem suas variações conhecidas
    const padroes = [
        // Mercado Livre: inclui razões sociais antigas (Ebazar, Ibazar), Mercado Pago (mesmo grupo)
        { match: /mercado ?livre|mercadolivre|mercado envios|mercadoenvios|mercado pago|mercadopago|\bmeli\b|\bml\b|ebazar|ibazar/i, nome: "MERCADO LIVRE" },
        { match: /via varejo|casas bahia|casasbahia|ponto frio|pontofrio|\bextra\b|mktp\.extra|extra\.com/i, nome: "VIA VAREJO" },
        { match: /madeira ?madeira|madeiramadeira|\bmm\b/i, nome: "MADEIRA MADEIRA" },
        { match: /magazine luiza|magalu|magazineluiza|\blu\b/i, nome: "MAGALU" },
        { match: /shopee/i, nome: "SHOPEE" },
        { match: /amazon/i, nome: "AMAZON" },
        { match: /americanas|b2w|submarino|shoptime/i, nome: "AMERICANAS" },
        { match: /carrefour/i, nome: "CARREFOUR" },
        { match: /mobly/i, nome: "MOBLY" },
        { match: /leroy merlin|leroymerlin/i, nome: "LEROY MERLIN" }
    ];

    for(const p of padroes){
        if(p.match.test(fontes)) return p.nome;
    }

    // DETECÇÃO POR PADRÃO DE numero_ecommerce:
    // Mercado Livre usa IDs que começam com "2000" e têm 16+ dígitos
    // (ex: 2000012543328483). Como o ML nem sempre preenche intermediador
    // nas NFs, esse é o melhor indicador secundário.
    const numEcom = String(nf.numero_ecommerce || "").trim();
    if(/^2000\d{10,}$/.test(numEcom)){
        return "MERCADO LIVRE";
    }

    // Se não bateu com nenhum padrão conhecido mas tem intermediador, usa ele
    // (caso de marketplace novo que ainda não está na lista)
    if(nf.intermediador?.nome){
        return nf.intermediador.nome.toUpperCase();
    }

    // FALLBACK FINAL: se tem numero_ecommerce mas nenhum marketplace reconhecido,
    // é uma venda de e-commerce (marketplace desconhecido ou marketplace próprio).
    // Retorna "E-COMMERCE" genérico em vez de vazio — assim NÃO é pulada no massivo.
    if(numEcom !== ""){
        return "E-COMMERCE";
    }

    return "";
}

/* ── PREENCHIMENTO MASSIVO ───────────────────────────────────── */

// Estado do massivo — cache das NFs que serão processadas
let _massivoNFs = [];
let _massivoAbortar = false;

/* Abre modal pra começar o preenchimento massivo */
function abrirModalMassivo(){
    // Reset visual
    document.getElementById("massivoEtapaDatas").style.display = "block";
    document.getElementById("massivoEtapaPrevia").style.display = "none";
    document.getElementById("massivoEtapaProgresso").style.display = "none";
    document.getElementById("massivoEtapaRelatorio").style.display = "none";
    _massivoNFs = [];
    _massivoAbortar = false;

    // Sugere datas padrão: mês atual
    const hoje = new Date();
    const primeiroDoMes = new Date(hoje.getFullYear(), hoje.getMonth(), 1);
    document.getElementById("massivoDataInicial").value = primeiroDoMes.toISOString().slice(0,10);
    document.getElementById("massivoDataFinal").value = hoje.toISOString().slice(0,10);

    document.getElementById("modalMassivo").style.display = "flex";
}

function fecharModalMassivo(){
    document.getElementById("modalMassivo").style.display = "none";
    _massivoAbortar = true;
}

function voltarMassivoEtapaDatas(){
    document.getElementById("massivoEtapaDatas").style.display = "block";
    document.getElementById("massivoEtapaPrevia").style.display = "none";
    _massivoNFs = [];
}

/* Converte YYYY-MM-DD pro formato dd/mm/yyyy (que o Tiny aceita) */
function isoParaBR(iso){
    if(!iso) return "";
    const [y, m, d] = iso.split("-");
    return `${d}/${m}/${y}`;
}

/* Etapa 1: busca todas as NFs do período e filtra por marketplace */
async function iniciarPrevia(){
    const dIni = document.getElementById("massivoDataInicial").value;
    const dFim = document.getElementById("massivoDataFinal").value;

    if(!dIni || !dFim){
        alert("⚠️ Preencha as duas datas antes de continuar.");
        return;
    }
    if(dIni > dFim){
        alert("⚠️ A data inicial não pode ser posterior à data final.");
        return;
    }

    const btn = document.getElementById("btnPreviaMassivo");
    btn.disabled = true;
    const labelOriginal = btn.textContent;
    btn.textContent = "⏳ Conectando no Tiny...";

    // Timer visual pra acompanhar quanto tempo tá levando
    const tempoInicio = Date.now();
    let paginaAtual = 0;
    let totalPagsEsperadas = 0;
    let candidatasEncontradas = 0;

    let timerInterval = setInterval(() => {
        const segs = Math.floor((Date.now() - tempoInicio) / 1000);
        if(totalPagsEsperadas > 0){
            btn.textContent = `⏳ Página ${paginaAtual}/${totalPagsEsperadas} • ${candidatasEncontradas} candidatas • ${segs}s`;
        } else {
            btn.textContent = `⏳ Conectando no Tiny... ${segs}s`;
        }
    }, 500);

    try{
        const dataIniBR = isoParaBR(dIni);
        const dataFimBR = isoParaBR(dFim);
        console.log(`[Massivo] Buscando NFs de ${dataIniBR} a ${dataFimBR}...`);

        // Busca TODAS as NFs no período (paginada) — a API do Tiny retorna 100 por página
        // ESTRATÉGIA: pré-filtra candidatas a marketplace durante a paginação,
        // descartando as demais pra não sobrecarregar a memória/parse.
        const candidatasEcommerce = [];
        let pagina = 1;
        let totalPaginas = 1;
        let totalAnalisadas = 0;

        const dominiosML = [
            "mktp.extra","mercadolivre","meli.","magazineluiza","magalu",
            "madeiramadeira","amazon","shopee","americanas","mobly",
            "leroymerlin","carrefour","viavarejo"
        ];

        do {
            const t0 = Date.now();

            const resp = await chamarTinyAPI("listar_nf", {
                dataInicial: dataIniBR,
                dataFinal: dataFimBR,
                pagina: String(pagina),
                tipoNota: "S" // só notas de SAÍDA — filtra entradas direto na API
            });

            const tempoReq = Date.now() - t0;

            if(resp.erro){
                clearInterval(timerInterval);
                alert("❌ Erro ao conectar no Tiny:\n" + resp.erro);
                return;
            }
            const retorno = resp.retorno || {};
            if(retorno.status === "Erro"){
                const erros = (retorno.erros || []).map(e => e.erro || e).join("\n");
                console.warn("[Massivo] Tiny erro:", erros);
                if(erros.toLowerCase().includes("nenhum registro")){
                    break;
                }
                clearInterval(timerInterval);
                alert("❌ Tiny retornou erro:\n" + erros);
                return;
            }

            const notas = retorno.notas_fiscais || [];
            totalPaginas = parseInt(retorno.numero_paginas || 1);
            totalPagsEsperadas = totalPaginas;
            paginaAtual = pagina;

            // SAFETY: se a primeira página retornar mais de 10 páginas totais,
            // o filtro de data provavelmente falhou e tá retornando TUDO.
            // Aborta pra não travar o app.
            if(pagina === 1 && totalPaginas > 10){
                clearInterval(timerInterval);
                const msg = `⚠️ A API retornou ${totalPaginas} páginas (${totalPaginas * 100}+ NFs) — isso indica que o filtro de data não foi aceito pelo Tiny.\n\nPara períodos grandes, tente dividir em pedaços menores (ex: 1 semana por vez).\n\nSe o período já é pequeno e ainda veio muito, reporta esse erro — é um bug da integração.`;
                alert(msg);
                console.error("[Massivo] FILTRO NÃO FUNCIONOU — " + totalPaginas + " páginas retornadas. Verifique os nomes dos parâmetros.");
                return;
            }

            // Filtra LOCALMENTE já nesta página — só guarda candidatas
            for(const n of notas){
                const nf = n.nota_fiscal;
                totalAnalisadas++;

                // Filtro local: candidata a marketplace se tiver numero_ecommerce
                // OU se o email do cliente tiver domínio conhecido de marketplace
                const temNumEcom = nf.numero_ecommerce && nf.numero_ecommerce.trim() !== "";
                const email = (nf.cliente?.email || "").toLowerCase();
                const temDominioML = dominiosML.some(d => email.includes(d));

                if(temNumEcom || temDominioML){
                    candidatasEcommerce.push(nf);
                    candidatasEncontradas = candidatasEcommerce.length;
                }
            }

            console.log(`[Massivo] Pág ${pagina}/${totalPaginas} em ${tempoReq}ms — ${notas.length} NFs (${candidatasEcommerce.length} candidatas totais)`);

            pagina++;
            // Delay mínimo pra respeitar rate limit (30 req/min = 2s entre requisições)
            // Reduzi pra 1s pra ser mais rápido — se der rate limit erro, aumento
            if(pagina <= totalPaginas) await new Promise(r => setTimeout(r, 1000));
        } while(pagina <= totalPaginas);

        clearInterval(timerInterval);
        const tempoTotal = Math.floor((Date.now() - tempoInicio) / 1000);
        console.log(`[Massivo] Busca completa em ${tempoTotal}s. ${totalAnalisadas} NFs analisadas, ${candidatasEcommerce.length} candidatas.`);

        if(totalAnalisadas === 0){
            alert("ℹ️ Nenhuma NF de saída encontrada no período selecionado.");
            return;
        }

        if(candidatasEcommerce.length === 0){
            alert(`ℹ️ Nenhuma NF de marketplace encontrada no período.\n\nAnalisadas: ${totalAnalisadas} NFs de saída\nNenhuma tem indicadores de e-commerce (número de e-commerce ou email de marketplace).\n\nTempo: ${tempoTotal}s`);
            return;
        }

        _massivoNFs = candidatasEcommerce;

        // Calcula quantas faturas em aberto disponíveis
        const faturasDisponiveis = [];
        pages.forEach((page, i) => {
            if(!finalizadas.includes(i)) faturasDisponiveis.push(i);
        });

        // Monta prévia
        const info = document.getElementById("massivoPreviaInfo");
        const lista = document.getElementById("massivoPreviaLista");

        info.innerHTML = `
            <strong>${candidatasEcommerce.length}</strong> NF(s) de marketplace encontrada(s) no período
            <strong>${isoParaBR(dIni)}</strong> a <strong>${isoParaBR(dFim)}</strong>.<br>
            <span style="color:#666;font-size:12px;">(${totalAnalisadas} NFs totais analisadas)</span><br><br>
            Faturas em aberto disponíveis: <strong>${faturasDisponiveis.length}</strong>
            ${faturasDisponiveis.length < candidatasEcommerce.length
                ? `<br><span style="color:#c0392b;font-weight:600;">⚠️ Só ${faturasDisponiveis.length} NFs poderão ser processadas (o resto ficará sem fatura).</span>`
                : ""}
        `;

        lista.innerHTML = candidatasEcommerce.slice(0, 50).map(nf => `
            <div style="padding:4px 0;border-bottom:1px dotted #ddd;">
                NF ${nf.numero} — ${nf.nome || nf.cliente?.nome || "—"}
                <span style="color:#666;">• ${nf.data_emissao}</span>
                <span style="color:#2ecc71;font-weight:600;">• R$ ${nf.valor || "0,00"}</span>
            </div>
        `).join("") + (candidatasEcommerce.length > 50 ? `<div style="padding:6px;color:#666;font-style:italic;">... e mais ${candidatasEcommerce.length - 50} NFs</div>` : "");

        document.getElementById("massivoEtapaDatas").style.display = "none";
        document.getElementById("massivoEtapaPrevia").style.display = "block";

    }catch(e){
        console.error("[Massivo Prévia]", e);
        alert("❌ Erro inesperado:\n" + e.message);
    }finally{
        clearInterval(timerInterval);
        btn.disabled = false;
        btn.textContent = labelOriginal;
    }
}

/* Etapa 3: executa o processamento real */
async function executarMassivo(){
    if(_massivoNFs.length === 0){
        alert("⚠️ Nada pra processar.");
        return;
    }

    // Confirma antes
    if(!confirm(`Confirmar processamento de ${_massivoNFs.length} NF(s)?\n\nCada NF vai:\n• Ativar modo Via de Cliente na próxima fatura em aberto\n• Preencher dados do cliente, itens, vendedor e total\n• Finalizar a fatura\n• Salvar imagem no servidor\n• Arquivar o modo VC\n\nProcesso não pode ser desfeito facilmente.`)) return;

    _massivoAbortar = false;
    document.getElementById("massivoEtapaPrevia").style.display = "none";
    document.getElementById("massivoEtapaProgresso").style.display = "block";

    const barra = document.getElementById("massivoBarraProgresso");
    const texto = document.getElementById("massivoProgTexto");
    const detalhe = document.getElementById("massivoProgDetalhe");

    const total = _massivoNFs.length;
    const sucessos = [];
    const pulados = [];
    const erros = [];
    const skusFaltando = new Set();

    const addLog = (msg) => {
        const linha = document.createElement("div");
        linha.innerHTML = msg;
        detalhe.appendChild(linha);
        detalhe.scrollTop = detalhe.scrollHeight;
    };

    const atualizarProgresso = (i) => {
        const pct = Math.round((i / total) * 100);
        barra.style.width = pct + "%";
        barra.textContent = pct + "%";
        texto.textContent = `Processando ${i} de ${total}...`;
    };

    atualizarProgresso(0);
    addLog("🚀 Iniciando processamento...");

    // Encontra a próxima fatura em aberto (índice da primeira não-finalizada)
    const encontrarProximaFaturaAberta = () => {
        for(let i = 0; i < pages.length; i++){
            if(!finalizadas.includes(i)) return i;
        }
        return -1;
    };

    for(let idx = 0; idx < _massivoNFs.length; idx++){
        if(_massivoAbortar){
            addLog("🛑 Processamento abortado pelo usuário.");
            break;
        }

        const nfResumo = _massivoNFs[idx];
        const numero = nfResumo.numero;

        atualizarProgresso(idx);
        texto.textContent = `Processando ${idx+1} de ${total}: NF ${numero}`;

        try{
            // SEGURANÇA: verifica se essa NF já foi cadastrada em outra fatura
            // (cruzamento de dados pra evitar duplicata)
            const faturaExistente = buscarFaturaPorNumeroNF(numero);
            if(faturaExistente >= 0){
                const numFaturaExistente = String(faturaInicial + faturaExistente).padStart(6, "0");
                pulados.push({ numero, motivo: `Já existe na Fatura ${numFaturaExistente}` });
                addLog(`⚠️ NF ${numero}: já está na Fatura ${numFaturaExistente} — pulada`);
                // Alerta rápido não-bloqueante (não pausa o loop)
                console.warn(`[Massivo] NF ${numero} duplicada — já existe na Fatura ${numFaturaExistente}`);
                continue;
            }

            // Busca próxima fatura disponível
            const indiceFatura = encontrarProximaFaturaAberta();
            if(indiceFatura === -1){
                pulados.push({ numero, motivo: "Sem faturas em aberto disponíveis" });
                addLog(`⚠️ NF ${numero}: sem fatura em aberto — pulada`);
                continue;
            }

            // Busca detalhes completos da NF no Tiny
            const idNF = nfResumo.id;
            if(!idNF){
                erros.push({ numero, motivo: "ID da NF não encontrado" });
                addLog(`❌ NF ${numero}: sem ID — pulada`);
                continue;
            }

            const resp = await chamarTinyAPI("detalhe_nf", { id: idNF });
            if(resp.erro){
                erros.push({ numero, motivo: "Erro na API: " + resp.erro });
                addLog(`❌ NF ${numero}: ${resp.erro}`);
                continue;
            }
            const retorno = resp.retorno || {};
            if(retorno.status === "Erro"){
                const msgErro = (retorno.erros || []).map(e => e.erro || e).join(" / ");
                erros.push({ numero, motivo: msgErro });
                addLog(`❌ NF ${numero}: ${msgErro}`);
                continue;
            }
            const nf = retorno.nota_fiscal;
            if(!nf){
                erros.push({ numero, motivo: "Dados da NF não retornados" });
                addLog(`❌ NF ${numero}: sem dados`);
                continue;
            }

            // Valida que realmente é marketplace (tem intermediador ou forma_envio de marketplace)
            const marketplace = identificarMarketplace(nf);
            if(!marketplace){
                pulados.push({ numero, motivo: "Não é NF de marketplace (sem intermediador identificado)" });
                addLog(`⏭️ NF ${numero}: não é marketplace — pulada`);
                // Delay mesmo pulando pra respeitar rate limit
                await new Promise(r => setTimeout(r, 2000));
                continue;
            }

            // Valida limite de 14 itens
            const itens = nf.itens || [];
            if(itens.length > 14){
                pulados.push({ numero, motivo: `${itens.length} itens (máx 14)` });
                addLog(`⏭️ NF ${numero}: ${itens.length} itens — pulada (máx 14)`);
                await new Promise(r => setTimeout(r, 2000));
                continue;
            }

            // Ativa modo Via de Cliente na fatura
            // Remove registros arquivados antigos dessa fatura se houver
            viasCliente = viasCliente.filter(v => v.indice !== indiceFatura);
            viasCliente.push({
                indice: indiceFatura,
                nf: numero,
                codCliente: "",
                obs: ""
            });

            // Navega pra fatura e aplica visual
            faturaAtual = indiceFatura;
            mostrarFatura();
            aplicarViaClienteNaPagina(indiceFatura);

            // Aguarda DOM atualizar
            await new Promise(r => setTimeout(r, 100));

            const page = pages[indiceFatura];
            if(!page){
                erros.push({ numero, motivo: "Página da fatura não encontrada" });
                addLog(`❌ NF ${numero}: fatura inexistente`);
                continue;
            }

            // Preenche o campo Nº NF visualmente
            const inpNF = page.querySelector(".vc-nf-input");
            if(inpNF) inpNF.value = numero;

            // Preenche todos os dados da NF (cliente, itens, total, vendedor)
            const resultado = await preencherFaturaComNF(page, nf);
            const skusNaoCad = resultado?.skusNaoEncontrados || [];

            // Se tem SKU não cadastrado → pula e desfaz
            if(skusNaoCad.length > 0){
                // Desfaz o preenchimento
                viasCliente = viasCliente.filter(v => v.indice !== indiceFatura);
                aplicarViaClienteNaPagina(indiceFatura);
                // Limpa os campos que foram preenchidos
                limparFatura(indiceFatura);

                pulados.push({ numero, motivo: `SKUs não cadastrados: ${skusNaoCad.join(", ")}` });
                skusNaoCad.forEach(s => skusFaltando.add(s));
                addLog(`⏭️ NF ${numero}: SKU(s) não cadastrado(s): ${skusNaoCad.join(", ")}`);
                await new Promise(r => setTimeout(r, 2000));
                continue;
            }

            // Finaliza a fatura (adiciona à lista de finalizadas)
            if(!finalizadas.includes(indiceFatura)){
                finalizadas.push(indiceFatura);
            }

            // Gera imagem da fatura e envia pro VPS
            const numeroFatura = String(faturaInicial + indiceFatura).padStart(6,"0");
            try {
                await gerarESalvarImagem(numeroFatura);
            } catch(imgErr){
                console.warn("[Massivo] Erro ao gerar imagem:", imgErr);
                addLog(`⚠️ NF ${numero}: imagem não foi gerada (${imgErr.message})`);
            }

            // Arquiva o modo VC (preserva dados, bloqueia edição)
            const vc = viasCliente.find(v => v.indice === indiceFatura);
            if(vc) vc.arquivada = true;
            aplicarViaClienteNaPagina(indiceFatura);

            sucessos.push({ numero, fatura: numeroFatura, cliente: nf.cliente?.nome || "-", marketplace });
            addLog(`✅ NF ${numero} → Fatura ${numeroFatura} (${marketplace})`);

            // Throttle: 2s entre chamadas pra não bater o rate limit do Tiny (30req/min)
            await new Promise(r => setTimeout(r, 2000));

        } catch(e){
            console.error("[Massivo]", e);
            erros.push({ numero, motivo: e.message });
            addLog(`❌ NF ${numero}: ${e.message}`);
            await new Promise(r => setTimeout(r, 2000));
        }
    }

    atualizarProgresso(total);
    texto.textContent = "✅ Processamento concluído!";

    // Sincroniza tudo uma vez só no final
    salvar();

    // Monta relatório final
    const relatorio = document.getElementById("massivoRelatorio");
    relatorio.innerHTML = `
        <h4 style="margin:0 0 10px;color:#27ae60;">✅ Processamento concluído</h4>
        <div style="margin-bottom:10px;">
            <strong>Processadas com sucesso:</strong> ${sucessos.length}<br>
            <strong>Puladas:</strong> ${pulados.length}<br>
            <strong>Com erro:</strong> ${erros.length}
        </div>

        ${sucessos.length > 0 ? `
            <details style="margin-bottom:8px;">
                <summary style="cursor:pointer;color:#27ae60;font-weight:600;">✅ Sucessos (${sucessos.length})</summary>
                <div style="max-height:150px;overflow-y:auto;margin-top:6px;font-size:12px;background:#eafaf1;padding:6px;border-radius:4px;">
                    ${sucessos.map(s => `NF ${s.numero} → Fatura ${s.fatura} — ${s.cliente} (${s.marketplace})`).join("<br>")}
                </div>
            </details>
        ` : ""}

        ${pulados.length > 0 ? `
            <details style="margin-bottom:8px;">
                <summary style="cursor:pointer;color:#e67e22;font-weight:600;">⏭️ Puladas (${pulados.length})</summary>
                <div style="max-height:150px;overflow-y:auto;margin-top:6px;font-size:12px;background:#fef5e7;padding:6px;border-radius:4px;">
                    ${pulados.map(p => `NF ${p.numero}: ${p.motivo}`).join("<br>")}
                </div>
            </details>
        ` : ""}

        ${erros.length > 0 ? `
            <details style="margin-bottom:8px;">
                <summary style="cursor:pointer;color:#c0392b;font-weight:600;">❌ Erros (${erros.length})</summary>
                <div style="max-height:150px;overflow-y:auto;margin-top:6px;font-size:12px;background:#fadbd8;padding:6px;border-radius:4px;">
                    ${erros.map(e => `NF ${e.numero}: ${e.motivo}`).join("<br>")}
                </div>
            </details>
        ` : ""}

        ${skusFaltando.size > 0 ? `
            <div style="margin-top:10px;padding:8px;background:#fff3cd;border-left:3px solid #f39c12;border-radius:4px;font-size:12px;">
                <strong>📦 SKUs não cadastrados:</strong><br>
                ${[...skusFaltando].join(", ")}<br><br>
                <em>Cadastre esses produtos no sistema pra que eles sejam aceitos no próximo massivo.</em>
            </div>
        ` : ""}
    `;

    document.getElementById("massivoEtapaProgresso").style.display = "none";
    document.getElementById("massivoEtapaRelatorio").style.display = "block";
}

/* Helper: limpa uma fatura (pra quando o preenchimento falha no massivo) */
function limparFatura(indice){
    const page = pages[indice];
    if(!page) return;

    // Limpa todos os inputs da fatura
    page.querySelectorAll("input.line, input.flex").forEach(inp => inp.value = "");
    page.querySelectorAll("textarea.discArea").forEach(ta => ta.value = "");
    page.querySelectorAll(".table td input").forEach(inp => inp.value = "");
    const totalBox = page.querySelector(".totalBox");
    if(totalBox) totalBox.value = "";
    const somaBox = page.querySelector(".somaBox");
    if(somaBox) somaBox.value = "";
    // Campos do VC
    const inpNF = page.querySelector(".vc-nf-input");
    const inpCod = page.querySelector(".vc-cod-input");
    const taObs = page.querySelector(".vc-obs-textarea");
    if(inpNF) inpNF.value = "";
    if(inpCod) inpCod.value = "";
    if(taObs) taObs.value = "";
}

/* ── SALVAR ──────────────────────────────────────────────────── */
function salvar(){
    const dados = [];
    const refFats = [];

    pages.forEach(page=>{
        dados.push(
            inputsEditaveis(page).map(i=>i.value)
        );
        refFats.push(getRefFatValores(page));
    });

    // Atualiza dados do Via de Cliente pra fatura atual (se estiver em modo VC)
    atualizarDadosViaClienteAtual();

    // Persiste localmente (fallback offline)
    localStorage.setItem("faturasDados", JSON.stringify(dados));
    localStorage.setItem("faturaAtual", faturaAtual);
    localStorage.setItem("faturasFinalizadas", JSON.stringify(finalizadas));
    localStorage.setItem("faturasConferidas", JSON.stringify(conferidas));
    localStorage.setItem("faturasRefFats", JSON.stringify(refFats));
    localStorage.setItem("faturasViasCliente", JSON.stringify(viasCliente));

    // Envia para o servidor → propaga para todos os clientes (celular/PC)
    if (socket.connected) {
        syncDot.className = "sync-dot syncing";
        socket.emit("update-data", { dados, finalizadas, conferidas, refFats, viasCliente });
        // Limpa pendente se existia
        localStorage.removeItem("faturasPendente");
    } else {
        // Sem conexão — salva como pendente para sincronizar quando voltar
        localStorage.setItem("faturasPendente", JSON.stringify({ dados, finalizadas, conferidas, refFats, viasCliente }));
        syncDot.className = "sync-dot disconnected";
        syncLabel.textContent = "Offline — pendente";
    }
}

/* ── CARREGAR (usado apenas no boot, como fallback offline) ───── */
function carregar(){
    // Remove chaves antigas (versão anterior usava "pedidos*")
    ["pedidosDados","pedidoAtual","pedidosFinalizados"].forEach(k => localStorage.removeItem(k));
    // Marca versão para detectar primeiro boot após atualização
    const versaoAtual = "v7";
    if(localStorage.getItem("versao") !== versaoAtual){
        localStorage.removeItem("faturasDados");
        localStorage.removeItem("faturaAtual");
        localStorage.removeItem("faturasFinalizadas");
        localStorage.setItem("versao", versaoAtual);
    }

    const atual = localStorage.getItem("faturaAtual");
    if(atual !== null) faturaAtual = parseInt(atual);

    // Vai direto para a primeira fatura em aberto (não finalizada)
    const primeiraAberta = Array.from({length: pages.length}, (_,i) => i)
      .find(i => !finalizadas.includes(i));
    if(primeiraAberta !== undefined) faturaAtual = primeiraAberta;

    const dados = localStorage.getItem("faturasDados");
    if(!dados) return;

    const lista = JSON.parse(dados);

    // Detecta dados corrompidos: qtd de valores por página diferente do esperado
    const inputsEsperados = inputsEditaveis(pages[0]).length;
    const corrompido = lista.some(p => Array.isArray(p) && p.length !== inputsEsperados);

    if(corrompido){
        console.warn("Dados corrompidos detectados — limpando storage.");
        limparDados(false);
        return;
    }

    pages.forEach((page,p)=>{
        const inputs = inputsEditaveis(page);
        if(lista[p]){
            inputs.forEach((inp,i)=>{
                if(lista[p][i] !== undefined) inp.value = lista[p][i];
            });
        }
    });

    // Carrega refFats do localStorage
    const refFatsStr = localStorage.getItem("faturasRefFats");
    if(refFatsStr){
        try {
            const refFats = JSON.parse(refFatsStr);
            pages.forEach((page, p) => {
                if(refFats[p]) setRefFatValores(page, refFats[p]);
            });
        } catch(e){}
    }

    recalcularTodos();
    // Redimensiona textareas e ajusta linhas da tabela para conteúdo longo expandir
    pages.forEach(page => {
        page.querySelectorAll("textarea.discArea").forEach(ta => autoResizeTextarea(ta));
        if(typeof ajustarLinhasTabela === "function") ajustarLinhasTabela(page);
    });
}

/* ── LIMPAR DADOS ────────────────────────────────────────────── */
function limparDados(confirmar = true){
    if(confirmar && !confirm("Apagar todos os dados salvos e começar do zero?")) return;
    localStorage.removeItem("faturasDados");
    localStorage.removeItem("faturaAtual");
    localStorage.removeItem("faturasFinalizadas");
    finalizadas = [];
    faturaAtual = 0;
    pages.forEach(page => {
        inputsEditaveis(page).forEach(inp => {
            inp.value = "";
            if(inp.tagName === "TEXTAREA") autoResizeTextarea(inp);
        });
    });
    recalcularTodos();
    mostrarFatura();
    if(socket.connected) socket.emit("update-data", pages.map(page => inputsEditaveis(page).map(i => i.value)));
}

/* ── MOSTRAR ─────────────────────────────────────────────────── */
function mostrarFatura(){
    pages.forEach((p,i)=>{
        // Lazy loading — só renderiza fatura atual
        const visivel = i===faturaAtual;
        p.style.display = visivel ? "block" : "none";
        // Marca como carregada para otimização futura
        if(visivel && !p.dataset.loaded) p.dataset.loaded="1";
    });

    aplicarBloqueio();

    // Redimensiona textareas da fatura que acabou de ficar visível
    // (precisa fazer aqui porque scrollHeight=0 quando display:none)
    const pageAtual = pages[faturaAtual];
    if(pageAtual){
        pageAtual.querySelectorAll("textarea.discArea").forEach(ta => autoResizeTextarea(ta));
        if(typeof ajustarLinhasTabela === "function") ajustarLinhasTabela(pageAtual);

        // Mostra o REF FAT se já tem valores salvos (pra continuar visível ao voltar numa fatura do cliente 396)
        const wrap = pageAtual.querySelector(".ref-fat-wrap");
        if(wrap){
            const valores = getRefFatValores(pageAtual);
            if(valores){
                wrap.style.display = "flex";
                pageAtual.classList.add("com-ref-fat");
            }
        }

        // Aplica modo Via de Cliente se estiver ativo na fatura atual
        aplicarViaClienteNaPagina(faturaAtual);
    }

    // Atualiza o botão do painel conforme a fatura atual
    atualizarBotaoViaCliente();

    const numero = String(faturaInicial+faturaAtual).padStart(6,"0");
    let status = "EM ABERTO";

    if(finalizadas.includes(faturaAtual)){
        status = "FINALIZADA";
    }else if(
        faturaAtual > 0 &&
        !finalizadas.includes(faturaAtual-1)
    ){
        status = "BLOQUEADA";
    }

    document.getElementById("statusFatura").textContent =
    "Fatura "+numero+" | "+status;

    recalcularAtual();
}

/* ── BLOQUEIO ────────────────────────────────────────────────── */
function aplicarBloqueio(){
    // Se está em modo edição autorizado, não aplica bloqueio
    if(modoEdicao) return;

    let liberar = true;

    // Bloqueia se já foi finalizada
    if(finalizadas.includes(faturaAtual)){
        liberar = false;
    }
    // Bloqueia se é fatura futura (anterior ainda não finalizada)
    else if(faturaAtual > 0 && !finalizadas.includes(faturaAtual - 1)){
        liberar = false;
    }

    const campos = pages[faturaAtual].querySelectorAll("input, textarea.discArea");
    campos.forEach(inp=>{
        inp.disabled = !liberar;
        inp.style.background = liberar ? "" : "#f3f3f3";
    });

    // EXCEÇÃO: mesmo com a fatura bloqueada/finalizada, o CÓD CLIENTE do modo
    // Via de Cliente arquivada continua editável ATÉ ser confirmado pelo botão ✓.
    // Isso permite que a pessoa que faz o preenchimento massivo possa colocar
    // o código do cliente depois, sem precisar destravar a fatura inteira.
    if(!liberar){
        const vc = viasCliente.find(v => v.indice === faturaAtual);
        if(vc && vc.arquivada && !vc.codConfirmado){
            const inpCod = pages[faturaAtual].querySelector(".vc-cod-input");
            if(inpCod){
                inpCod.disabled = false;
                inpCod.style.background = "";
            }
        }
    }
}

/* ── FINALIZAR ───────────────────────────────────────────────── */
/* ── VALIDAÇÃO DE CAMPOS OBRIGATÓRIOS ─────────────────────── */
/* Retorna lista de campos faltando na fatura atual.
   Cada item: { label, inputs: [HTMLElement, ...] } */
function validarCamposObrigatorios(){
    const page = pages[faturaAtual];
    if(!page) return [];
    const faltando = [];

    // Helper: pega input pelo label
    function inputPorLabel(texto){
        const spans = [...page.querySelectorAll("span.label")];
        const span = spans.find(s => s.textContent.trim().replace(/:$/,"") === texto.replace(/:$/,""));
        if(!span) return null;
        return span.parentElement.querySelector("input.line, input.flex");
    }

    // Nome
    const inpNome = inputPorLabel("Nome");
    if(inpNome && !inpNome.value.trim()){
        faltando.push({ label: "Nome", inputs: [inpNome] });
    }

    // Cidade
    const inpCidade = inputPorLabel("Cidade");
    if(inpCidade && !inpCidade.value.trim()){
        faltando.push({ label: "Cidade", inputs: [inpCidade] });
    }

    // Data (3 inputs na primeira row: dia/mês/ano)
    const primeiraRow = page.querySelector(".row");
    if(primeiraRow){
        const inputsData = [...primeiraRow.querySelectorAll("input.line")].slice(0, 3);
        const algumVazio = inputsData.some(i => !i.value.trim());
        if(algumVazio){
            faltando.push({ label: "Data", inputs: inputsData.filter(i => !i.value.trim()) });
        }
    }

    // TOTAL (input com classe totalBox)
    const inpTotal = page.querySelector("input.totalBox");
    if(inpTotal && !inpTotal.value.trim()){
        faltando.push({ label: "TOTAL", inputs: [inpTotal] });
    }

    // Vendedor — segundo input dentro de .signs
    const signs = page.querySelector(".signs");
    if(signs){
        const sigs = [...signs.querySelectorAll(".sig input.line")];
        if(sigs.length >= 2 && !sigs[1].value.trim()){
            faltando.push({ label: "Vendedor", inputs: [sigs[1]] });
        }
    }

    // Linhas da tabela de produtos — se qualquer campo de uma linha foi preenchido,
    // os outros 2 (Quant / Discriminação / Valor) viram obrigatórios
    const linhas = [...page.querySelectorAll(".table tr")].slice(1); // pula header
    linhas.forEach((tr, idx) => {
        const inpQuant = tr.querySelector("td:nth-child(1) input");
        const taDisc   = tr.querySelector("td:nth-child(2) textarea.discArea");
        const inpValor = tr.querySelector("td:nth-child(3) input");
        if(!inpQuant || !taDisc || !inpValor) return;

        const vQuant = inpQuant.value.trim();
        const vDisc  = taDisc.value.trim();
        const vValor = inpValor.value.trim();

        // Se nenhum dos três foi preenchido, pula (linha vazia é permitida)
        if(!vQuant && !vDisc && !vValor) return;

        // Se pelo menos um está preenchido, os 3 viram obrigatórios
        const vazios = [];
        if(!vQuant) vazios.push(inpQuant);
        if(!vDisc)  vazios.push(taDisc);
        if(!vValor) vazios.push(inpValor);

        if(vazios.length > 0){
            faltando.push({
                label: `Linha ${idx + 1} da tabela (Quant / Discriminação / Valor)`,
                inputs: vazios
            });
        }
    });

    return faltando;
}

/* Marca os inputs faltando em vermelho e remove quando o usuário digitar */
function destacarCamposVazios(faltando){
    faltando.forEach(item => {
        item.inputs.forEach(inp => {
            inp.classList.add("campo-obrigatorio-vazio");
            const limpar = () => {
                inp.classList.remove("campo-obrigatorio-vazio");
                inp.removeEventListener("input", limpar);
            };
            inp.addEventListener("input", limpar);
        });
    });
    // Foca no primeiro campo vazio (modal HTML não bagunça o caret como o alert nativo)
    if(faltando.length && faltando[0].inputs.length){
        const alvo = faltando[0].inputs[0];
        try {
            alvo.focus();
            if(typeof alvo.setSelectionRange === "function"){
                const pos = alvo.value.length;
                alvo.setSelectionRange(pos, pos);
            }
        } catch(e){}
    }
}

/* ── MODAL DE AVISO (substitui alert nativo) ─────────────────── */
// Usa callback porque o modal é HTML, não bloqueia execução como alert()
let _avisoCallback = null;
function mostrarAviso(titulo, mensagem, callback){
    document.getElementById("avisoTitulo").textContent = titulo || "⚠️ Atenção";
    document.getElementById("avisoMsg").textContent = mensagem || "";
    document.getElementById("modalAviso").classList.add("ativo");
    _avisoCallback = callback || null;
    // Foca no botão OK pra poder apertar Enter
    setTimeout(() => {
        try { document.getElementById("btnConfirmarAviso").focus(); } catch(e){}
    }, 100);
}

function fecharAviso(){
    document.getElementById("modalAviso").classList.remove("ativo");
    const cb = _avisoCallback;
    _avisoCallback = null;
    if(typeof cb === "function"){
        // pequeno delay pro modal sumir antes de executar o callback
        setTimeout(cb, 60);
    }
}

// Enter e Escape fecham o aviso
document.addEventListener("keydown", (e) => {
    if(document.getElementById("modalAviso").classList.contains("ativo")){
        if(e.key === "Enter" || e.key === "Escape"){
            e.preventDefault();
            fecharAviso();
        }
    }
});

/* ── PAINEL DE BUSCA E FILTRO ────────────────────────────────── */
function abrirPainelBusca(){
    document.getElementById("painelBusca").classList.add("ativo");
    aplicarFiltroBusca();
    setTimeout(() => {
        try { document.getElementById("buscaNumero").focus(); } catch(e){}
    }, 250);
}

function fecharPainelBusca(){
    document.getElementById("painelBusca").classList.remove("ativo");
}

// Fecha painel ao clicar fora
document.addEventListener("click", (e) => {
    const painel = document.getElementById("painelBusca");
    if(!painel || !painel.classList.contains("ativo")) return;
    // Só fecha se clicou no overlay (fora do conteúdo)
    if(e.target === painel) fecharPainelBusca();
});

// Escape fecha
document.addEventListener("keydown", (e) => {
    if(e.key === "Escape"){
        const painel = document.getElementById("painelBusca");
        if(painel && painel.classList.contains("ativo")) fecharPainelBusca();
    }
});

/* Converte data em formato DD/MM/AAAA ou DD, MM, AAAA dos campos da fatura
   Retorna objeto Date ou null se inválida */
function parseDataFatura(page){
    const primeiraRow = page.querySelector(".row");
    if(!primeiraRow) return null;
    const inputs = [...primeiraRow.querySelectorAll("input.line")].slice(0, 3);
    if(inputs.length < 3) return null;
    const dia = parseInt((inputs[0].value || "").trim());
    const mes = parseInt((inputs[1].value || "").trim());
    let ano = parseInt((inputs[2].value || "").trim());
    if(!dia || !mes || !ano) return null;
    // Aceita ano com 2 dígitos (25 -> 2025) ou 4 dígitos
    if(ano < 100) ano = 2000 + ano;
    const d = new Date(ano, mes - 1, dia);
    if(isNaN(d.getTime())) return null;
    return d;
}

/* Extrai nome do cliente da fatura */
function nomeClienteFatura(page){
    const spans = [...page.querySelectorAll("span.label")];
    const spanNome = spans.find(s => s.textContent.trim().replace(/:$/,"") === "Nome");
    if(!spanNome) return "";
    const inp = spanNome.parentElement.querySelector("input.line, input.flex");
    return inp ? inp.value.trim() : "";
}

/* Extrai total da fatura */
function totalFatura(page){
    const inp = page.querySelector("input.totalBox");
    return inp ? inp.value.trim() : "";
}

/* Atalhos de período pra facilitar */
function aplicarPeriodo(tipo){
    const hoje = new Date();
    const fmt = d => d.toISOString().slice(0, 10);
    const inicio = document.getElementById("buscaDataInicio");
    const fim    = document.getElementById("buscaDataFim");
    if(tipo === "hoje"){
        inicio.value = fmt(hoje);
        fim.value    = fmt(hoje);
    } else if(tipo === "ontem"){
        const ontem = new Date(hoje); ontem.setDate(hoje.getDate() - 1);
        inicio.value = fmt(ontem);
        fim.value    = fmt(ontem);
    } else if(tipo === "7dias"){
        const h7 = new Date(hoje); h7.setDate(hoje.getDate() - 6);
        inicio.value = fmt(h7);
        fim.value    = fmt(hoje);
    } else if(tipo === "mes"){
        const ini = new Date(hoje.getFullYear(), hoje.getMonth(), 1);
        inicio.value = fmt(ini);
        fim.value    = fmt(hoje);
    } else if(tipo === "limpar"){
        inicio.value = "";
        fim.value    = "";
    }
    aplicarFiltroBusca();
}

/* Aplica o filtro e busca, atualizando a lista de resultados */
// Estado do filtro por tipo (todas | via-cliente)
let _filtroTipoAtivo = "todas";

function aplicarFiltroTipo(tipo){
    _filtroTipoAtivo = tipo;
    // Destaca visualmente qual filtro está ativo
    const btnTodas = document.getElementById("btnFiltroTodas");
    const btnVC = document.getElementById("btnFiltroVC");
    if(btnTodas && btnVC){
        if(tipo === "via-cliente"){
            btnTodas.style.opacity = "0.5";
            btnVC.style.opacity = "1";
            btnVC.style.transform = "scale(1.05)";
            btnTodas.style.transform = "scale(1)";
        } else {
            btnTodas.style.opacity = "1";
            btnVC.style.opacity = "0.7";
            btnTodas.style.transform = "scale(1.05)";
            btnVC.style.transform = "scale(1)";
        }
    }
    aplicarFiltroBusca();
}

function aplicarFiltroBusca(){
    const termoNum = (document.getElementById("buscaNumero").value || "").trim();
    const dataIni  = document.getElementById("buscaDataInicio").value;
    const dataFim  = document.getElementById("buscaDataFim").value;

    const dIni = dataIni ? new Date(dataIni + "T00:00:00") : null;
    const dFim = dataFim ? new Date(dataFim + "T23:59:59") : null;

    const resultados = [];
    pages.forEach((page, i) => {
        const numFatura = String(faturaInicial + i).padStart(6, "0");

        // Filtro por número — compara como texto contendo
        if(termoNum){
            const numSemZeros = String(faturaInicial + i); // sem padStart
            if(!numFatura.includes(termoNum) && !numSemZeros.includes(termoNum)) return;
        }

        // Filtro por data
        if(dIni || dFim){
            const dataFat = parseDataFatura(page);
            if(!dataFat) return; // faturas sem data não aparecem em filtro de data
            if(dIni && dataFat < dIni) return;
            if(dFim && dataFat > dFim) return;
        }

        // Filtro por tipo (Via de Cliente)
        if(_filtroTipoAtivo === "via-cliente" && !foiViaCliente(i)) return;

        resultados.push({
            indice: i,
            numero: numFatura,
            cliente: nomeClienteFatura(page),
            data: parseDataFatura(page),
            total: totalFatura(page)
        });
    });

    renderizarResultadosBusca(resultados);
}

function renderizarResultadosBusca(resultados){
    const resumo = document.getElementById("buscaResumo");
    const lista  = document.getElementById("buscaResultados");
    resumo.textContent = `${resultados.length} fatura${resultados.length === 1 ? "" : "s"} encontrada${resultados.length === 1 ? "" : "s"}`;

    if(resultados.length === 0){
        lista.innerHTML = '<div class="painel-vazio">Nenhuma fatura corresponde aos filtros.</div>';
        return;
    }

    lista.innerHTML = "";
    resultados.forEach(r => {
        const div = document.createElement("div");
        div.className = "resultado-item";
        let statusClass = "aberto";
        let statusTxt = "Em aberto";
        if(conferidas.find(c => c.indice === r.indice)){
            statusClass = "conferida";
            statusTxt = "Conferida";
        } else if(finalizadas.includes(r.indice)){
            statusClass = "finalizada";
            statusTxt = "Finalizada";
        }
        const dataStr = r.data ? r.data.toLocaleDateString("pt-BR") : "—";

        // Tag de Via de Cliente — aparece em qualquer fatura que tenha ou teve VC
        const tagVC = foiViaCliente(r.indice)
            ? '<span class="res-status via-cliente">📋 Via de Cliente</span>'
            : '';

        div.innerHTML = `
            <div class="res-numero">Nº ${r.numero}
                <span class="res-status ${statusClass}">${statusTxt}</span>
                ${tagVC}
            </div>
            <div class="res-info">
                ${r.cliente || "<sem nome>"} • ${dataStr}
                ${r.total ? " • R$ " + r.total : ""}
            </div>
        `;
        div.addEventListener("click", () => {
            faturaAtual = r.indice;
            mostrarFatura();
            salvar();
            fecharPainelBusca();
        });
        lista.appendChild(div);
    });
}

async function finalizarFatura(){
    const numero = String(faturaInicial + faturaAtual).padStart(6,"0");

    if(finalizadas.includes(faturaAtual)){
        mostrarAviso("Fatura já finalizada", "Esta fatura já foi finalizada anteriormente.");
        return;
    }

    // Validação de campos obrigatórios
    const faltando = validarCamposObrigatorios();
    if(faltando.length > 0){
        const lista = faltando.map(f => "• " + f.label).join("\n");
        mostrarAviso(
            "⚠️ Campos obrigatórios",
            "Preencha os campos obrigatórios antes de finalizar:\n\n" + lista,
            () => destacarCamposVazios(faltando) // Destaca e foca DEPOIS do modal fechar
        );
        return;
    }

    finalizadas.push(faturaAtual);
    // Se estiver em modo Via de Cliente, garante que os valores estão salvos
    if(isViaClienteAtiva(faturaAtual)){
        atualizarDadosViaClienteAtual();
    }
    // Força salvar imediatamente sem debounce ao finalizar
    clearTimeout(_salvarTimer);
    salvar();

    // Gera imagem e salva no servidor
    await gerarESalvarImagem(numero);

    // Em qualquer caso (Electron ou Chrome), abre modal para imprimir
    // Só avança para próxima fatura após clicar em Imprimir no modal
    abrirModalImpressao(numero);
}

/* ── CAPTURA E SALVA IMAGEM DA FATURA ───────────────────────── */
async function gerarESalvarImagem(numero){
    try{
        const page = pages[faturaAtual];

        // Esconde elementos que não devem aparecer na imagem
        const topbar = document.querySelector('.topbar');
        const sidebar = document.querySelector('.lista-clientes');
        const topbarDisplay = topbar.style.display;
        const sidebarDisplay = sidebar.style.display;
        topbar.style.display = 'none';
        sidebar.style.display = 'none';

        // Marca campos vazios da Via de Cliente com classe "vazio" pra que fiquem ocultos
        const vcNFWrap = page.querySelector(".vc-nf-wrap");
        const vcCodWrap = page.querySelector(".vc-cod-wrap");
        const vcNF = page.querySelector(".vc-nf-input");
        const vcCod = page.querySelector(".vc-cod-input");
        if(vcNFWrap){
            if(!vcNF || !vcNF.value.trim()) vcNFWrap.classList.add("vazio");
            else vcNFWrap.classList.remove("vazio");
        }
        if(vcCodWrap){
            if(!vcCod || !vcCod.value.trim()) vcCodWrap.classList.add("vazio");
            else vcCodWrap.classList.remove("vazio");
        }
        // Adiciona classe "gerando-pdf" temporariamente pra CSS esconder campos vazios
        page.classList.add("gerando-pdf");

        // Captura a fatura como canvas
        const canvas = await html2canvas(page, {
            scale: 2,           // alta resolução
            useCORS: true,
            backgroundColor: '#ffffff',
            width: page.offsetWidth,
            height: page.offsetHeight,
            windowWidth: page.offsetWidth,
            windowHeight: page.offsetHeight,
        });

        // Restaura elementos
        topbar.style.display = topbarDisplay;
        sidebar.style.display = sidebarDisplay;
        page.classList.remove("gerando-pdf");

        // Converte para base64
        const imgBase64 = canvas.toDataURL('image/jpeg', 0.92).split(',')[1];

        // Envia para o servidor PC1 salvar
        socket.emit('salvar-imagem', { numero, imgBase64 });
        console.log('Imagem enviada para salvar: FAT ' + numero);

        // Salva cópia local via IPC (só funciona em Electron, no navegador é ignorado silenciosamente)
        if(typeof require === "function"){
          try{
            const { ipcRenderer } = require('electron');
            ipcRenderer.invoke('salvar-imagem-local', { numero, imgBase64 });
          }catch(e){ console.log('Cópia local Electron não salva:', e.message); }
        }
        // Se estiver no navegador (sem Electron), não tenta — a imagem já foi enviada pro VPS

    }catch(e){
        console.error('Erro ao gerar imagem:', e);
    }
}

function avancarFatura(){
    if(faturaAtual < totalFaturas - 1){
        faturaAtual++;
    }
    mostrarFatura();
}

/* ── MODAL IMPRESSÃO CHROME ─────────────────────────────────── */
function abrirModalImpressao(numero){
    document.getElementById("modalImpressaoNumero").textContent =
        "Fatura " + numero + " — escolha o que deseja fazer:";
    document.getElementById("modalImpressao").classList.add("ativo");
}

function fecharModalImpressao(){
    document.getElementById("modalImpressao").classList.remove("ativo");
    avancarFatura();
}

function imprimirPDF(){
    // Fecha o modal SEM avançar fatura
    document.getElementById("modalImpressao").classList.remove("ativo");
    // 1ª impressão: salvar como PDF com nome correto
    const numero = String(faturaInicial + faturaAtual).padStart(6,"0");
    const tituloOriginal = document.title;
    document.title = "FAT " + numero;
    setTimeout(() => {
        window.print();
        document.title = tituloOriginal;
        // Após salvar PDF, abre modal para imprimir
        setTimeout(() => {
            abrirModalImprimir();
        }, 1000);
    }, 300);
}

function abrirModalImprimir(){
    document.getElementById("modalImprimir").classList.add("ativo");
}

function fecharModalImprimir(){
    document.getElementById("modalImprimir").classList.remove("ativo");
}

function fecharModalImprimirSemImprimir(){
    document.getElementById("modalImprimir").classList.remove("ativo");
    avancarFatura();
}

function confirmarImprimir(){
    // Fecha modal sem avançar
    document.getElementById("modalImprimir").classList.remove("ativo");
    // Imprime a fatura atual e só então avança
    setTimeout(() => {
        window.print();
        setTimeout(() => avancarFatura(), 500);
    }, 300);
}

function imprimirImpressora(){
    document.getElementById("modalImpressao").classList.remove("ativo");
    setTimeout(() => {
        window.print();
        setTimeout(() => avancarFatura(), 500);
    }, 300);
}

/* ── ALTURA FIXA DA LINHA ────────────────────────────────────── */
const ALTURA_LINHA = 29; // px — altura de cada linha da tabela

function autoResizeTextarea(ta){
    ta.style.height = "auto";
    ta.style.height = ta.scrollHeight + "px";
}

// Recalcula quais linhas da tabela ficam visíveis para manter a tabela no tamanho fixo
function ajustarLinhasTabela(page){
    const linhas = [...page.querySelectorAll(".table tr")].slice(1); // pula header
    const totalLinhas = linhas.length; // 14

    // Primeiro: redimensiona todos os textareas
    linhas.forEach(tr => {
        const ta = tr.querySelector("textarea.discArea");
        if(ta) autoResizeTextarea(ta);
    });

    // Calcula quantos "slots" cada linha ocupa (arredonda para cima)
    const slots = linhas.map(tr => {
        const ta = tr.querySelector("textarea.discArea");
        if(!ta || !ta.value.trim()) return 1;
        const h = ta.scrollHeight;
        return Math.max(1, Math.round(h / ALTURA_LINHA));
    });

    // Mostra/oculta linhas para que a soma de slots não passe de totalLinhas
    let slotsUsados = 0;
    linhas.forEach((tr, i) => {
        const slot = slots[i];
        if(slotsUsados + slot <= totalLinhas){
            tr.style.display = "";
            slotsUsados += slot;
        } else {
            // Esconde linhas vazias do final para compensar
            const ta = tr.querySelector("textarea.discArea");
            const temConteudo = ta && ta.value.trim();
            if(!temConteudo){
                tr.style.display = "none";
            } else {
                tr.style.display = "";
                slotsUsados += slot;
            }
        }
    });
}

function vincularAutoResizes(){
    pages.forEach(page => {
        page.querySelectorAll("textarea.discArea").forEach(ta => {
            if(ta.dataset.resize) return;
            ta.dataset.resize = "1";
            ta.addEventListener("input", () => {
                autoResizeTextarea(ta);
                ajustarLinhasTabela(ta.closest(".page"));
            });
            autoResizeTextarea(ta);
        });
        ajustarLinhasTabela(page);
    });
}

/* ── LISTA LATERAL DE CLIENTES ──────────────────────────────── */
function popularListaClientes(){
    const container = document.getElementById("listaClientesItens");
    if(!container) return;
    Object.entries(CLIENTES)
        .sort((a,b) => parseInt(a[0]) - parseInt(b[0]))
        .forEach(([cod, c]) => {
            const item = document.createElement("div");
            item.className = "lista-clientes-item";
            item.innerHTML = `<span class="lista-clientes-cod">${cod} -</span><span class="lista-clientes-cidade">${c.cidade}</span>`;
            container.appendChild(item);
        });
}

/* ── AUTOCOMPLETE DE CLIENTES (campo Nome) ───────────────────── */
function vincularAutocompleteClientes(){
    pages.forEach(page => {
        // Campo Nome é o primeiro input da row topspace
        const inpNome = page.querySelector(".row.topspace input.line.flex");
        if(!inpNome || inpNome.dataset.autocompleteCliente) return;
        inpNome.dataset.autocompleteCliente = "1";

        inpNome.addEventListener("input", () => {
            fecharAutocomplete();
            const termo = inpNome.value.trim().toUpperCase();

            // Se apagou o nome, esconde o REF FAT e limpa
            if(!termo){
                atualizarRefFatVisibilidade(page, "");
                return;
            }

            const resultados = Object.entries(CLIENTES).filter(([cod, c]) =>
                /^\d+$/.test(termo) && cod.startsWith(termo)
            ).slice(0, 10);

            if(!resultados.length) return;

            const lista = document.createElement("div");
            lista.className = "autocomplete-lista";

            resultados.forEach(([cod, c]) => {
                const item = document.createElement("div");
                item.className = "autocomplete-item";
                item.innerHTML = `<span class="autocomplete-codigo">${cod}</span>${c.nome} — ${c.cidade}`;
                item.addEventListener("mousedown", (e) => {
                    e.preventDefault();
                    inpNome.value = c.nome;
                    fecharAutocomplete();
                    inpNome.dispatchEvent(new Event("input", { bubbles: true }));

                    // Preenche Cidade automaticamente
                    const rowCidade = page.querySelector(".row:nth-of-type(8)");
                    // Busca input de Cidade pelo label
                    const allRows = page.querySelectorAll(".row");
                    allRows.forEach(row => {
                        const label = row.querySelector(".label");
                        if(label && label.textContent.trim() === "Cidade:"){
                            const inpCidade = row.querySelector("input.line.flex");
                            if(inpCidade){
                                inpCidade.value = c.cidade;
                                inpCidade.dispatchEvent(new Event("input", { bubbles: true }));
                            }
                        }
                    });

                    // Clientes isentos (cidades-sede): preenche TOTAL=1,00 e Vendedor=ISENTO
                    const CODIGOS_ISENTOS = ["396","397","409","473","511","1651","5248"];
                    if(CODIGOS_ISENTOS.includes(cod)){
                        // Preenche TOTAL = 1,00
                        const inpTotal = page.querySelector("input.totalBox");
                        if(inpTotal){
                            inpTotal.value = "1,00";
                            inpTotal.dispatchEvent(new Event("input", { bubbles: true }));
                        }
                        // Preenche Vendedor = ISENTO (segundo input em .signs)
                        const signs = page.querySelector(".signs");
                        if(signs){
                            const sigs = [...signs.querySelectorAll(".sig input.line")];
                            if(sigs.length >= 2){
                                sigs[1].value = "ISENTO";
                                sigs[1].dispatchEvent(new Event("input", { bubbles: true }));
                            }
                        }
                    }

                    // Mostra/esconde campo REF FAT (só pro código 396 - BAIXO GUANDU)
                    atualizarRefFatVisibilidade(page, cod);
                    if(cod === "396"){
                        // Foca na primeira caixinha de REF FAT pra facilitar
                        const primeira = page.querySelector(".ref-fat-box");
                        if(primeira) setTimeout(() => primeira.focus(), 80);
                    }
                });
                lista.appendChild(item);
            });

            const wrap = document.createElement("div");
            wrap.className = "autocomplete-wrap";
            wrap.style.position = "absolute";
            wrap.style.left = inpNome.getBoundingClientRect().left + window.scrollX + "px";
            wrap.style.top = (inpNome.getBoundingClientRect().bottom + window.scrollY) + "px";
            wrap.style.width = inpNome.offsetWidth + "px";
            wrap.style.zIndex = 99998;
            wrap.appendChild(lista);
            document.body.appendChild(wrap);
            _autocompleteAtivo = wrap;
        });

        inpNome.addEventListener("keydown", (e) => {
            if(!_autocompleteAtivo) return;
            const itens = _autocompleteAtivo.querySelectorAll(".autocomplete-item");
            const ativo = _autocompleteAtivo.querySelector(".autocomplete-item.ativo");
            let idx = [...itens].indexOf(ativo);
            if(e.key === "ArrowDown"){ e.preventDefault(); idx = Math.min(idx+1, itens.length-1); }
            else if(e.key === "ArrowUp"){ e.preventDefault(); idx = Math.max(idx-1, 0); }
            else if(e.key === "Enter" && ativo){ e.preventDefault(); ativo.dispatchEvent(new Event("mousedown")); return; }
            else if(e.key === "Escape"){ fecharAutocomplete(); return; }
            itens.forEach(i => i.classList.remove("ativo"));
            if(itens[idx]) itens[idx].classList.add("ativo");
        });

        inpNome.addEventListener("blur", () => {
            setTimeout(fecharAutocomplete, 150);
        });
    });
}

/* ── AUTOCOMPLETE DE PRODUTOS (campo Discriminação) ─────────── */
let _autocompleteAtivo = null; // referência à lista aberta

function fecharAutocomplete(){
    if(_autocompleteAtivo){
        _autocompleteAtivo.remove();
        _autocompleteAtivo = null;
    }
}

function criarAutocomplete(inp){
    if(!inp || inp.dataset.autocomplete) return;
    inp.dataset.autocomplete = "1";

    inp.addEventListener("input", () => {
        fecharAutocomplete();
        const termo = inp.value.trim().toUpperCase();
        if(!termo) return;

        // Filtra por código OU por palavra na descrição
        const resultados = Object.entries(PRODUTOS).filter(([cod, desc]) =>
            cod.startsWith(termo) || desc.toUpperCase().includes(termo)
        ).slice(0, 10); // máximo 10 sugestões

        if(!resultados.length) return;

        // Cria a lista
        const lista = document.createElement("div");
        lista.className = "autocomplete-lista";

        resultados.forEach(([cod, desc]) => {
            const item = document.createElement("div");
            item.className = "autocomplete-item";
            item.innerHTML = `<span class="autocomplete-codigo">${cod}</span>${desc}`;
            item.addEventListener("mousedown", async (e) => {
                e.preventDefault(); // evita blur antes do click
                inp.value = `${cod} - ${desc}`;
                fecharAutocomplete();
                // Dispara input para salvar e sincronizar
                inp.dispatchEvent(new Event("input", { bubbles: true }));
                // Avança para o campo Valor (próxima td após a discriminação)
                autoResizeTextarea(inp);
                const td = inp.closest("td");
                const inpValor = td && td.nextElementSibling
                    ? td.nextElementSibling.querySelector("input")
                    : null;
                if(inpValor){
                    setTimeout(() => inpValor.focus(), 50);
                    // Auto-preenche valor de custo do Tiny (apenas pras faturas
                    // NORMAIS — nas Vias de Cliente o valor já vem da NF)
                    if(!inpValor.value.trim()){
                        // Mostra um indicador discreto enquanto busca
                        const placeholderOriginal = inpValor.placeholder || "";
                        inpValor.placeholder = "buscando...";
                        try{
                            const custo = await obterPrecoCustoTiny(cod);
                            // Só preenche se o usuário ainda não digitou nada
                            if(custo != null && !inpValor.value.trim()){
                                inpValor.value = custo.toLocaleString("pt-BR", {
                                    minimumFractionDigits: 2,
                                    maximumFractionDigits: 2
                                });
                                // Dispara input pra recalcular soma
                                inpValor.dispatchEvent(new Event("input", { bubbles: true }));
                            }
                        }catch(err){
                            // Falha silenciosa — usuário digita manualmente
                        }finally{
                            inpValor.placeholder = placeholderOriginal;
                        }
                    }
                }
            });
            lista.appendChild(item);
        });

        // Posiciona relativo ao input
        const wrap = document.createElement("div");
        wrap.className = "autocomplete-wrap";
        wrap.style.position = "absolute";
        wrap.style.left = inp.getBoundingClientRect().left + window.scrollX + "px";
        wrap.style.top = (inp.getBoundingClientRect().bottom + window.scrollY) + "px";
        wrap.style.width = inp.offsetWidth + "px";
        wrap.style.zIndex = 99998;
        wrap.appendChild(lista);
        document.body.appendChild(wrap);
        _autocompleteAtivo = wrap;
    });

    inp.addEventListener("keydown", (e) => {
        if(!_autocompleteAtivo) return;
        const itens = _autocompleteAtivo.querySelectorAll(".autocomplete-item");
        const ativo = _autocompleteAtivo.querySelector(".autocomplete-item.ativo");
        let idx = [...itens].indexOf(ativo);

        if(e.key === "ArrowDown"){ e.preventDefault(); idx = Math.min(idx+1, itens.length-1); }
        else if(e.key === "ArrowUp"){ e.preventDefault(); idx = Math.max(idx-1, 0); }
        else if(e.key === "Enter" && ativo){ e.preventDefault(); ativo.dispatchEvent(new Event("mousedown")); return; }
        else if(e.key === "Escape"){ fecharAutocomplete(); return; }

        itens.forEach(i => i.classList.remove("ativo"));
        if(itens[idx]) itens[idx].classList.add("ativo");
    });

    inp.addEventListener("blur", () => {
        setTimeout(fecharAutocomplete, 150);
    });
}

function vincularAutocompletePagina(page){
    page.querySelectorAll(".table tr").forEach((tr, i) => {
        if(i === 0) return;
        // Discriminação agora é textarea
        const ta = tr.querySelector("textarea.discArea");
        if(ta) criarAutocomplete(ta);
    });
}

function vincularTodosAutocompletes(){
    pages.forEach(page => vincularAutocompletePagina(page));
}

/* ── MÁSCARA MONETÁRIA (campo Valor — 3ª coluna da tabela) ────── */
function aplicarMascaraMonetaria(inp){
    let digits = inp.value.replace(/\D/g, "");
    if(!digits){ inp.value = ""; return; }
    digits = digits.slice(-10);
    const num = parseInt(digits, 10) / 100;
    inp.value = num.toLocaleString("pt-BR", {minimumFractionDigits:2, maximumFractionDigits:2});
}

/* ── FORÇA MAIÚSCULAS em todos os campos de texto da fatura ─── */
function vincularMaiusculas(){
    pages.forEach(page => {
        const campos = page.querySelectorAll("input, textarea");
        campos.forEach(campo => {
            if(campo.dataset.maiusculas) return;
            campo.dataset.maiusculas = "1";
            campo.addEventListener("input", () => {
                // Preserva posição do cursor ao converter
                const start = campo.selectionStart;
                const end = campo.selectionEnd;
                const upper = campo.value.toUpperCase();
                if(campo.value !== upper){
                    campo.value = upper;
                    try { campo.setSelectionRange(start, end); } catch(e){}
                }
            });
        });
    });
}

function vincularMascaras(){
    pages.forEach(page => {
        // Máscara no campo Valor (3ª coluna da tabela)
        page.querySelectorAll(".table tr").forEach((tr, i) => {
            if(i === 0) return;
            const inpValor = tr.querySelector("td:nth-child(3) input");
            if(!inpValor || inpValor.dataset.mascara) return;
            inpValor.dataset.mascara = "1";
            inpValor.addEventListener("keydown", (e) => {
                const permitidos = ["Backspace","Delete","Tab","ArrowLeft","ArrowRight","ArrowUp","ArrowDown"];
                if(!permitidos.includes(e.key) && !/^\d$/.test(e.key)){
                    e.preventDefault();
                }
            });
            inpValor.addEventListener("input", () => {
                aplicarMascaraMonetaria(inpValor);
            });
        });

        // Máscara no campo TOTAL
        const totalInp = page.querySelector(".totalBox");
        if(totalInp && !totalInp.dataset.mascara){
            totalInp.dataset.mascara = "1";
            totalInp.addEventListener("keydown", (e) => {
                const permitidos = ["Backspace","Delete","Tab","ArrowLeft","ArrowRight","ArrowUp","ArrowDown"];
                if(!permitidos.includes(e.key) && !/^\d$/.test(e.key)){
                    e.preventDefault();
                }
            });
            totalInp.addEventListener("input", () => {
                aplicarMascaraMonetaria(totalInp);
            });
        }
    });
}

/* ── EDITAR COM SENHA ────────────────────────────────────────── */
const USUARIO_EDIT = "renan";
const SENHA_EDIT   = "3003";
let modoEdicao = false;

function abrirModalEditar(){
    // Se já está em modo edição, desativa sem pedir senha
    if(modoEdicao){
        desativarEdicao();
        return;
    }
    const u = document.getElementById("loginUsuario");
    const s = document.getElementById("loginSenha");
    const erro = document.getElementById("loginErro");
    // Sempre limpa tudo ao abrir
    u.value = "";
    s.value = "";
    u.disabled = false;
    s.disabled = false;
    erro.style.display = "none";
    document.getElementById("modalLogin").classList.add("ativo");
    // Força foco na janela antes de focar no input
    setTimeout(() => {
        window.focus();
        u.blur();
        u.focus();
        u.click();
    }, 200);
}

function fecharModalEditar(){
    document.getElementById("modalLogin").classList.remove("ativo");
    // Garante que os campos ficam habilitados para próxima abertura
    document.getElementById("loginUsuario").disabled = false;
    document.getElementById("loginSenha").disabled   = false;
}

function confirmarLogin(){
    const u = document.getElementById("loginUsuario").value.trim();
    const s = document.getElementById("loginSenha").value.trim();
    if(u === USUARIO_EDIT && s === SENHA_EDIT){
        fecharModalEditar();
        ativarEdicao();
    } else {
        document.getElementById("loginErro").style.display = "block";
        // Limpa senha e volta foco para o usuário
        document.getElementById("loginSenha").value = "";
        setTimeout(() => document.getElementById("loginUsuario").focus(), 50);
    }
}

// Permite Enter para confirmar login
document.addEventListener("keydown", (e) => {
    if(e.key === "Enter" && document.getElementById("modalLogin").classList.contains("ativo")){
        confirmarLogin();
    }
});

function ativarEdicao(){
    // Só permite editar faturas finalizadas — bloqueadas por sequência não podem ser editadas
    const isFinalizada = finalizadas.includes(faturaAtual);
    const isBloqueadaSequencia = faturaAtual > 0 && !finalizadas.includes(faturaAtual - 1);

    if(isBloqueadaSequencia){
        alert("Esta fatura ainda não pode ser editada.\nFinalize as faturas anteriores primeiro.");
        return;
    }

    if(!isFinalizada){
        alert("Esta fatura ainda está em aberto e pode ser editada normalmente.");
        return;
    }

    modoEdicao = true;
    document.getElementById("btnEditar").textContent = "🔓 Bloqueando...";
    document.getElementById("btnEditar").style.background = "#27ae60";
    // Libera inputs apenas de fatura finalizada
    const campos = pages[faturaAtual].querySelectorAll("input, textarea.discArea");
    campos.forEach(inp => {
        if(!inp.classList.contains("somaBox")){
            inp.disabled = false;
            inp.style.background = "";
        }
    });

    // Se a fatura é Via de Cliente arquivada com Cód Cliente já confirmado,
    // reseta o estado "confirmado" pra o usuário poder confirmar de novo depois
    const vc = viasCliente.find(v => v.indice === faturaAtual);
    if(vc && vc.arquivada && vc.codConfirmado){
        vc.codConfirmado = false;
        // Remove readonly do input e mostra o botão ✓
        const page = pages[faturaAtual];
        const inpCod = page.querySelector(".vc-cod-input");
        const btnCodConfirmar = page.querySelector(".vc-cod-btn-confirmar");
        if(inpCod) inpCod.readOnly = false;
        if(btnCodConfirmar) btnCodConfirmar.classList.remove("confirmado");
    }
}

function desativarEdicao(){
    modoEdicao = false;
    document.getElementById("btnEditar").textContent = "✏️ Editar";
    document.getElementById("btnEditar").style.background = "#e67e22";
    salvar(); // salva o que foi editado
    aplicarBloqueio(); // volta ao estado correto
}

/* ── SOMA ────────────────────────────────────────────────────── */
function recalcularPagina(page){
    let total = 0;
    page.querySelectorAll(".table tr").forEach((tr,i)=>{
        if(i===0) return;
        const inpQuant = tr.querySelector("td:nth-child(1) input");
        const inpValor = tr.querySelector("td:nth-child(3) input");
        if(!inpQuant || !inpValor) return;
        const q = parseFloat((inpQuant.value||"0").replace(",",".")) || 0;
        const v = parseFloat((inpValor.value||"0").replace(/\./g,"").replace(",",".")) || 0;
        total += q*v;
    });
    page.querySelector(".somaBox").value =
    total.toLocaleString("pt-BR",{minimumFractionDigits:2,maximumFractionDigits:2});
}

function recalcularAtual(){
    recalcularPagina(pages[faturaAtual]);
}

// Recalcula todas as páginas — necessário após sync via socket
function recalcularTodos(){
    pages.forEach(page => recalcularPagina(page));
}

/* ── EVENTOS ─────────────────────────────────────────────────── */
let _salvarTimer = null;
let _temMudancaNaoSalva = false;  // flag de "tem alguma coisa pra salvar?"

document.addEventListener("input", () => {
    recalcularAtual();
    if (!_ignorarInput){
        _temMudancaNaoSalva = true;
        // Debounce — espera 300ms após parar de digitar antes de salvar
        clearTimeout(_salvarTimer);
        _salvarTimer = setTimeout(() => {
            salvar();
            _temMudancaNaoSalva = false;
        }, 300);
    }
});

/* ── AUTO-SAVE 3s (safety net) ─────────────────────────────────
   Se o usuário fica digitando ininterruptamente por mais de 3s,
   o debounce de 300ms acima nunca dispara. Esse timer força o
   save a cada 3s mesmo durante digitação contínua.
   Garantia: no máximo 3s de trabalho perdido em caso de crash. */
setInterval(() => {
    if(_temMudancaNaoSalva && !_ignorarInput){
        // Limpa o debounce pendente (se houver) e salva agora
        clearTimeout(_salvarTimer);
        salvar();
        _temMudancaNaoSalva = false;
    }
}, 3000);

function proximaFatura(){
    if(faturaAtual < totalFaturas-1){
        resetarModoEdicao();
        faturaAtual++;
        mostrarFatura();
        salvar();
    }
}

function faturaAnterior(){
    if(faturaAtual > 0){
        resetarModoEdicao();
        faturaAtual--;
        mostrarFatura();
        salvar();
    }
}

// Garante que ao trocar de fatura o modo edição é sempre desligado
function resetarModoEdicao(){
    if(modoEdicao){
        modoEdicao = false;
        document.getElementById("btnEditar").textContent = "✏️ Editar";
        document.getElementById("btnEditar").style.background = "#e67e22";
    }
}

function gerarPDF(){
    // Antes de imprimir: marca campos vazios da Via de Cliente com a classe "vazio"
    // assim o CSS @media print oculta esses containers na impressão
    pages.forEach(page => {
        const vcNFWrap = page.querySelector(".vc-nf-wrap");
        const vcCodWrap = page.querySelector(".vc-cod-wrap");
        const vcNF = page.querySelector(".vc-nf-input");
        const vcCod = page.querySelector(".vc-cod-input");
        if(vcNFWrap){
            if(!vcNF || !vcNF.value.trim()) vcNFWrap.classList.add("vazio");
            else vcNFWrap.classList.remove("vazio");
        }
        if(vcCodWrap){
            if(!vcCod || !vcCod.value.trim()) vcCodWrap.classList.add("vazio");
            else vcCodWrap.classList.remove("vazio");
        }
    });
    window.print();
}

/* ── CALCULADORA DE NFs ──────────────────────────────────────── */
function abrirCalculadora(){
  // Tenta via Electron IPC primeiro
  if(window.process && window.process.type){
    try{
      const { ipcRenderer } = require('electron');
      ipcRenderer.send('abrir-calculadora');
      return;
    }catch(e){}
  }
  // Fallback: abre em nova aba no browser
  window.open('/calculadora-nf.html', '_blank');
}

/* ── LOGIN DE ACESSO ── */
const LOGIN_USUARIO = "site";
const LOGIN_SENHA   = "dev";

function entrarNoSistema(){
  document.getElementById("telaLogin").style.display = "none";
  document.getElementById("sistemaCompleto").style.display = "block";
  const erro = document.getElementById("loginErroMsg");
  if(erro) erro.style.display = "none";
  vincularMascaras();
  vincularMaiusculas();
  vincularAutoResizes();
  vincularTodosAutocompletes();
  vincularAutocompleteClientes();
  vincularRefFatInicial();
  vincularViaClienteInputs();
  popularListaClientes();
  carregar();
  renderizarTodasMarcas();
  aplicarViaClienteEmTodasPaginas();
  mostrarFatura();
}

function fazerLogin(){
  const u = document.getElementById("loginUser").value.trim();
  const s = document.getElementById("loginPass").value.trim();
  const erro = document.getElementById("loginErroMsg");
  if(u === LOGIN_USUARIO && s === LOGIN_SENHA){
    sessionStorage.setItem("logado", "1");
    entrarNoSistema();
  } else {
    erro.style.display = "block";
    document.getElementById("loginPass").value = "";
    document.getElementById("loginPass").focus();
  }
}

/* ── START ───────────────────────────────────────────────────── */
// Verifica se já estava logado antes do redirecionamento
if(sessionStorage.getItem("logado") === "1"){
  entrarNoSistema();
} else {
  document.getElementById("loginUser").focus();
}

/* ── SALVAR CÓPIA LOCAL DE IMAGEM (recebida de outro PC) ── */
socket.on('salvar-imagem-copia', ({ numero, imgBase64, dataStr }) => {
  try{
    const { ipcRenderer } = require('electron');
    ipcRenderer.invoke('salvar-imagem-local', { numero, imgBase64 });
    console.log('[Cópia] Imagem recebida e salva localmente: FAT ' + numero);
  }catch(e){}
});

