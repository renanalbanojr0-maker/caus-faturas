<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Precificação NF Entrada</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Sora:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
:root{--bg:#0f0f0f;--surface:#181818;--surface2:#222222;--border:#2e2e2e;--border2:#3a3a3a;--text:#e8e6e0;--muted:#7a7870;--accent:#c8f060;--accent-dim:#8aaa38;--teal:#3ecfb2;--amber:#f0b429;--red:#e05c5c;--radius:10px;--mono:'IBM Plex Mono',monospace;--sans:'Sora',sans-serif;}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:var(--sans);font-size:14px;min-height:100vh;}
.app{display:grid;grid-template-columns:300px 1fr;min-height:100vh;}

/* ── Sidebar ── */
.sidebar{background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;position:sticky;top:0;height:100vh;overflow-y:auto;}
.sidebar-header{padding:28px 24px 20px;border-bottom:1px solid var(--border);}
.logo{font-family:var(--mono);font-size:11px;color:var(--accent);letter-spacing:.15em;text-transform:uppercase;margin-bottom:6px;}
.sidebar-title{font-size:18px;font-weight:600;line-height:1.3;}
.token-section{padding:20px 24px;border-bottom:1px solid var(--border);}
.label{font-size:11px;color:var(--muted);letter-spacing:.08em;text-transform:uppercase;margin-bottom:8px;display:block;}
.token-row{display:flex;gap:8px;}
.token-row input{flex:1;background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:9px 12px;color:var(--text);font-family:var(--mono);font-size:12px;outline:none;transition:border-color .2s;}
.token-row input:focus{border-color:var(--accent-dim);}
.btn-connect{background:var(--accent);color:#0f0f0f;border:none;border-radius:8px;padding:9px 14px;font-family:var(--sans);font-size:12px;font-weight:600;cursor:pointer;white-space:nowrap;}
.btn-connect:hover{opacity:.85;}.btn-connect:disabled{opacity:.4;cursor:not-allowed;}
.server-warn{background:rgba(240,180,41,.1);border:1px solid rgba(240,180,41,.3);border-radius:8px;padding:10px 14px;font-size:12px;color:var(--amber);margin-top:12px;line-height:1.6;}
.debug-box{margin:12px 0 0;background:var(--surface2);border:1px solid var(--border2);border-radius:8px;padding:10px 12px;font-family:var(--mono);font-size:11px;color:var(--muted);display:none;max-height:140px;overflow-y:auto;line-height:1.6;}
.debug-box.visible{display:block;}.de{color:var(--red);}.dok{color:var(--teal);}
.filter-section{padding:16px 24px;border-bottom:1px solid var(--border);}
.filter-row{display:flex;gap:8px;margin-bottom:8px;}.filter-row:last-child{margin-bottom:0;}
.filter-row input,.filter-row select{flex:1;background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:8px 10px;color:var(--text);font-family:var(--sans);font-size:12px;outline:none;}
.filter-row select option{background:var(--surface2);}
.btn-search{width:100%;background:var(--surface2);border:1px solid var(--border2);border-radius:8px;padding:9px;color:var(--text);font-family:var(--sans);font-size:13px;font-weight:500;cursor:pointer;}
.btn-search:hover{background:var(--border);}
.nf-list-section{flex:1;overflow-y:auto;}
.nf-list-header{padding:16px 24px 10px;font-size:11px;color:var(--muted);letter-spacing:.08em;text-transform:uppercase;display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;background:var(--surface);z-index:1;}
.nf-count{background:var(--surface2);border-radius:99px;padding:2px 8px;font-size:11px;color:var(--accent);font-family:var(--mono);}
.nf-item{padding:14px 24px;border-bottom:1px solid var(--border);cursor:pointer;transition:background .15s;display:flex;flex-direction:column;gap:4px;}
.nf-item:hover{background:var(--surface2);}.nf-item.active{background:var(--surface2);border-left:3px solid var(--accent);padding-left:21px;}
.nf-item-top{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;}
.nf-num{font-family:var(--mono);font-size:13px;font-weight:500;color:var(--accent);}
.nf-status{font-size:10px;padding:2px 7px;border-radius:99px;font-weight:500;flex-shrink:0;}
.nf-status.autorizado{background:rgba(62,207,178,.15);color:var(--teal);}
.nf-status.cancelado{background:rgba(224,92,92,.15);color:var(--red);}
.nf-status.outro{background:var(--surface2);color:var(--muted);}
.nf-emit{font-size:12px;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.nf-meta{display:flex;gap:12px;font-size:11px;color:var(--muted);font-family:var(--mono);}
.sidebar-state{padding:32px 24px;text-align:center;color:var(--muted);font-size:13px;line-height:1.7;}

/* ── Main ── */
.main{background:var(--bg);display:flex;flex-direction:column;}
.main-header{padding:24px 36px 16px;border-bottom:1px solid var(--border);display:flex;align-items:flex-start;justify-content:space-between;gap:16px;}
.nf-info-block{display:flex;flex-direction:column;gap:4px;}
.nf-info-num{font-family:var(--mono);font-size:22px;font-weight:500;color:var(--accent);}
.nf-info-meta{font-size:13px;color:var(--muted);}
.nf-info-emit{font-size:15px;font-weight:500;}

/* ── XML Upload area ── */
.xml-bar{padding:14px 36px;border-bottom:1px solid var(--border);background:var(--surface);display:flex;align-items:center;gap:14px;flex-wrap:wrap;}
.xml-label{font-size:12px;color:var(--muted);white-space:nowrap;}
.xml-drop{flex:1;min-width:200px;border:1.5px dashed var(--border2);border-radius:8px;padding:10px 16px;font-size:12px;color:var(--muted);cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:10px;background:var(--surface2);}
.xml-drop:hover,.xml-drop.over{border-color:var(--accent-dim);color:var(--text);background:var(--bg);}
.xml-drop.loaded{border-color:var(--teal);color:var(--teal);}
.xml-drop input[type=file]{display:none;}
.xml-clear{background:none;border:1px solid var(--border2);border-radius:6px;color:var(--muted);font-size:11px;padding:4px 10px;cursor:pointer;}
.xml-clear:hover{color:var(--red);border-color:var(--red);}
.xml-hint{font-size:11px;color:var(--muted);line-height:1.5;}

.globals-bar{padding:14px 36px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:20px;flex-wrap:wrap;background:var(--surface);}
.global-field{display:flex;align-items:center;gap:10px;}
.global-field input{width:90px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:7px 10px;color:var(--text);font-family:var(--mono);font-size:13px;text-align:right;outline:none;}
.global-field input:focus{border-color:var(--accent-dim);}
.globals-hint{font-size:11px;color:var(--muted);margin-left:auto;}
.table-wrap{flex:1;overflow-x:auto;padding:24px 36px;}
table{width:100%;border-collapse:collapse;font-size:13px;}
thead th{text-align:left;padding:10px 12px;font-family:var(--mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--border);white-space:nowrap;}
thead th.num{text-align:right;}
tbody tr{border-bottom:1px solid var(--border);}
tbody tr:hover{background:var(--surface);}
tbody td{padding:11px 12px;}
tbody td.num{text-align:right;font-family:var(--mono);font-size:12px;}
tbody td.sku{font-family:var(--mono);font-size:12px;color:var(--accent);}
tbody td.desc{max-width:220px;}
tbody td.desc span{display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
td input{background:transparent;border:none;font-family:var(--mono);font-size:12px;color:var(--text);text-align:right;width:70px;outline:none;border-bottom:1px solid transparent;padding:2px 4px;}
td input:focus{border-bottom-color:var(--accent-dim);}
.val-pf{color:var(--amber);}.val-pl{color:var(--teal);}.val-pp{color:var(--accent);}
.pl-menor{text-decoration:line-through;opacity:.5;font-size:11px;}
.pl-atual{color:var(--teal);font-weight:700;}
.pl-wrap{display:flex;flex-direction:column;align-items:flex-end;gap:1px;}
.summary-bar{padding:20px 36px;border-top:1px solid var(--border);background:var(--surface);display:flex;gap:12px;flex-wrap:wrap;align-items:center;}
.metric{display:flex;flex-direction:column;gap:3px;padding:12px 16px;background:var(--surface2);border-radius:var(--radius);min-width:105px;border:1px solid var(--border);}
.metric .mlabel{font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);font-family:var(--mono);}
.metric .mval{font-size:16px;font-weight:500;font-family:var(--mono);}
.metric.m-pc .mval{color:var(--text);}.metric.m-pf .mval{color:var(--amber);}.metric.m-pl .mval{color:var(--teal);}.metric.m-pp .mval{color:var(--accent);}
.export-group{margin-left:auto;display:flex;gap:8px;align-items:center;}
.btn-export{background:var(--accent);color:#0f0f0f;border:none;border-radius:8px;padding:10px 18px;font-family:var(--sans);font-size:13px;font-weight:600;cursor:pointer;}
.btn-export:hover{opacity:.85;}.btn-export:disabled{opacity:.4;cursor:not-allowed;}
.btn-csv{background:transparent;color:var(--text);border:1px solid var(--border2);border-radius:8px;padding:10px 16px;font-family:var(--sans);font-size:13px;cursor:pointer;}
.btn-csv:hover{background:var(--surface2);}
.main-empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;color:var(--muted);padding:60px;text-align:center;}
.main-empty .big{font-size:40px;opacity:.2;}
.main-empty p{font-size:14px;line-height:1.7;max-width:340px;}
.spinner{width:20px;height:20px;border:2px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin .7s linear infinite;display:inline-block;}
@keyframes spin{to{transform:rotate(360deg);}}
.toast{position:fixed;bottom:24px;right:24px;background:var(--surface);border:1px solid var(--border2);border-radius:var(--radius);padding:12px 18px;font-size:13px;color:var(--text);z-index:9999;transform:translateY(80px);opacity:0;transition:all .3s;max-width:380px;}
.toast.show{transform:translateY(0);opacity:1;}.toast.err{border-color:var(--red);color:var(--red);}.toast.ok{border-color:var(--accent);}

/* ── Abas ── */
.app-tabs{display:flex;border-bottom:1px solid var(--border);background:var(--surface);}
.app-tab{padding:14px 24px;font-size:13px;font-weight:600;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;transition:all .15s;letter-spacing:.03em;}
.app-tab:hover{color:var(--text);}
.app-tab.active{color:var(--accent);border-bottom-color:var(--accent);}
.tab-content{display:none;flex:1;flex-direction:column;}
.tab-content.active{display:flex;}


/* ── Histórico ── */
.hist-header{padding:20px 36px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:16px;}
.hist-title{font-size:18px;font-weight:600;}
.hist-count{font-family:var(--mono);font-size:12px;color:var(--muted);background:var(--surface2);padding:3px 10px;border-radius:99px;border:1px solid var(--border);}
.hist-search{display:flex;gap:8px;align-items:center;}
.hist-search input{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:8px 12px;color:var(--text);font-family:var(--sans);font-size:13px;outline:none;width:220px;}
.hist-search input:focus{border-color:var(--accent-dim);}
.hist-list{flex:1;overflow-y:auto;padding:16px 36px;display:flex;flex-direction:column;gap:10px;}
.hist-empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;color:var(--muted);font-size:14px;text-align:center;padding:60px;}
.hist-empty .big{font-size:40px;opacity:.2;}
.hist-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px 20px;cursor:pointer;transition:all .15s;display:flex;align-items:flex-start;gap:16px;}
.hist-card:hover{border-color:var(--border2);background:var(--surface2);}
.hist-card-icon{font-size:28px;flex-shrink:0;margin-top:2px;}
.hist-card-body{flex:1;min-width:0;}
.hist-card-top{display:flex;align-items:center;gap:10px;margin-bottom:4px;}
.hist-card-nf{font-family:var(--mono);font-size:14px;font-weight:500;color:var(--accent);}
.hist-card-cat{font-size:10px;padding:2px 7px;border-radius:99px;font-weight:600;background:var(--surface2);color:var(--muted);border:1px solid var(--border);}
.hist-card-emit{font-size:13px;font-weight:500;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.hist-card-meta{display:flex;gap:16px;margin-top:6px;font-size:11px;color:var(--muted);font-family:var(--mono);}
.hist-card-vals{display:flex;gap:10px;flex-wrap:wrap;margin-top:8px;}
.hist-val{font-size:11px;font-family:var(--mono);padding:3px 8px;border-radius:6px;border:1px solid var(--border);}
.hist-val.pf{color:var(--amber);border-color:rgba(240,180,41,.2);background:rgba(240,180,41,.06);}
.hist-val.pl{color:var(--teal);border-color:rgba(62,207,178,.2);background:rgba(62,207,178,.06);}
.hist-val.pp{color:var(--accent);border-color:rgba(200,240,96,.2);background:rgba(200,240,96,.06);}
.hist-card-actions{display:flex;flex-direction:column;gap:6px;flex-shrink:0;}
.hist-btn{background:var(--surface2);border:1px solid var(--border2);border-radius:6px;padding:6px 12px;font-size:11px;font-family:var(--sans);color:var(--text);cursor:pointer;white-space:nowrap;transition:all .15s;}
.hist-btn:hover{background:var(--border);}.hist-btn.danger{color:var(--red);}.hist-btn.danger:hover{border-color:var(--red);}
.hist-btn.conferido{color:var(--teal);border-color:rgba(62,207,178,.3);background:rgba(62,207,178,.06);cursor:default;}
.hist-card.is-conferido{border-left:3px solid var(--teal);}
.hist-conferido-badge{font-size:10px;font-weight:600;color:var(--teal);background:rgba(62,207,178,.1);border:1px solid rgba(62,207,178,.2);padding:2px 8px;border-radius:99px;}

/* Modal senha */
.senha-modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:10000;align-items:center;justify-content:center;}
.senha-modal.open{display:flex;}
.senha-modal-box{background:var(--surface);border:1px solid var(--border2);border-radius:14px;padding:28px;width:320px;display:flex;flex-direction:column;gap:14px;}
.senha-modal-box h3{font-size:15px;font-weight:600;margin:0;}
.senha-modal-box p{font-size:13px;color:var(--muted);margin:0;}
.senha-modal-box input{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:10px 12px;color:var(--text);font-family:var(--mono);font-size:14px;outline:none;width:100%;letter-spacing:.15em;}
.senha-modal-box input:focus{border-color:var(--accent-dim);}
.senha-modal-erro{font-size:12px;color:var(--red);display:none;}
.senha-modal-btns{display:flex;gap:8px;}
.senha-modal-btns button{flex:1;padding:9px;border:none;border-radius:8px;font-family:var(--sans);font-size:13px;font-weight:600;cursor:pointer;}
.senha-modal-ok{background:var(--accent);color:#0f0f0f;}
.senha-modal-cancel{background:var(--surface2);color:var(--text);border:1px solid var(--border2)!important;}

/* ── Modal visualização ── */
.hist-modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:9998;align-items:center;justify-content:center;}
.hist-modal.open{display:flex;}
.hist-modal-box{background:var(--surface);border:1px solid var(--border2);border-radius:16px;width:90vw;max-width:900px;max-height:88vh;display:flex;flex-direction:column;overflow:hidden;}
.hist-modal-head{padding:20px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.hist-modal-head h2{font-size:16px;font-weight:600;}
.hist-modal-close{background:none;border:none;color:var(--muted);font-size:20px;cursor:pointer;padding:4px 8px;}
.hist-modal-close:hover{color:var(--red);}
.hist-modal-body{flex:1;overflow-y:auto;padding:24px;}
.hist-modal-info{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:10px;margin-bottom:20px;}
.hist-info-card{background:var(--surface2);border-radius:8px;padding:12px;border:1px solid var(--border);}
.hist-info-card .lbl{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px;}
.hist-info-card .val{font-size:14px;font-weight:500;font-family:var(--mono);}
.hist-modal-table{width:100%;border-collapse:collapse;font-size:12px;}
.hist-modal-table th{text-align:left;padding:8px 10px;font-family:var(--mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--border);}
.hist-modal-table th.r{text-align:right;}
.hist-modal-table td{padding:10px 10px;border-bottom:1px solid var(--border);}
.hist-modal-table td.r{text-align:right;font-family:var(--mono);}
.hist-modal-table tr:hover td{background:var(--surface2);}
/* ═══════ EMISSÃO MASSIVA NF ═══════ */
.em-wrap{padding:32px;max-width:1200px;margin:0 auto;width:100%;}
.em-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:24px;gap:16px;}
.em-title{font-size:24px;font-weight:600;color:var(--text);margin-bottom:6px;letter-spacing:-.01em;}
.em-sub{color:var(--muted);font-size:13px;line-height:1.5;max-width:680px;}
.em-subtitle{font-size:16px;font-weight:600;color:var(--text);margin-bottom:14px;}
.em-section{margin-bottom:24px;}

/* Cards informativos */
.em-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:18px 22px;margin-bottom:16px;}
.em-card-info{background:rgba(62,207,178,.05);border-color:rgba(62,207,178,.25);}
.em-card-title{font-size:13px;font-weight:600;color:var(--teal);margin-bottom:12px;letter-spacing:.02em;}
.em-config-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:8px 24px;font-size:12px;color:var(--text);}
.em-config-lbl{color:var(--muted);}

/* Botões */
.em-btn{background:var(--surface2);border:1px solid var(--border2);border-radius:8px;padding:10px 20px;color:var(--text);font-family:var(--sans);font-size:13px;font-weight:500;cursor:pointer;transition:all .15s;}
.em-btn:hover:not(:disabled){background:var(--border);}
.em-btn:disabled{opacity:.4;cursor:not-allowed;}
.em-btn-primary{background:var(--accent);color:#0f0f0f;border-color:var(--accent);font-weight:600;}
.em-btn-primary:hover:not(:disabled){background:var(--accent-dim);color:#fff;}
.em-btn-secondary{background:transparent;}
.em-btn-cancelar{background:transparent;border-color:var(--red);color:var(--red);}
.em-btn-cancelar:hover{background:rgba(224,92,92,.1);}
.em-actions{display:flex;gap:10px;margin-top:18px;}
.em-actions .em-btn{flex:1;}

/* Drop area */
.em-drop{border:2px dashed var(--border2);border-radius:var(--radius);padding:48px 32px;text-align:center;background:var(--surface);cursor:pointer;transition:all .15s;}
.em-drop:hover{border-color:var(--accent-dim);background:var(--surface2);}
.em-drop.over{border-color:var(--accent);background:rgba(62,207,178,.05);}
.em-drop-icon{font-size:42px;margin-bottom:12px;opacity:.7;}
.em-drop-text{color:var(--text);font-size:15px;margin-bottom:6px;}
.em-drop-hint{color:var(--muted);font-size:12px;}
.em-arquivo-info{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:18px 22px;margin-top:16px;}
.em-arquivo-nome{font-size:14px;font-weight:600;color:var(--text);margin-bottom:8px;font-family:var(--mono);}
.em-arquivo-stats{font-size:13px;color:var(--muted);line-height:1.6;}
.em-arquivo-stats strong{color:var(--text);}

/* Erros de validação */
.em-erros-card{background:rgba(224,92,92,.05);border:1px solid rgba(224,92,92,.4);border-radius:var(--radius);padding:18px;margin-top:16px;}
.em-erros-titulo{color:var(--red);font-weight:600;font-size:14px;margin-bottom:10px;}
.em-erros-lista{font-family:var(--mono);font-size:12px;color:var(--text);max-height:200px;overflow-y:auto;line-height:1.7;}
.em-erros-lista .l{display:block;padding:3px 0;}

/* Progresso */
.em-progresso{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:24px;}
.em-progresso-bar{background:var(--surface2);border-radius:99px;overflow:hidden;height:30px;margin-bottom:14px;border:1px solid var(--border);}
.em-progresso-fill{background:linear-gradient(90deg,var(--accent-dim),var(--accent));height:100%;width:0%;transition:width .3s ease;display:flex;align-items:center;justify-content:center;color:#0f0f0f;font-weight:700;font-size:13px;font-family:var(--mono);}
.em-progresso-txt{font-size:14px;color:var(--text);text-align:center;margin-bottom:14px;font-weight:500;}
.em-progresso-log{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:12px 14px;font-family:var(--mono);font-size:11px;color:var(--muted);max-height:280px;overflow-y:auto;line-height:1.7;}
.em-progresso-log .ok{color:var(--teal);}
.em-progresso-log .err{color:var(--red);}
.em-progresso-log .wrn{color:var(--amber);}
.em-progresso-log .info{color:var(--text);}

/* Relatório */
.em-rel-resumo{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:10px;margin-bottom:18px;}
.em-rel-box{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:18px;text-align:center;}
.em-rel-box.ok{border-color:var(--teal);}
.em-rel-box.err{border-color:var(--red);}
.em-rel-box.wrn{border-color:var(--amber);}
.em-rel-num{font-size:32px;font-weight:700;color:var(--text);font-family:var(--mono);margin-bottom:4px;}
.em-rel-box.ok .em-rel-num{color:var(--teal);}
.em-rel-box.err .em-rel-num{color:var(--red);}
.em-rel-box.wrn .em-rel-num{color:var(--amber);}
.em-rel-lbl{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;font-weight:600;}
.em-rel-detalhes{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:0;overflow:hidden;}
.em-rel-tabela{width:100%;border-collapse:collapse;font-size:12px;}
.em-rel-tabela th{text-align:left;padding:12px 14px;font-family:var(--mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--border);background:var(--surface2);}
.em-rel-tabela td{padding:11px 14px;border-bottom:1px solid var(--border);font-size:12px;color:var(--text);}
.em-rel-tabela tr:last-child td{border-bottom:none;}
.em-rel-tabela tr:hover td{background:var(--surface2);}
.em-rel-status{display:inline-block;padding:3px 10px;border-radius:99px;font-size:10px;font-weight:600;letter-spacing:.05em;}
.em-rel-status.ok{background:rgba(62,207,178,.15);color:var(--teal);}
.em-rel-status.err{background:rgba(224,92,92,.15);color:var(--red);}
.em-rel-status.wrn{background:rgba(240,180,41,.15);color:var(--amber);}

</style>
</head>
<body>
<div class="app">
  <aside class="sidebar">
    <div class="sidebar-header">
      <div class="logo">Tiny ERP → NF Entrada</div>
      <div class="sidebar-title">Precificação<br>de Entradas</div>
    </div>
    <div class="token-section" style="display:none;">
      <span class="label">Token da API Tiny</span>
      <div class="token-row">
        <input type="password" id="token-input" placeholder="Cole seu token aqui" autocomplete="off" value=""/>
        <button class="btn-connect" id="btn-connect" onclick="conectar()">Conectar</button>
      </div>
<div id="server-warn" style="display:none"></div>
      <div class="debug-box" id="debug-box"></div>
    </div>
    <div class="filter-section" id="filter-section" style="display:none">
      <span class="label">Filtrar notas de entrada</span>
      <div class="filter-row">
        <input type="text" id="f-numero" placeholder="Número da NF"/>
        <select id="f-situacao">
          <option value="">Todas</option>
          <option value="A">Autorizada</option>
          <option value="C">Cancelada</option>
        </select>
      </div>
      <div class="filter-row">
        <input type="text" id="f-fornecedor" placeholder="Fornecedor / remetente"/>
      </div>
      <div class="filter-row">
        <input type="date" id="f-data-ini" title="Data inicial"/>
        <input type="date" id="f-data-fim" title="Data final"/>
      </div>
      <button class="btn-search" onclick="buscarNFs()">⌕ Buscar notas de entrada</button>
    </div>
    <div class="nf-list-section">
      <div class="nf-list-header">
        <span>Notas de entrada</span>
        <span class="nf-count" id="nf-count">0</span>
      </div>
      <div id="nf-list"><div class="sidebar-state"><span class="spinner"></span><br><br>Carregando notas...</div></div>
    </div>
  </aside>

  <div style="flex:1;display:flex;flex-direction:column;overflow:hidden;">
    <!-- Abas -->
    <div class="app-tabs">
      <div class="app-tab active" id="tab-calc" onclick="mudarAba('calc')">📊 Precificação</div>
      <div class="app-tab" id="tab-hist" onclick="mudarAba('hist')">🗂 Histórico</div>
      <div class="app-tab" id="tab-em" onclick="mudarAba('em')">📋 Emissão Massiva NF</div>
    </div>

    <!-- Tab: Precificação -->
    <div class="tab-content active" id="tc-calc" style="overflow:auto;">
      <main class="main" id="main">
        <div class="main-empty">
          <div class="big">📄</div>
          <p>Selecione uma nota de entrada para carregar os produtos e calcular os preços.</p>
        </div>
      </main>
    </div>

    <!-- Tab: Histórico -->
    <div class="tab-content" id="tc-hist">
      <div class="hist-header">
        <div style="display:flex;align-items:center;gap:12px;">
          <div class="hist-title">Histórico de Precificações</div>
          <span class="hist-count" id="hist-count">0 registros</span>
        </div>
        <div class="hist-search">
          <input type="text" placeholder="Buscar por NF ou fornecedor…" oninput="filtrarHistorico(this.value)">
        </div>
      </div>
      <div class="hist-list" id="hist-list">
        <div class="hist-empty">
          <div class="big">🗂</div>
          <p>Nenhuma NF precificada ainda.<br>Gere um PDF para registrar aqui.</p>
        </div>
      </div>
    </div>

    <!-- Tab: Emissão Massiva NF -->
    <div class="tab-content" id="tc-em" style="overflow:auto;">
      <div class="em-wrap">
        <div class="em-header">
          <div>
            <h2 class="em-title">📋 Emissão Massiva de Notas Fiscais</h2>
            <p class="em-sub">Faça upload de uma planilha Excel pra cadastrar clientes em massa, criar pedidos e gerar NFs (pendentes pra autorização manual).</p>
          </div>
          <button class="em-btn em-btn-secondary" onclick="emBaixarModelo()">📥 Baixar modelo</button>
        </div>

        <!-- Configurações fixas (informativo) -->
        <div class="em-card em-card-info">
          <div class="em-card-title">⚙️ Configurações fixas das NFs geradas</div>
          <div class="em-config-grid">
            <div><span class="em-config-lbl">Forma de envio:</span> <strong>Envio Próprio Caús</strong></div>
            <div><span class="em-config-lbl">Frete por conta:</span> <strong>Transporte Próprio do Remetente</strong></div>
            <div><span class="em-config-lbl">Forma de pagamento:</span> <strong>Dinheiro</strong></div>
            <div><span class="em-config-lbl">Valor unitário:</span> <strong>preço Tiny − 40%</strong></div>
            <div><span class="em-config-lbl">Status final:</span> <strong>Pendente (você autoriza no SEFAZ)</strong></div>
            <div><span class="em-config-lbl">Operação Presencial:</span> <strong>marcar manualmente antes de autorizar</strong></div>
          </div>
        </div>

        <!-- Etapa 1: Upload -->
        <div class="em-section" id="emSection1">
          <h3 class="em-subtitle">1. Selecione a planilha</h3>
          <div class="em-drop" id="emDropArea" ondragover="emDragOver(event)" ondragleave="emDragLeave(event)" ondrop="emDrop(event)" onclick="document.getElementById('emFileInput').click()">
            <div class="em-drop-icon">📂</div>
            <div class="em-drop-text">Arraste a planilha aqui ou <strong>clique pra escolher</strong></div>
            <div class="em-drop-hint">Aceita arquivos .xlsx (Excel)</div>
            <input type="file" id="emFileInput" accept=".xlsx" style="display:none;" onchange="emFileChange(event)">
          </div>
          <div id="emArquivoInfo" style="display:none;" class="em-arquivo-info">
            <div class="em-arquivo-nome"><span id="emArquivoNome"></span></div>
            <div class="em-arquivo-stats" id="emArquivoStats"></div>
            <div class="em-actions">
              <button class="em-btn em-btn-secondary" onclick="emResetar()">↺ Trocar arquivo</button>
              <button class="em-btn em-btn-primary" onclick="emProcessar()" id="emBtnProcessar">▶ Processar planilha</button>
            </div>
          </div>
          <div id="emValidacaoErros" style="display:none;" class="em-erros-card"></div>
        </div>

        <!-- Etapa 2: Progresso -->
        <div class="em-section" id="emSection2" style="display:none;">
          <h3 class="em-subtitle">2. Processando…</h3>
          <div class="em-progresso">
            <div class="em-progresso-bar">
              <div class="em-progresso-fill" id="emProgFill" style="width:0%;">0%</div>
            </div>
            <div class="em-progresso-txt" id="emProgTxt">Iniciando…</div>
            <div class="em-progresso-log" id="emProgLog"></div>
            <div style="margin-top:14px;text-align:right;">
              <button class="em-btn em-btn-cancelar" onclick="emCancelar()" id="emBtnCancelar">⏹ Cancelar</button>
            </div>
          </div>
        </div>

        <!-- Etapa 3: Relatório -->
        <div class="em-section" id="emSection3" style="display:none;">
          <h3 class="em-subtitle">3. Relatório final</h3>
          <div class="em-rel-resumo" id="emRelResumo"></div>
          <div class="em-rel-detalhes" id="emRelDetalhes"></div>
          <div class="em-actions" style="margin-top:18px;">
            <button class="em-btn em-btn-secondary" onclick="emResetar()">📋 Nova emissão</button>
            <button class="em-btn em-btn-primary" onclick="emExportarRelatorio()">📥 Exportar relatório CSV</button>
          </div>
        </div>
      </div>
    </div>

  </div>

  <!-- Modal visualizar histórico -->
  <div class="hist-modal" id="histModal">
    <div class="hist-modal-box">
      <div class="hist-modal-head">
        <h2 id="histModalTitle">Detalhes da Precificação</h2>
        <button class="hist-modal-close" onclick="fecharHistModal()">✕</button>
      </div>
      <div class="hist-modal-body" id="histModalBody"></div>
    </div>
  </div>
</div>
<div class="toast" id="toast"></div>

<!-- Modal de senha -->
<div class="senha-modal" id="senhaModal">
  <div class="senha-modal-box">
    <h3 id="senhaTitulo">🔐 Confirmação</h3>
    <p id="senhaDesc">Digite a senha para continuar.</p>
    <input type="password" id="senhaInput" placeholder="••••" maxlength="20">
    <div class="senha-modal-erro" id="senhaErro">Senha incorreta. Tente novamente.</div>
    <div class="senha-modal-btns">
      <button class="senha-modal-cancel" onclick="fecharSenhaModal()" style="background:var(--surface2);color:var(--text);border:1px solid var(--border2);">Cancelar</button>
      <button class="senha-modal-ok" onclick="confirmarSenha()">Confirmar</button>
    </div>
  </div>
</div>

<script>
const API = window.location.origin + "/tiny-api";
let token="", activeNF=null, activeNFData=null, rows=[], xmlCarregado=null, xmlCteCarregado=null;

/* ── utils ── */
function toast(msg,tipo="ok"){const t=document.getElementById("toast");t.textContent=msg;t.className="toast show "+(tipo==="err"?"err":"ok");clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove("show"),5000);}
function dbg(msg,tipo=""){const b=document.getElementById("debug-box");b.classList.add("visible");const d=document.createElement("div");d.className=tipo==="err"?"de":tipo==="ok"?"dok":"";d.textContent="["+new Date().toLocaleTimeString("pt-BR")+"] "+msg;b.appendChild(d);b.scrollTop=b.scrollHeight;}
async function proxy(action,params={}){
  try{
    dbg("→ "+action+" "+JSON.stringify(params).substring(0,60));
    const r=await fetch(API,{
      method:"POST",
      headers:{"Content-Type":"application/json"},
      body:JSON.stringify({action,token,params})
    });
    const txt=await r.text();
    if(!r.ok) throw new Error("HTTP "+r.status+": "+txt.substring(0,200));
    return JSON.parse(txt);
  }catch(e){
    dbg("ERRO proxy: "+e.message,"err");
    throw e;
  }
}

/* ── Conectar / Buscar / Selecionar ── */
async function conectar(){
  token=document.getElementById("token-input").value.trim();
  // Token pode estar vazio — o proxy do VPS usa o TINY_TOKEN do .env automaticamente
  const btn=document.getElementById("btn-connect");btn.disabled=true;btn.textContent="Conectando...";
  document.getElementById("server-warn").style.display="none";

  // Define período padrão: últimos 60 dias
  const hoje=new Date();
  const ini=new Date(); ini.setDate(hoje.getDate()-60);
  const fmt=d=>d.toISOString().split("T")[0];
  const elIni=document.getElementById("f-data-ini");
  const elFim=document.getElementById("f-data-fim");
  if(elIni&&!elIni.value) elIni.value=fmt(ini);
  if(elFim&&!elFim.value) elFim.value=fmt(hoje);

  try{dbg("Conectando...");await buscarNFs();document.getElementById("filter-section").style.display="block";toast("Conectado!");}
  catch(e){dbg(e.message,"err");toast(e.message,"err");}
  finally{btn.disabled=false;btn.textContent="Conectar";}
}
function fmtDataTiny(d){ // dd/mm/yyyy
  if(!d) return "";
  const p=d.split("-"); return p[2]+"/"+p[1]+"/"+p[0];
}

async function buscarNFs(){
  const listEl=document.getElementById("nf-list");
  listEl.innerHTML=`<div class="sidebar-state"><span class="spinner"></span><br><br>Buscando...</div>`;
  const params={tipoNota:"E"};
  const num=document.getElementById("f-numero")?.value.trim();
  const sit=document.getElementById("f-situacao")?.value;
  const forn=document.getElementById("f-fornecedor")?.value.trim();
  const dataIni=document.getElementById("f-data-ini")?.value;
  const dataFim=document.getElementById("f-data-fim")?.value;
  if(num)params.numero=num;
  if(sit)params.situacao=sit;
  if(forn)params.nome=forn;
  if(dataIni)params.dataInicial=fmtDataTiny(dataIni);
  if(dataFim)params.dataFinal=fmtDataTiny(dataFim);
  dbg("Buscando: "+JSON.stringify(params));
  const data=await proxy("listar_nf",params);
  dbg("Resp: "+JSON.stringify(data).substring(0,200));
  const ret=data?.retorno;
  if(!ret)throw new Error("Sem retorno. Verifique o token.");
  if(ret.status==="Erro"){const erros=ret.erros||ret.registros?.[0]?.registro?.erros;const msg=Array.isArray(erros)?erros.map(e=>e.erro||e).join(", "):"Erro";throw new Error("Tiny: "+msg);}
  const raw=ret.notas_fiscais||ret.notas||[];
  const arr=Array.isArray(raw)?raw:[raw];
  const listaRaw=arr.map(n=>n.nota_fiscal||n.nota||n).filter(n=>n&&n.id);

  // Ordena por data de emissão — mais recente primeiro (formato dd/mm/yyyy)
  const parseDt = s => {
    if(!s) return 0;
    const p=s.split("/");
    if(p.length===3) return new Date(p[2],p[1]-1,p[0]).getTime();
    return new Date(s).getTime()||0;
  };
  const lista = listaRaw.sort((a,b)=>parseDt(b.data_emissao||b.data)-parseDt(a.data_emissao||a.data));

  dbg(lista.length+" notas",lista.length>0?"ok":"");
  document.getElementById("nf-count").textContent=lista.length;
  if(!lista.length){listEl.innerHTML=`<div class="sidebar-state">Nenhuma nota encontrada.</div>`;return;}
  listEl.innerHTML="";
  lista.forEach(nf=>{
    const div=document.createElement("div");div.className="nf-item";
    const sit=(nf.situacao||"").toString().toUpperCase();
    const sc=sit==="A"?"autorizado":sit==="C"?"cancelado":"outro";
    const sl=sc==="autorizado"?"Autorizada":sc==="cancelado"?"Cancelada":sit||"—";
    const emit=nf.nome_contato||nf.remetente?.nome||nf.fornecedor?.nome||nf.nome||"—";
    const num=nf.numero||nf.numero_nf||"—";
    const val=Number(nf.valor_total||nf.valor||0).toLocaleString("pt-BR",{minimumFractionDigits:2});
    const dt=nf.data_emissao||nf.data||"—";
    div.innerHTML=`<div class="nf-item-top"><span class="nf-num">NF ${num}</span><span class="nf-status ${sc}">${sl}</span></div><div class="nf-emit" title="${emit}">${emit}</div><div class="nf-meta"><span>${dt}</span><span>R$ ${val}</span></div>`;
    div.onclick=()=>selecionarNF(nf,div);listEl.appendChild(div);
  });
}
async function selecionarNF(nf,el){
  document.querySelectorAll(".nf-item").forEach(d=>d.classList.remove("active"));
  el.classList.add("active");activeNF=nf;xmlCarregado=null;xmlCteCarregado=null;if(document.getElementById('cte-drop'))limparCTE();
  const main=document.getElementById("main");
  main.innerHTML=`<div class="main-empty"><span class="spinner" style="width:32px;height:32px;border-width:3px"></span><br><br><p>Carregando NF ${nf.numero||"—"}...</p></div>`;
  try{
    dbg("Carregando id="+nf.id);
    const data=await proxy("detalhe_nf",{id:nf.id});
    const ret=data?.retorno;
    if(!ret||ret.status==="Erro")throw new Error(ret?.erros?.[0]?.erro||"Erro ao obter NF");
    activeNFData=ret.nota_fiscal||ret.nota||{};
    renderMain(activeNFData,nf);
  }catch(e){dbg(e.message,"err");toast(e.message,"err");main.innerHTML=`<div class="main-empty"><p style="color:var(--red)">${e.message}</p></div>`;}
}

/* ── Render tela ── */
function renderMain(nfData,nfMeta){
  let lista=[];
  const itensRaw=nfData.itens||nfData.itens_nota||nfData.produtos||[];
  if(Array.isArray(itensRaw))lista=itensRaw.map(i=>i.item||i.produto||i);
  else if(itensRaw&&typeof itensRaw==="object"){const val=Object.values(itensRaw)[0];lista=Array.isArray(val)?val.map(i=>i.item||i):[itensRaw];}
  dbg("Itens: "+lista.length,lista.length>0?"ok":"err");
  // Log completo do primeiro item para ver todos os campos disponíveis
  if(lista.length>0){
    dbg("Keys item[0]: "+Object.keys(lista[0]).join(", "));
    dbg("item[0] completo: "+JSON.stringify(lista[0]).substring(0,400));
  }

  rows=lista.map((item,idx)=>{
    const ipiRaw = item.percentual_ipi ?? item.aliquota_ipi ?? item.p_ipi ?? item.ipi_percentual ?? item.ipi ?? null;
    const ipiVal = ipiRaw!=null && ipiRaw!=="" ? parseFloat(ipiRaw) : null;
    if(idx===0) dbg("IPI campo: "+JSON.stringify(ipiRaw)+" val="+ipiVal);
    return {
      id:idx,
      sku:item.codigo||item.sku||"",
      desc:item.descricao||item.nome||"",
      pc:parseFloat(item.valor_unitario||item.preco_unitario||0),
      q:parseFloat(item.quantidade||1),
      ipi:ipiVal,
      frete:null
    };
  });
  const emit=nfMeta.nome_contato||nfMeta.nome||nfData.remetente||"—";
  const dt=nfMeta.data_emissao||nfData.data_emissao||"—";
  const num=nfMeta.numero||nfData.numero||"—";

  document.getElementById("main").innerHTML=`
    <div class="main-header">
      <div class="nf-info-block">
        <div class="nf-info-num">NF ${num}</div>
        <div class="nf-info-emit">${emit}</div>
        <div class="nf-info-meta">Emissão: ${dt} &nbsp;·&nbsp; ${lista.length} itens</div>
      </div>
    </div>

    <div class="xml-bar">
      <span class="xml-label">XML da NF:</span>
      <label class="xml-drop" id="xml-drop" ondragover="xmlDragOver(event)" ondragleave="xmlDragLeave(event)" ondrop="xmlDrop(event)">
        <input type="file" id="xml-file" accept=".xml" onchange="xmlFileChange(event)"/>
        <span id="xml-drop-text">📂 Clique ou arraste o arquivo XML da NF aqui</span>
      </label>
      <button class="xml-clear" id="xml-clear-btn" onclick="limparXML()" style="display:none">✕ Remover</button>
      <div class="xml-hint">Baixe o XML no Tiny: Suprimentos → Notas de Entrada → ⋮ → Baixar XML</div>
    </div>
    <div class="xml-bar" style="border-top:none;">
      <span class="xml-label">XML da CT-e:</span>
      <label class="xml-drop" id="cte-drop" ondragover="cteDragOver(event)" ondragleave="cteDragLeave(event)" ondrop="cteDrop(event)">
        <input type="file" id="cte-file" accept=".xml" onchange="cteFileChange(event)"/>
        <span id="cte-drop-text">📂 Opcional — arraste o XML da CT-e (frete por conta nossa)</span>
      </label>
      <button class="xml-clear" id="cte-clear-btn" onclick="limparCTE()" style="display:none">✕ Remover</button>
      <div class="xml-hint" style="color:var(--muted);font-style:italic;">Opcional — apenas quando o frete for por nossa conta</div>
    </div>

    <div class="globals-bar">
      <span class="label">Ajustes globais:</span>
      <div class="global-field"><span style="font-size:12px;color:var(--muted)">IPI global %</span><input type="number" id="g-ipi" placeholder="0" min="0" step="0.01" oninput="recalc()"/></div>
      <div class="global-field"><span style="font-size:12px;color:var(--muted)">Frete global %</span><input type="number" id="g-frete" placeholder="0" min="0" step="0.01" oninput="recalc()"/></div>
      <div class="global-field">
        <span style="font-size:12px;color:var(--muted)">Categoria</span>
        <select id="g-categoria" onchange="recalc()" style="background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:7px 10px;color:var(--text);font-family:var(--mono);font-size:13px;outline:none;cursor:pointer;">
          <option value="moveis">Móveis</option>
          <option value="eletro">Eletro</option>
        </select>
      </div>
      <span class="globals-hint">Valores por linha sobrescrevem o global</span>
    </div>

    <div class="table-wrap"><table>
      <thead><tr>
        <th style="width:80px">CÓD SKU</th><th>Descrição</th>
        <th class="num" style="width:80px">PC (R$)</th>
        <th class="num" style="width:65px">IPI %</th>
        <th class="num" style="width:65px">Frete %</th>
        <th class="num" style="width:85px">PF (R$)</th>
        <th class="num" style="width:85px">PL (R$)</th>
        <th class="num" style="width:85px">PP (R$)</th>
        <th class="num" style="width:50px">Qtde</th>
      </tr></thead>
      <tbody id="tbody"></tbody>
    </table></div>

    <div class="summary-bar">
      <div class="metric m-pc"><div class="mlabel">Total PC</div><div class="mval" id="s-pc">R$ 0,00</div></div>
      <div class="metric m-pf"><div class="mlabel">Total PF</div><div class="mval" id="s-pf">R$ 0,00</div></div>
      <div class="metric m-pl"><div class="mlabel">Total PL</div><div class="mval" id="s-pl">R$ 0,00</div></div>
      <div class="metric m-pp"><div class="mlabel">Total PP</div><div class="mval" id="s-pp">R$ 0,00</div></div>
      <div class="export-group">
        <button class="btn-csv" onclick="exportarCSV()">↓ CSV</button>
        <button class="btn-csv" id="btn-atualizar-tiny" onclick="atualizarPrecosTiny()" style="color:var(--teal);border-color:var(--teal);">↑ Atualizar Preços no Tiny</button>
        <button class="btn-export" id="btn-pdf" onclick="exportarPDF()">↓ PDF completo</button>
      </div>
    </div>`;
  renderTabela();
}

/* ── XML upload handlers ── */
function xmlDragOver(e){e.preventDefault();document.getElementById("xml-drop").classList.add("over");}
function xmlDragLeave(e){document.getElementById("xml-drop").classList.remove("over");}
function xmlDrop(e){e.preventDefault();document.getElementById("xml-drop").classList.remove("over");const f=e.dataTransfer.files[0];if(f)lerXML(f);}
function xmlFileChange(e){const f=e.target.files[0];if(f)lerXML(f);}
function lerXML(file){
  if(!file.name.endsWith(".xml")&&file.type!=="text/xml"){toast("Selecione um arquivo .xml","err");return;}
  const reader=new FileReader();
  reader.onload=e=>{
    xmlCarregado=e.target.result;
    const drop=document.getElementById("xml-drop");
    drop.classList.add("loaded");
    document.getElementById("xml-drop-text").textContent="✓ "+file.name+" carregado";
    document.getElementById("xml-clear-btn").style.display="inline-block";
    toast("XML carregado: "+file.name,"ok");
    dbg("XML carregado: "+file.name+" ("+file.size+" bytes)","ok");

    // Valida se o XML é da NF correta
    const nNFMatch = xmlCarregado.match(/<nNF[^>]*>(\d+)<\/nNF>/);
    if(nNFMatch && activeNF){
      const nNFXml = parseInt(nNFMatch[1]);
      const nNFAtiva = parseInt(activeNF.numero||"0");
      if(nNFXml !== nNFAtiva){
        // XML errado — avisa e bloqueia
        toast("⚠️ XML incorreto! O XML é da NF "+nNFXml+" mas a NF selecionada é "+nNFAtiva,"err");
        dbg("ERRO: XML da NF "+nNFXml+" não corresponde à NF "+nNFAtiva+" selecionada","err");
        // Destaca o drop em vermelho
        drop.classList.remove("loaded");
        drop.style.borderColor="var(--red)";
        drop.style.color="var(--red)";
        document.getElementById("xml-drop-text").textContent="❌ XML incorreto! NF "+nNFXml+" ≠ NF "+nNFAtiva;
        document.getElementById("xml-clear-btn").style.display="inline-block";
        xmlCarregado=null; // invalida o XML
        atualizarBotaoPDF();
        return;
      } else {
        dbg("✓ XML validado: NF "+nNFXml+" corresponde à NF selecionada","ok");
        toast("✓ XML validado! Corresponde à NF "+nNFAtiva,"ok");
      }
    }

    // Extrai IPI de cada produto do XML e preenche na tabela
    extrairIPIDoXML(xmlCarregado);
    atualizarBotaoPDF();
  };
  reader.readAsText(file);
}

function extrairIPIDoXML(xmlStr){
  try{
    // Divide por nItem="N" que aparece como atributo na tag det
    // ex: <det nItem="1"> ou <ns1:det nItem="1">
    const partes = xmlStr.split(/nItem="/);
    // partes[0] = cabeçalho, partes[1..N] = cada item começando com "1">..."
    const blocos = partes.slice(1); // remove o cabeçalho

    dbg("Blocos por nItem attr: "+blocos.length+" | itens tabela: "+rows.length);

    if(blocos.length===0){
      // Último fallback: pega todos pIPI em ordem e aplica por índice
      const pIPIs=[...xmlStr.matchAll(/<pIPI[^>]*>([^<]+)<\/pIPI>/g)].map(m=>parseFloat(m[1]));
      dbg("Fallback pIPIs: "+pIPIs.length);
      rows.forEach((r,i)=>{ r.ipi = pIPIs[i] ?? 0; });
      renderTabela();
      toast("IPI aplicado por índice!","ok");
      return;
    }

    let comIPI=0, semIPI=0;
    blocos.forEach((bloco, idx)=>{
      const row = rows[idx];
      if(!row) return;

      const pIPIM = bloco.match(/<pIPI[^>]*>([^<]+)<\/pIPI>/);
      if(pIPIM){
        row.ipi = parseFloat(pIPIM[1].trim());
        comIPI++;
      } else {
        row.ipi = 0;
        semIPI++;
      }
      if(idx<3) dbg("Item "+(idx+1)+": IPI="+(pIPIM ? row.ipi+"%" : "0% (sem IPI)"));
    });

    dbg(comIPI+" com IPI | "+semIPI+" sem IPI (0%)","ok");
    renderTabela();
    toast("IPI preenchido em "+rows.length+" produto(s)!","ok");

  }catch(e){
    dbg("Erro ao extrair IPI: "+e.message,"err");
  }
}
function limparXML(){
  xmlCarregado=null;
  const drop=document.getElementById("xml-drop");
  drop.classList.remove("loaded");
  drop.style.borderColor="";
  drop.style.color="";
  document.getElementById("xml-drop-text").textContent="📂 Clique ou arraste o arquivo XML da NF aqui";
  document.getElementById("xml-clear-btn").style.display="none";
  document.getElementById("xml-file").value="";
  atualizarBotaoPDF();
}

function cteDragOver(e){e.preventDefault();document.getElementById("cte-drop").classList.add("over");}
function cteDragLeave(e){document.getElementById("cte-drop").classList.remove("over");}
function cteDrop(e){e.preventDefault();document.getElementById("cte-drop").classList.remove("over");const f=e.dataTransfer.files[0];if(f)lerCTE(f);}
function cteFileChange(e){const f=e.target.files[0];if(f)lerCTE(f);}

function lerCTE(file){
  if(!file.name.endsWith(".xml")&&file.type!=="text/xml"){toast("Selecione um arquivo .xml","err");return;}
  const reader=new FileReader();
  reader.onload=e=>{
    const xml=e.target.result;
    // Valida se é CT-e (tag cteProc ou CTe)
    if(!xml.includes("<CTe") && !xml.includes("<cteProc")){
      toast("Arquivo não é um XML de CT-e válido","err");
      return;
    }
    xmlCteCarregado=xml;
    const drop=document.getElementById("cte-drop");
    drop.classList.add("loaded");
    document.getElementById("cte-drop-text").textContent="✓ "+file.name+" carregado";
    document.getElementById("cte-clear-btn").style.display="inline-block";
    toast("CT-e carregado: "+file.name,"ok");
    dbg("CT-e carregado: "+file.name+" ("+file.size+" bytes)","ok");
  };
  reader.readAsText(file);
}

function limparCTE(){
  xmlCteCarregado=null;
  const drop=document.getElementById("cte-drop");
  drop.classList.remove("loaded");
  drop.style.borderColor="";
  drop.style.color="";
  document.getElementById("cte-drop-text").textContent="📂 Opcional — arraste o XML da CT-e (frete por conta nossa)";
  document.getElementById("cte-clear-btn").style.display="none";
  document.getElementById("cte-file").value="";
}

function atualizarBotaoPDF(){
  // Bloqueia/libera tanto o PDF quanto o botão de atualizar Tiny — ambos dependem do XML
  const btns = [
    { el: document.getElementById("btn-pdf"), msg: "Anexe o XML da NF para gerar o PDF" },
    { el: document.getElementById("btn-atualizar-tiny"), msg: "Anexe o XML da NF para atualizar preços no Tiny" }
  ];
  btns.forEach(({el, msg}) => {
    if(!el) return;
    if(!xmlCarregado){
      el.disabled = true;
      el.title = msg;
      el.style.opacity = "0.4";
      el.style.cursor = "not-allowed";
    } else {
      el.disabled = false;
      el.title = "";
      el.style.opacity = "";
      el.style.cursor = "";
    }
  });
}

/* ── Cálculos ── */
function getGlobal(){return{gi:parseFloat(document.getElementById("g-ipi")?.value)||0,gf:parseFloat(document.getElementById("g-frete")?.value)||0};}
function arredondar(v){const cents=Math.round((v%1)*100);return cents>=50?Math.ceil(v):Math.floor(v);}
function calcRow(r){
  const{gi,gf}=getGlobal();
  const ipi=r.ipi!==null?r.ipi:gi;
  const frete=r.frete!==null?r.frete:gf;
  const pf=r.pc*(1+ipi/100+frete/100);
  const cat=document.getElementById("g-categoria")?.value||"moveis";
  const m1=cat==="eletro"?1.45:1.50;
  const m2=cat==="eletro"?1.50:1.55;
  const pl=arredondar(pf*m1*m2);
  const pp=arredondar(pl*0.67);
  return{ipi,frete,pf,pl,pp};
}
function fmt(v){return v.toLocaleString("pt-BR",{minimumFractionDigits:2,maximumFractionDigits:2});}
function renderPLCell(r, pl){
  // Verifica se tem preço atual no Tiny para comparar
  if(r.precoTiny && pl < r.precoTiny){
    // PL calculado é MENOR — mostra tachado + preço atual maior
    return `<div class="pl-wrap">
      <span class="pl-atual val-pl">R$ ${fmt(r.precoTiny)}</span>
      <span class="pl-menor">R$ ${fmt(pl)}</span>
    </div>`;
  }
  return `<span class="val-pl">R$ ${fmt(pl)}</span>`;
}

function renderTabela(){
  atualizarBotaoPDF();
  const tbody=document.getElementById("tbody");if(!tbody)return;tbody.innerHTML="";
  if(!rows.length){tbody.innerHTML=`<tr><td colspan="9" style="text-align:center;padding:32px;color:var(--muted)">Nenhum item encontrado.</td></tr>`;updateSummary();return;}
  rows.forEach(r=>{
    const{pf,pl,pp}=calcRow(r);const tr=document.createElement("tr");
    tr.innerHTML=`<td class="sku">${r.sku||"—"}</td><td class="desc"><span title="${r.desc}">${r.desc||"—"}</span></td><td class="num">${fmt(r.pc)}</td><td class="num"><input type="number" value="${r.ipi!==null?r.ipi:""}" placeholder="${getGlobal().gi||"0"}" step="0.01" min="0" oninput="upd(${r.id},'ipi',this.value)"/></td><td class="num"><input type="number" value="${r.frete!==null?r.frete:""}" placeholder="${getGlobal().gf||"0"}" step="0.01" min="0" oninput="upd(${r.id},'frete',this.value)"/></td><td class="num val-pf" id="pf-${r.id}">${fmt(pf)}</td><td class="num" id="pl-${r.id}">${renderPLCell(r,pl)}</td><td class="num val-pp" id="pp-${r.id}">${fmt(pp)}</td><td class="num">${r.q}</td>`;
    tbody.appendChild(tr);
  });updateSummary();
}
function upd(id,field,val){const r=rows.find(r=>r.id===id);if(!r)return;r[field]=val===""?null:parseFloat(val);const{pf,pl,pp}=calcRow(r);["pf","pl","pp"].forEach(k=>{const e=document.getElementById(k+"-"+id);if(e)e.textContent=fmt({pf,pl,pp}[k]);});updateSummary();}
function recalc(){renderTabela();}
function updateSummary(){let tPc=0,tPf=0,tPl=0,tPp=0;rows.forEach(r=>{const{pf,pl,pp}=calcRow(r);tPc+=r.pc*r.q;tPf+=pf*r.q;tPl+=pl*r.q;tPp+=pp*r.q;});[["s-pc",tPc],["s-pf",tPf],["s-pl",tPl],["s-pp",tPp]].forEach(([id,v])=>{const e=document.getElementById(id);if(e)e.textContent="R$ "+fmt(v);});}

/* ── ATUALIZAR PREÇOS NO TINY ── */
async function atualizarPrecosTiny(){
  if(!xmlCarregado){ toast("Anexe o XML da NF antes de atualizar os preços","err"); return; }
  if(!rows.length){ toast("Nenhum produto para atualizar","err"); return; }
  const btn = document.getElementById("btn-atualizar-tiny");
  btn.disabled = true;
  btn.textContent = "⏳ Buscando preços...";

  let atualizados = 0;
  let ignorados = 0;
  let erros = 0;

  for(const r of rows){
    if(!r.sku){ erros++; continue; }
    try{
      const {pf, pl} = calcRow(r);

      // 1º — Pesquisa produto no Tiny pelo SKU para obter o ID interno
      btn.textContent = `⏳ Buscando ${r.sku}...`;
      const respPesq = await proxy("pesquisar_produto", { pesquisa: r.sku });
      const listaProd = respPesq?.retorno?.produtos;

      if(!listaProd || !listaProd.length){
        dbg("Produto não encontrado no Tiny: "+r.sku,"err");
        erros++;
        continue;
      }

      // Tenta achar produto com SKU exatamente igual (a pesquisa pode retornar vários)
      const prodPesq = listaProd.find(p => (p.produto?.codigo || "").trim() === r.sku.trim())?.produto
                    || listaProd[0].produto;

      const idProduto = prodPesq.id;
      if(!idProduto){ dbg("ID não encontrado para SKU: "+r.sku,"err"); erros++; continue; }

      // 2º — Obtém detalhes completos do produto pelo ID
      const respBusca = await proxy("obter_produto", { id: idProduto });
      const prod = respBusca?.retorno?.produto;

      if(!prod){ dbg("Falha ao obter detalhes do produto "+r.sku,"err"); erros++; continue; }

      const precoAtual = parseFloat(prod.preco || 0);

      // Salva preço atual para comparação visual
      r.precoTiny = precoAtual;

      // Monta payload de atualização
      const payload = {
        id: idProduto,
        preco_custo: pf.toFixed(2), // sempre atualiza PF como custo
      };

      // PL só atualiza se for MAIOR que o atual
      if(pl > precoAtual){
        payload.preco = pl.toFixed(2);
        atualizados++;
        dbg(`✓ ${r.sku}: PF=${fmt(pf)} | PL ${fmt(precoAtual)}→${fmt(pl)}`, "ok");
      } else {
        ignorados++;
        dbg(`↔ ${r.sku}: PF=${fmt(pf)} | PL mantido (${fmt(precoAtual)} > ${fmt(pl)})`);
      }

      // Envia atualização para o Tiny
      btn.textContent = `⏳ Atualizando ${r.sku}...`;
      await proxy("alterar_produto", payload);

    }catch(e){
      dbg("Erro ao atualizar "+r.sku+": "+e.message,"err");
      erros++;
    }
  }

  // Redesenha tabela com indicadores visuais
  renderTabela();

  btn.disabled = false;
  btn.textContent = "↑ Atualizar Preços no Tiny";

  toast(`✓ ${atualizados} atualizados | ${ignorados} mantidos | ${erros} erros`, atualizados > 0 ? "ok" : "err");
}

/* ── CSV ── */
function exportarCSV(){
  if(!rows.length){toast("Nenhum dado","err");return;}
  const header="SKU,Descrição,PC,IPI%,Frete%,PF,PL,PP,Qtde";
  const linhas=rows.map(r=>{const{ipi,frete,pf,pl,pp}=calcRow(r);return[r.sku,`"${r.desc}"`,r.pc.toFixed(2),ipi.toFixed(2),frete.toFixed(2),pf.toFixed(2),pl.toFixed(2),pp.toFixed(2),r.q].join(",");});
  const csv=[header,...linhas].join("\n");
  const blob=new Blob(["\uFEFF"+csv],{type:"text/csv;charset=utf-8;"});
  const url=URL.createObjectURL(blob);const a=document.createElement("a");a.href=url;a.download=`NF_${activeNF?.numero||"export"}_precificacao.csv`;a.click();URL.revokeObjectURL(url);toast("CSV exportado!");
}

/* ── PDF ── */
async function exportarPDF(){
  if(!rows.length){toast("Nenhum dado","err");return;}
  const btn=document.getElementById("btn-pdf");
  btn.disabled=true;

  try{
    let danfeBytes=null;

    if(xmlCarregado){
      // Tem XML carregado — gera DANFE
      btn.textContent="Gerando DANFE...";
      dbg("Enviando XML para gerar DANFE...");
      const resp=await fetch(API,{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({action:"danfe_from_xml",token,params:{xml:xmlCarregado}})});
      const data=await resp.json();
      if(data.erro){
        dbg("Erro DANFE: "+data.erro,"err");
        toast("Erro ao gerar DANFE: "+data.erro,"err");
      } else {
        danfeBytes=base64ToBytes(data.pdf);
        dbg("DANFE gerado com sucesso!","ok");
      }
    } else {
      dbg("Sem XML — gerando só a tabela de precificação");
      toast("Sem XML carregado — gerando só a tabela de precificação");
    }

    btn.textContent="Montando PDF...";
    const precBytes=await gerarPaginaPrecificacao();

    // Gera DACT-e se CT-e foi carregada
    let dacteBytes=null;
    if(xmlCteCarregado){
      btn.textContent="Gerando DACT-e...";
      dbg("Enviando CT-e para gerar DACT-e...");
      try{
        const respCte=await fetch(API,{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({action:"danfe_from_xml",token,params:{xml:xmlCteCarregado}})});
        const dataCte=await respCte.json();
        if(dataCte.erro){
          dbg("Erro DACT-e: "+dataCte.erro,"err");
          toast("Erro ao gerar DACT-e: "+dataCte.erro,"err");
        } else {
          dacteBytes=base64ToBytes(dataCte.pdf);
          dbg("DACT-e gerado!","ok");
        }
      }catch(e){
        dbg("Erro DACT-e: "+e.message,"err");
      }
    }

    let finalBytes;
    if(danfeBytes && dacteBytes){
      finalBytes=await mergePDFs(precBytes,danfeBytes,dacteBytes);
      toast("PDF completo! Precificação + DANFE + DACT-e","ok");
    } else if(danfeBytes){
      finalBytes=await mergePDFs(precBytes,danfeBytes);
      toast("PDF completo gerado! Precificação (pág 1) + DANFE (pág 2)","ok");
    } else {
      finalBytes=precBytes;
      toast("PDF de precificação gerado!","ok");
    }
    registrarNoPrecificado();

    const nfNum = String(activeNF?.numero||"000000").padStart(6,"0").slice(-6);
    const fornecedor = (activeNF?.nome_contato||activeNF?.nome||"FORNECEDOR")
      .toUpperCase()
      .replace(/[<>:"/\\|?*]/g,"") // remove caracteres inválidos em nomes de arquivo
      .trim()
      .substring(0,60);
    const nomeArq=`${nfNum} - ${fornecedor}.pdf`;
    const b64 = btoa(String.fromCharCode(...new Uint8Array(finalBytes)));

    // Detecta Electron pelo process.type
    let isElectron = false;
    try { isElectron = !!(window.process && window.process.type); } catch(e) {}

    // Envia para o servidor salvar (funciona tanto no Electron quanto no browser)
    try{
      const resp = await fetch(window.location.origin+"/salvar-pdf-nf",{
        method:"POST",
        headers:{"Content-Type":"application/json"},
        body:JSON.stringify({nome:nomeArq, pdf:b64, isLocal:isElectron})
      });
      const res = await resp.json();
      if(res.ok){
        dbg("PDF salvo: "+nomeArq,"ok");
        mostrarAvisoPDF(nomeArq, res.caminho||"Downloads");
      } else {
        toast("Erro ao salvar PDF: "+(res.erro||"erro desconhecido"),"err");
      }
    }catch(e){
      toast("Erro ao salvar PDF: "+e.message,"err");
      dbg("Erro: "+e.message,"err");
    }

    // Browser externo (IP): faz download normal também
    if(!isElectron){
      const blob=new Blob([finalBytes],{type:"application/pdf"});
      const url=URL.createObjectURL(blob);
      const a=document.createElement("a");a.href=url;a.download=nomeArq;a.click();
      URL.revokeObjectURL(url);
    }

  }catch(e){
    dbg(e.message,"err");toast("Erro: "+e.message,"err");
  }finally{
    btn.disabled=false;btn.textContent="↓ PDF completo";
  }
}

function mostrarAvisoPDF(nome, local){
  // Cria aviso no centro da tela
  const overlay = document.createElement("div");
  overlay.style.cssText=`position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:99999;display:flex;align-items:center;justify-content:center;`;
  overlay.innerHTML=`
    <div style="background:var(--surface);border:1px solid var(--border2);border-radius:16px;padding:32px 36px;text-align:center;max-width:380px;animation:fadeIn .2s ease;">
      <div style="font-size:48px;margin-bottom:12px;">✅</div>
      <div style="font-size:17px;font-weight:600;color:var(--text);margin-bottom:8px;">PDF Salvo!</div>
      <div style="font-size:13px;color:var(--muted);margin-bottom:6px;">${nome}</div>
      <div style="font-size:12px;color:var(--teal);margin-bottom:24px;">📁 ${local}</div>
      <button onclick="this.closest('div[style*=inset]').remove()" style="background:var(--accent);color:#0f0f0f;border:none;border-radius:8px;padding:10px 28px;font-size:14px;font-weight:700;cursor:pointer;font-family:var(--sans);">OK</button>
    </div>`;
  document.body.appendChild(overlay);
  overlay.addEventListener("click", e=>{ if(e.target===overlay) overlay.remove(); });
}

function base64ToBytes(b64){
  const bin=atob(b64);const bytes=new Uint8Array(bin.length);
  for(let i=0;i<bin.length;i++)bytes[i]=bin.charCodeAt(i);
  return bytes;
}

async function mergePDFs(...pdfs){
  const{PDFDocument}=await import("https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.esm.js");
  const out=await PDFDocument.create();
  for(const pdf of pdfs){
    if(!pdf) continue;
    const doc=await PDFDocument.load(pdf);
    const pages=await out.copyPages(doc,doc.getPageIndices());
    pages.forEach(p=>out.addPage(p));
  }
  return await out.save();
}

async function gerarPaginaPrecificacao(){
  const{jsPDF}=window.jspdf;
  // Retrato A4 — muito melhor no celular
  const doc=new jsPDF({orientation:"portrait",unit:"mm",format:"a4"});
  const W=210, M=10;

  // Paleta
  const BG_DARK=[18,18,18];
  const BG_CARD=[245,245,243];
  const BG_HEAD=[230,230,228];
  const BLACK=[10,10,10];
  const GRAY=[120,118,112];
  const LGRAY=[200,200,198];
  const GREEN=[40,120,10];
  const GREEN_BG=[230,248,220];
  const AMBER=[160,100,5];
  const AMBER_BG=[255,243,210];
  const TEAL=[10,130,115];
  const TEAL_BG=[215,245,240];
  const ACCENT_Y=[200,240,96]; // amarelo-limao

  let y=0;

  // ── CABEÇALHO ──────────────────────────────────────────────────────────────
  doc.setFillColor(...BG_DARK);
  doc.rect(0,0,W,28,"F");
  doc.setFillColor(...ACCENT_Y);
  doc.rect(0,0,5,28,"F");

  doc.setFont("helvetica","bold");
  doc.setFontSize(16);
  doc.setTextColor(...ACCENT_Y);
  doc.text("TABELA DE PRECIFICAÇÃO",M+5,12);

  doc.setFont("helvetica","normal");
  doc.setFontSize(8);
  doc.setTextColor(160,158,140);
  const emit=(activeNF?.nome_contato||activeNF?.nome||"—").substring(0,45);
  doc.text(emit,M+5,20);
  doc.text(`NF ${activeNF?.numero||"—"}  ·  Emissão: ${activeNF?.data_emissao||"—"}`,M+5,26);
  y=32;

  // ── BLOCO INFO NF ──────────────────────────────────────────────────────────
  const infoH=22;
  doc.setFillColor(...BG_CARD);
  doc.rect(M,y,W-M*2,infoH,"F");
  doc.setDrawColor(...LGRAY);doc.setLineWidth(0.2);
  doc.rect(M,y,W-M*2,infoH,"D");

  const infoFields=[
    ["FORNECEDOR",emit],
    ["NOTA FISCAL","NF "+(activeNF?.numero||"—")],
    ["DATA EMISSÃO",activeNF?.data_emissao||"—"],
    ["VALOR NF","R$ "+Number(activeNF?.valor_total||activeNF?.valor||0).toLocaleString("pt-BR",{minimumFractionDigits:2})],
  ];
  const iW=(W-M*2)/4;
  infoFields.forEach(([lbl,val],i)=>{
    const x=M+i*iW;
    if(i>0){doc.setDrawColor(...LGRAY);doc.setLineWidth(0.2);doc.line(x,y,x,y+infoH);}
    doc.setFont("helvetica","normal");doc.setFontSize(6);doc.setTextColor(...GRAY);
    doc.text(lbl,x+3,y+7);
    doc.setFont("helvetica","bold");doc.setFontSize(9);doc.setTextColor(...BLACK);
    doc.text(val.substring(0,22),x+3,y+16);
  });
  y+=infoH+6;

  // ── TABELA DE ITENS ─────────────────────────────────────────────────────────
  // Só as colunas mais importantes — SKU, Descrição, PC, PF, PL, PP, Qtde
  function fmtPct(v){ return v.toFixed(2).replace(".",",")+"%"; }
  function fmtR(v){ return "R$"+v.toLocaleString("pt-BR",{minimumFractionDigits:2,maximumFractionDigits:2}); }

  // Quebra descrição em 2 linhas quebrando em espaço
  function splitDesc(d){
    d=(d||"—").trim();
    if(d.length<=28) return d;
    let cut=d.lastIndexOf(" ",28);
    if(cut<8) cut=28;
    const l1=d.substring(0,cut).trim();
    const l2=d.substring(cut).trim().substring(0,28);
    return l1+"\n"+l2;
  }

  const precRows=rows.map(r=>{
    const{ipi,frete,pf,pl,pp}=calcRow(r);
    // Se precoTiny > pl → mostra valor maior no topo, pl tachado abaixo
    const temRisco = r.precoTiny && pl < r.precoTiny;
    const celulaPL = temRisco
      ? { content: fmtR(r.precoTiny) + "\n" + fmtR(pl), _risco: true, _plCalc: pl }
      : fmtR(pl);
    return[
      r.sku||"—",
      splitDesc(r.desc),
      fmtPct(ipi),
      fmtPct(frete),
      fmtR(r.pc),
      fmtR(pf),
      fmtR(pp),
      celulaPL,
      String(r.q),
    ];
  });

  // 190mm: 14+52+12+12+24+24+24+24+4 = 190
  doc.autoTable({
    startY:y,
    head:[["SKU","Descrição","IPI","Frete","PC","PF","PP","PL","Q"]],
    body:precRows,
    theme:"plain",
    styles:{
      fontSize:8,
      cellPadding:{top:3,bottom:3,left:2,right:2},
      lineColor:LGRAY,
      lineWidth:0.2,
      textColor:BLACK,
      valign:"middle",
      overflow:"linebreak",
      minCellHeight:10,
    },
    headStyles:{
      fillColor:BG_HEAD,
      textColor:GRAY,
      fontStyle:"bold",
      fontSize:7.5,
      halign:"center",
      cellPadding:{top:4,bottom:4,left:2,right:2},
    },
    columnStyles:{
      0:{cellWidth:13,halign:"center",fontStyle:"bold",textColor:GREEN},
      1:{cellWidth:44,fontSize:7,overflow:"linebreak"},
      2:{cellWidth:12,halign:"center",textColor:AMBER,fontStyle:"bold"},
      3:{cellWidth:12,halign:"center",textColor:TEAL,fontStyle:"bold"},
      4:{cellWidth:23,halign:"right"},
      5:{cellWidth:23,halign:"right",textColor:AMBER,fontStyle:"bold"},
      6:{cellWidth:23,halign:"right",textColor:GREEN,fontStyle:"bold"},
      7:{cellWidth:23,halign:"right",textColor:TEAL,fontStyle:"bold"},
      8:{cellWidth:17,halign:"center",fontStyle:"bold",fontSize:9},
    },
    alternateRowStyles:{fillColor:[250,250,249]},
    margin:{left:M,right:M},
    rowPageBreak:"avoid",
    didDrawCell: function(data) {
      // Quando o PL calculado é MENOR que o preço do Tiny:
      // - linha 1: preço do Tiny (mantido)
      // - linha 2: PL calculado (tachado com um risco)
      if(data.section === "body" && data.column.index === 7 && data.cell.raw && data.cell.raw._risco){
        const c = data.cell;
        // Calcula a altura que cada linha ocupa dentro da célula
        // Texto tem fontSize 8 → ~2.8mm de altura por linha
        const padTop = c.padding("top");
        const padBottom = c.padding("bottom");
        const alturaUtil = c.height - padTop - padBottom;
        // Linha de baixo fica no centro da metade inferior
        const yRisco = c.y + padTop + alturaUtil * 0.75;
        doc.setDrawColor(200,40,40);
        doc.setLineWidth(0.5);
        doc.line(c.x + 3, yRisco, c.x + c.width - 3, yRisco);
      }
    }
  });
  y=doc.lastAutoTable.finalY+8;

  // ── BLOCO IPI E FRETE ──────────────────────────────────────────────────────
  const{gi,gf}=getGlobal();
  const ipiInfo=gi>0?`IPI global: ${fmt(gi)}%`:"IPI: por item";
  const freteInfo=gf>0?`Frete global: ${fmt(gf)}%`:"Frete: por item";

  doc.setFillColor(248,248,246);
  doc.setDrawColor(...LGRAY);doc.setLineWidth(0.2);
  doc.roundedRect(M,y,W-M*2,16,2,2,"FD");

  doc.setFont("helvetica","bold");doc.setFontSize(8);doc.setTextColor(...AMBER);
  doc.text(ipiInfo,M+6,y+7);
  doc.setFont("helvetica","bold");doc.setFontSize(8);doc.setTextColor(...TEAL);
  doc.text(freteInfo,M+6,y+13);

  doc.setFont("helvetica","normal");doc.setFontSize(7);doc.setTextColor(...GRAY);
  doc.text("PF = PC × (1 + IPI% + Frete%)",(W-M)-3,y+7,{align:"right"});
  doc.text("PL = PF × 1,50 × 1,55   ·   PP = PL × 0,67",(W-M)-3,y+13,{align:"right"});
  y+=22;

  // ── LEGENDA ────────────────────────────────────────────────────────────────
  doc.setFillColor(248,248,246);
  doc.roundedRect(M,y,W-M*2,14,2,2,"F");
  doc.setFont("helvetica","normal");doc.setFontSize(7);doc.setTextColor(...GRAY);
  doc.text("PF = PC × (1 + IPI% + Frete%)",M+5,y+5.5);
  const _cat=document.getElementById("g-categoria")?.value==="eletro"?"PL = PF × 1,45 × 1,50":"PL = PF × 1,50 × 1,55";
  doc.text(_cat,M+5,y+11);
  doc.text("PP = PL × 0,67",(W-M),y+5.5,{align:"right"});
  doc.text(`Markup móveis aplicado`,(W-M),y+11,{align:"right"});
  y+=20;

  // ── RODAPÉ ─────────────────────────────────────────────────────────────────
  doc.setFont("helvetica","normal");doc.setFontSize(7);doc.setTextColor(...GRAY);
  doc.text(`Gerado em ${new Date().toLocaleString("pt-BR")}`,M,287);
  doc.setFont("helvetica","bold");doc.setTextColor(...GREEN);
  doc.text("Precificação NF Entrada",W-M,287,{align:"right"});

  return doc.output("arraybuffer");
}

/* ── ABAS ── */
function mudarAba(aba){
  document.querySelectorAll(".app-tab").forEach(t=>t.classList.remove("active"));
  document.querySelectorAll(".tab-content").forEach(t=>t.classList.remove("active"));
  document.getElementById("tab-"+aba).classList.add("active");
  document.getElementById("tc-"+aba).classList.add("active");
  if(aba==="hist") renderHistorico();
}

/* ── HISTÓRICO ── */
let _histData = [];
let _histFiltro = "";
let _histCarregado = false;

async function carregarHistorico(){
  try{
    const resp = await fetch(window.location.origin+"/historico-prec");
    const data = await resp.json();
    _histData = data.historico || [];
    _histCarregado = true;
  }catch(e){
    console.warn("Erro ao carregar histórico do MongoDB:", e.message);
    _histData = [];
  }
}

async function salvarHistoricoLocal(){
  try{
    await fetch(window.location.origin+"/historico-prec", {
      method:"POST",
      headers:{"Content-Type":"application/json"},
      body:JSON.stringify({historico: _histData})
    });
  }catch(e){
    console.warn("Erro ao salvar histórico no MongoDB:", e.message);
  }
}

async function registrarNoPrecificado(){
  if(!rows.length || !activeNF) return;
  let tPc=0,tPf=0,tPl=0,tPp=0;
  const itens = rows.map(r=>{
    const{ipi,frete,pf,pl,pp}=calcRow(r);
    tPc+=r.pc*r.q; tPf+=pf*r.q; tPl+=pl*r.q; tPp+=pp*r.q;
    return{sku:r.sku,desc:r.desc,pc:r.pc,ipi,frete,pf,pl,pp,q:r.q};
  });
  const cat=document.getElementById("g-categoria")?.value||"moveis";
  const registro = {
    id: Date.now(),
    nf: activeNF.numero||"—",
    fornecedor: activeNF.nome_contato||activeNF.nome||"—",
    dataEmissao: activeNF.data_emissao||"—",
    dataPrecificacao: new Date().toLocaleString("pt-BR"),
    categoria: cat,
    totais:{pc:tPc,pf:tPf,pl:tPl,pp:tPp},
    itens
  };
  // Remove duplicata da mesma NF se existir
  _histData = _histData.filter(h=>h.nf!==registro.nf);
  _histData.unshift(registro); // mais recente primeiro
  if(_histData.length>200) _histData = _histData.slice(0,200);
  await salvarHistoricoLocal();
  dbg("Registrado no histórico: NF "+registro.nf,"ok");
}

function filtrarHistorico(v){ _histFiltro=v.toLowerCase(); renderHistorico(); }

async function renderHistorico(){
  await carregarHistorico();
  const el = document.getElementById("hist-list");
  if(!el) return;
  const lista = _histFiltro
    ? _histData.filter(h=>h.nf.toLowerCase().includes(_histFiltro)||h.fornecedor.toLowerCase().includes(_histFiltro))
    : _histData;
  document.getElementById("hist-count").textContent = lista.length+" registro"+(lista.length!==1?"s":"");
  if(!lista.length){
    el.innerHTML=`<div class="hist-empty"><div class="big">🗂</div><p>${_histFiltro?"Nenhum resultado encontrado.":"Nenhuma NF precificada ainda.<br>Gere um PDF para registrar aqui."}</p></div>`;
    return;
  }
  el.innerHTML="";
  lista.forEach(h=>{
    const card=document.createElement("div");
    card.className="hist-card"+(h.conferido?' is-conferido':'');
    const catLabel=h.categoria==="eletro"?"Eletro":"Móveis";
    card.innerHTML=`
      <div class="hist-card-icon">📋</div>
      <div class="hist-card-body">
        <div class="hist-card-top">
          <span class="hist-card-nf">NF ${h.nf}</span>
          <span class="hist-card-cat">${catLabel}</span>
          ${h.conferido ? `<span class="hist-conferido-badge">✓ Conferido</span>` : ""}
        </div>
        <div class="hist-card-emit">${h.fornecedor}</div>
        <div class="hist-card-meta">
          <span>Emissão: ${h.dataEmissao}</span>
          <span>Precificado: ${h.dataPrecificacao}</span>
          <span>${h.itens.length} produto(s)</span>
        </div>
        <div class="hist-card-vals">
          <span class="hist-val pf">PF total: R$ ${fmt(h.totais.pf)}</span>
          <span class="hist-val pl">PL total: R$ ${fmt(h.totais.pl)}</span>
          <span class="hist-val pp">PP total: R$ ${fmt(h.totais.pp)}</span>
        </div>
      </div>
      <div class="hist-card-actions">
        <button class="hist-btn" onclick="event.stopPropagation();verHistorico(${h.id})">👁 Ver</button>
        ${h.conferido
          ? `<button class="hist-btn conferido" disabled>✓ Conferido</button>`
          : `<button class="hist-btn" onclick="event.stopPropagation();pedirSenha('conferir',${h.id})" style="color:var(--teal)">✓ Conferir</button>`
        }
        <button class="hist-btn danger" onclick="event.stopPropagation();pedirSenha('excluir',${h.id})">🗑 Excluir</button>
      </div>`;
    card.onclick=()=>verHistorico(h.id);
    el.appendChild(card);
  });
}

function verHistorico(id){
  const h = _histData.find(x=>x.id===id);
  if(!h) return;
  document.getElementById("histModalTitle").textContent = "NF "+h.nf+" — "+h.fornecedor;
  const body = document.getElementById("histModalBody");
  const catLabel=h.categoria==="eletro"?"Eletro (×1,45×1,50)":"Móveis (×1,50×1,55)";
  body.innerHTML=`
    <div class="hist-modal-info">
      <div class="hist-info-card"><div class="lbl">Nota Fiscal</div><div class="val" style="color:var(--accent)">NF ${h.nf}</div></div>
      <div class="hist-info-card"><div class="lbl">Fornecedor</div><div class="val">${h.fornecedor}</div></div>
      <div class="hist-info-card"><div class="lbl">Data Emissão</div><div class="val">${h.dataEmissao}</div></div>
      <div class="hist-info-card"><div class="lbl">Precificado em</div><div class="val">${h.dataPrecificacao}</div></div>
      <div class="hist-info-card"><div class="lbl">Categoria</div><div class="val">${catLabel}</div></div>
      <div class="hist-info-card"><div class="lbl">Produtos</div><div class="val">${h.itens.length}</div></div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:20px;">
      <div class="hist-info-card"><div class="lbl">Total PC</div><div class="val">R$ ${fmt(h.totais.pc)}</div></div>
      <div class="hist-info-card"><div class="lbl">Total PF</div><div class="val" style="color:var(--amber)">R$ ${fmt(h.totais.pf)}</div></div>
      <div class="hist-info-card"><div class="lbl">Total PP</div><div class="val" style="color:var(--accent)">R$ ${fmt(h.totais.pp)}</div></div>
      <div class="hist-info-card"><div class="lbl">Total PL</div><div class="val" style="color:var(--teal)">R$ ${fmt(h.totais.pl)}</div></div>
    </div>
    <table class="hist-modal-table">
      <thead><tr>
        <th>SKU</th><th>Descrição</th>
        <th class="r">IPI%</th><th class="r">Frete%</th>
        <th class="r">PC</th><th class="r">PF</th>
        <th class="r" style="color:var(--accent)">PP</th>
        <th class="r" style="color:var(--teal)">PL</th>
        <th class="r">Qtde</th>
      </tr></thead>
      <tbody>
        ${h.itens.map(i=>`<tr>
          <td style="font-family:var(--mono);color:var(--accent)">${i.sku}</td>
          <td style="max-width:200px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="${i.desc}">${i.desc}</td>
          <td class="r">${fmt(i.ipi)}%</td>
          <td class="r">${fmt(i.frete)}%</td>
          <td class="r">R$ ${fmt(i.pc)}</td>
          <td class="r" style="color:var(--amber)">R$ ${fmt(i.pf)}</td>
          <td class="r" style="color:var(--accent)">R$ ${fmt(i.pp)}</td>
          <td class="r" style="color:var(--teal)">R$ ${fmt(i.pl)}</td>
          <td class="r">${i.q}</td>
        </tr>`).join("")}
      </tbody>
    </table>`;
  document.getElementById("histModal").classList.add("open");
}

function fecharHistModal(){
  document.getElementById("histModal").classList.remove("open");
}

const SENHA_HIST = "3003";
let _senhaAcao = null; // {tipo: 'conferir'|'excluir', id}

function pedirSenha(tipo, id){
  _senhaAcao = {tipo, id};
  const modal = document.getElementById("senhaModal");
  const titulo = document.getElementById("senhaTitulo");
  const desc = document.getElementById("senhaDesc");
  const inp = document.getElementById("senhaInput");
  const erro = document.getElementById("senhaErro");
  titulo.textContent = tipo==="conferir" ? "🔐 Confirmar Conferência" : "🔐 Confirmar Exclusão";
  desc.textContent = tipo==="conferir"
    ? "Digite a senha para marcar esta NF como conferida."
    : "Digite a senha para excluir este registro do histórico.";
  inp.value = "";
  erro.style.display = "none";
  modal.classList.add("open");
  setTimeout(()=>inp.focus(), 100);
}

async function confirmarSenha(){
  const inp = document.getElementById("senhaInput");
  const erro = document.getElementById("senhaErro");
  if(inp.value !== SENHA_HIST){
    erro.style.display = "block";
    inp.value = "";
    inp.focus();
    return;
  }
  fecharSenhaModal();
  if(!_senhaAcao) return;
  if(_senhaAcao.tipo === "conferir"){
    const h = _histData.find(x=>x.id===_senhaAcao.id);
    if(h){ h.conferido = true; h.dataConferido = new Date().toLocaleString("pt-BR"); }
    await salvarHistoricoLocal();
    await renderHistorico();
    toast("NF marcada como conferida! ✓","ok");
  } else {
    _histData = _histData.filter(h=>h.id!==_senhaAcao.id);
    await salvarHistoricoLocal();
    await renderHistorico();
    fecharHistModal();
    toast("Registro excluído","ok");
  }
  _senhaAcao = null;
}

function fecharSenhaModal(){
  document.getElementById("senhaModal").classList.remove("open");
  document.getElementById("senhaErro").style.display = "none";
}

// Enter confirma senha
document.addEventListener("keydown", e=>{
  if(e.key==="Enter" && document.getElementById("senhaModal").classList.contains("open")){
    confirmarSenha();
  }
  if(e.key==="Escape" && document.getElementById("senhaModal").classList.contains("open")){
    fecharSenhaModal();
  }
});

// Fecha modal ao clicar fora
document.getElementById("histModal").addEventListener("click",function(e){
  if(e.target===this) fecharHistModal();
});
document.getElementById("senhaModal").addEventListener("click",function(e){
  if(e.target===this) fecharSenhaModal();
});

// Carrega histórico ao iniciar
carregarHistorico();

// Auto-conecta ao carregar (proxy usa TINY_TOKEN do .env do VPS)
conectar();

/* ═══════════════════════════════════════════════════════════════
   EMISSÃO MASSIVA NF — lê planilha XLSX, cadastra cliente,
   cria pedido, gera NF (pendente). Tudo via API V2 do Tiny.
   ═══════════════════════════════════════════════════════════════ */

// Token vazio — proxy usa o TINY_TOKEN do .env do VPS automaticamente
const EM_TOKEN_TINY = "";
const EM_FORMA_ENVIO = "Envio  Próprio Caús";  // 2 espaços + acentos
const EM_FRETE_POR_CONTA = "3";                  // Transporte Próprio do Remetente
const EM_FORMA_PAGAMENTO = "Dinheiro";
const EM_DESCONTO_PERC = 40;                     // 40% off do preço Tiny
const EM_DELAY_MS = 400;                         // delay entre chamadas pra respeitar rate limit

// Colunas esperadas na planilha (na ordem)
const EM_COLUNAS = [
  "CPF/CNPJ", "Nome/Razão Social", "Telefone", "Email",
  "Nº Pedido", "CEP", "Endereço", "Número", "Complemento",
  "Bairro", "Cidade", "UF", "SKU", "Quantidade"
];
const EM_OBRIGATORIAS = [
  "CPF/CNPJ", "Nome/Razão Social", "Nº Pedido", "CEP",
  "Endereço", "Número", "Bairro", "Cidade", "UF",
  "SKU", "Quantidade"
];

// Estado da aba
let _emArquivo = null;
let _emLinhas = [];          // [{linha, dados, erros}, ...]
let _emGruposCpf = {};       // { cpf: [linha1, linha2, ...] }
let _emCancelar = false;
let _emRelatorio = [];       // [{numero_pedido, cliente, status, ...}]

/* ──────────── UTILS ──────────── */

function emSleep(ms){ return new Promise(r => setTimeout(r, ms)); }

// Limpa CPF/CNPJ (só dígitos)
function emLimparDoc(d){
  return String(d || "").replace(/[^\d]/g, "");
}

// Valida CPF (algoritmo do dígito verificador)
function emValidarCPF(cpf){
  cpf = emLimparDoc(cpf);
  if(cpf.length !== 11) return false;
  if(/^(\d)\1+$/.test(cpf)) return false; // todos iguais
  let s = 0;
  for(let i=0; i<9; i++) s += parseInt(cpf[i]) * (10-i);
  let r = (s * 10) % 11;
  if(r === 10) r = 0;
  if(r !== parseInt(cpf[9])) return false;
  s = 0;
  for(let i=0; i<10; i++) s += parseInt(cpf[i]) * (11-i);
  r = (s * 10) % 11;
  if(r === 10) r = 0;
  return r === parseInt(cpf[10]);
}

// Valida CNPJ (algoritmo do dígito verificador)
function emValidarCNPJ(cnpj){
  cnpj = emLimparDoc(cnpj);
  if(cnpj.length !== 14) return false;
  if(/^(\d)\1+$/.test(cnpj)) return false;
  let s = 0;
  const p1 = [5,4,3,2,9,8,7,6,5,4,3,2];
  for(let i=0; i<12; i++) s += parseInt(cnpj[i]) * p1[i];
  let r = s % 11;
  r = r < 2 ? 0 : 11 - r;
  if(r !== parseInt(cnpj[12])) return false;
  s = 0;
  const p2 = [6,5,4,3,2,9,8,7,6,5,4,3,2];
  for(let i=0; i<13; i++) s += parseInt(cnpj[i]) * p2[i];
  r = s % 11;
  r = r < 2 ? 0 : 11 - r;
  return r === parseInt(cnpj[13]);
}

// Valida documento (CPF ou CNPJ pelo tamanho)
function emValidarDoc(doc){
  const d = emLimparDoc(doc);
  if(d.length === 11) return emValidarCPF(d);
  if(d.length === 14) return emValidarCNPJ(d);
  return false;
}

// Tipo de pessoa pelo tamanho do documento
function emTipoPessoa(doc){
  return emLimparDoc(doc).length === 14 ? "J" : "F";
}

// Chamada pra API do Tiny (proxy)
async function emChamarTiny(action, params){
  const resp = await fetch("/tiny-api", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ action, token: EM_TOKEN_TINY, params })
  });
  if(!resp.ok) throw new Error(`HTTP ${resp.status}`);
  return await resp.json();
}

/* ──────────── BAIXAR MODELO ──────────── */

function emBaixarModelo(){
  // Cria planilha modelo do zero usando SheetJS
  const wb = XLSX.utils.book_new();
  const ws_data = [
    EM_COLUNAS,
    ["12345678900", "JOÃO DA SILVA SANTOS", "27999998888", "joao@email.com",
     "00001", "29730000", "Rua das Flores", "123", "Apto 5",
     "Centro", "Baixo Guandu", "ES", "2391", 1],
    ["12345678900", "JOÃO DA SILVA SANTOS", "27999998888", "joao@email.com",
     "00001", "29730000", "Rua das Flores", "123", "Apto 5",
     "Centro", "Baixo Guandu", "ES", "2298", 2],
    ["98765432100", "MARIA OLIVEIRA", "27988887777", "",
     "00002", "29730500", "Av Brasil", "456", "",
     "São Pedro", "Baixo Guandu", "ES", "1081", 1]
  ];
  const ws = XLSX.utils.aoa_to_sheet(ws_data);
  ws["!cols"] = EM_COLUNAS.map((c, i) => ({ wch: [16,30,16,26,14,12,26,10,16,18,22,6,10,12][i] || 14 }));

  // Força as células EXISTENTES de colunas com possíveis zeros à esquerda como TEXTO.
  // Senão o Excel remove o "0" inicial automaticamente (ex: "00001" vira 1).
  // Colunas (índice 0): A=CPF/CNPJ, C=Telefone, E=Nº Pedido, F=CEP, M=SKU
  // Aplicamos só nas células que JÁ existem (linhas 2-4 dos exemplos) — o usuário
  // que quiser preservar zero à esquerda em linhas novas precisa formatar a coluna
  // como Texto manualmente, OU prefixar com apóstrofo (').
  const colsTexto = ["A", "C", "E", "F", "M"];
  const linhasComDados = ws_data.length; // 4 (header + 3 exemplos)
  for(const col of colsTexto){
    for(let row = 2; row <= linhasComDados; row++){
      const ref = col + row;
      if(ws[ref]){
        ws[ref].t = "s";
        ws[ref].z = "@";
      }
    }
  }

  XLSX.utils.book_append_sheet(wb, ws, "Emissão NF");

  // Aba de instruções
  const ins_data = [
    ["📋 COMO USAR ESTA PLANILHA"],
    [""],
    ["1. Apague as linhas de exemplo (linhas 2, 3 e 4)"],
    ["2. Preencha os dados dos clientes (uma linha por SKU)"],
    ["3. Salve o arquivo"],
    ["4. Volte ao sistema → aba Emissão Massiva NF → upload"],
    [""],
    ["📌 REGRAS DE AGRUPAMENTO"],
    [""],
    ["• Cada linha = 1 SKU de 1 cliente"],
    ["• Mesmo CPF/CNPJ em várias linhas → agrupado em 1 NF"],
    ["• Quando agrupar, usa o Nº Pedido da PRIMEIRA linha do grupo"],
    [""],
    ["⚠️  ZEROS À ESQUERDA (Nº Pedido como '00001')"],
    [""],
    ["O Excel REMOVE zeros à esquerda automaticamente. Pra preservar:"],
    ["  Opção 1: Antes de digitar, selecione a coluna E (Nº Pedido)"],
    ["          → Botão direito → Formatar células → Texto → OK"],
    ["  Opção 2: Digite com apóstrofo na frente: '00001"],
    ["          (o apóstrofo não aparece, só força o texto)"],
    [""],
    ["⚙️  CONFIGURAÇÕES FIXAS DA NF"],
    [""],
    ["• Forma de envio: Envio Próprio Caús"],
    ["• Frete por conta: Transporte Próprio do Remetente"],
    ["• Forma de pagamento: Dinheiro"],
    ["• Valor unitário: preço de cadastro do Tiny − 40%"],
    [""],
    ["🚦 STATUS DA NF"],
    [""],
    ["NFs ficam PENDENTES — você autoriza no SEFAZ manualmente"],
    [""],
    ["📝 COLUNAS OBRIGATÓRIAS"],
    [EM_OBRIGATORIAS.join(", ")],
    [""],
    ["📝 COLUNAS OPCIONAIS"],
    ["Telefone, Email, Complemento"]
  ];
  const ws_ins = XLSX.utils.aoa_to_sheet(ins_data);
  ws_ins["!cols"] = [{ wch: 100 }];
  XLSX.utils.book_append_sheet(wb, ws_ins, "Instruções");

  XLSX.writeFile(wb, "modelo-emissao-nf.xlsx");
  toast("Modelo baixado!");
}

/* ──────────── UPLOAD E LEITURA ──────────── */

function emDragOver(e){
  e.preventDefault();
  document.getElementById("emDropArea").classList.add("over");
}

function emDragLeave(e){
  document.getElementById("emDropArea").classList.remove("over");
}

function emDrop(e){
  e.preventDefault();
  document.getElementById("emDropArea").classList.remove("over");
  const f = e.dataTransfer.files[0];
  if(f) emLerArquivo(f);
}

function emFileChange(e){
  const f = e.target.files[0];
  if(f) emLerArquivo(f);
  e.target.value = ""; // permite re-upload do mesmo arquivo
}

function emLerArquivo(file){
  if(!file.name.toLowerCase().endsWith(".xlsx")){
    toast("Use um arquivo .xlsx (Excel)", "err");
    return;
  }
  _emArquivo = file;
  const reader = new FileReader();
  reader.onload = function(e){
    try{
      const data = new Uint8Array(e.target.result);
      const wb = XLSX.read(data, { type: "array" });
      // Pega a primeira aba (assume que é a de dados)
      const ws = wb.Sheets[wb.SheetNames[0]];
      const json = XLSX.utils.sheet_to_json(ws, { defval: "", raw: false });
      emProcessarLinhas(json);
    }catch(err){
      console.error(err);
      toast("Erro ao ler planilha: " + err.message, "err");
    }
  };
  reader.readAsArrayBuffer(file);
}

function emProcessarLinhas(json){
  if(!json || json.length === 0){
    toast("Planilha vazia", "err");
    return;
  }

  // Verifica colunas
  const primeiraLinha = json[0];
  const colunasPlanilha = Object.keys(primeiraLinha);
  const colunasFaltando = EM_COLUNAS.filter(c => !colunasPlanilha.includes(c));
  if(colunasFaltando.length > 0){
    toast(`Faltam colunas: ${colunasFaltando.join(", ")}`, "err");
    return;
  }

  // Valida cada linha
  _emLinhas = [];
  _emGruposCpf = {};
  const errosValidacao = [];

  json.forEach((row, idx) => {
    const numLinha = idx + 2; // linha 1 é header, dados começam na 2
    const erros = [];

    // Validação de campos obrigatórios
    EM_OBRIGATORIAS.forEach(c => {
      const v = String(row[c] || "").trim();
      if(!v) erros.push(`'${c}' vazio`);
    });

    // Validação de CPF/CNPJ
    const doc = emLimparDoc(row["CPF/CNPJ"]);
    if(doc && !emValidarDoc(doc)){
      erros.push(`CPF/CNPJ inválido (${row["CPF/CNPJ"]})`);
    }

    // Validação de quantidade
    const qtd = parseFloat(String(row["Quantidade"]).replace(",","."));
    if(isNaN(qtd) || qtd <= 0){
      erros.push(`Quantidade inválida (${row["Quantidade"]})`);
    }

    // Validação de UF (2 letras)
    const uf = String(row["UF"] || "").trim().toUpperCase();
    if(uf && uf.length !== 2){
      erros.push(`UF deve ter 2 letras (${row["UF"]})`);
    }

    if(erros.length > 0){
      errosValidacao.push(`Linha ${numLinha}: ${erros.join("; ")}`);
    }

    _emLinhas.push({
      linha: numLinha,
      dados: row,
      doc: doc,
      qtd: qtd,
      erros: erros
    });

    // Agrupa por CPF/CNPJ (só se não tiver erro crítico)
    if(doc && erros.filter(e => !e.includes("Quantidade")).length === 0){
      if(!_emGruposCpf[doc]) _emGruposCpf[doc] = [];
      _emGruposCpf[doc].push(_emLinhas[_emLinhas.length - 1]);
    }
  });

  // Mostra info do arquivo
  const totalLinhas = _emLinhas.length;
  const totalLinhasOK = _emLinhas.filter(l => l.erros.length === 0).length;
  const totalGrupos = Object.keys(_emGruposCpf).length;
  const totalNFs = totalGrupos; // 1 NF por CPF único

  document.getElementById("emArquivoNome").textContent = "📊 " + _emArquivo.name;
  document.getElementById("emArquivoStats").innerHTML =
    `<strong>${totalLinhas}</strong> linhas lidas` +
    (totalLinhasOK < totalLinhas ? ` (<span style="color:var(--red);">${totalLinhas - totalLinhasOK} com erro</span>)` : "") +
    ` &middot; <strong>${totalGrupos}</strong> CPFs únicos` +
    ` &middot; <strong>${totalNFs}</strong> NF(s) serão geradas`;
  document.getElementById("emArquivoInfo").style.display = "block";

  // Erros de validação
  const errosEl = document.getElementById("emValidacaoErros");
  if(errosValidacao.length > 0){
    errosEl.innerHTML =
      `<div class="em-erros-titulo">⚠️ ${errosValidacao.length} erro(s) de validação encontrado(s):</div>` +
      `<div class="em-erros-lista">` +
      errosValidacao.map(e => `<span class="l">• ${e}</span>`).join("") +
      `</div>` +
      `<div style="margin-top:10px;font-size:12px;color:var(--muted);">As linhas com erro serão PULADAS no processamento. Você pode prosseguir e ver o relatório no final.</div>`;
    errosEl.style.display = "block";
  } else {
    errosEl.style.display = "none";
  }

  // Habilita botão se houver pelo menos 1 grupo válido
  document.getElementById("emBtnProcessar").disabled = totalGrupos === 0;
  if(totalGrupos === 0){
    toast("Nenhuma linha válida pra processar", "err");
  }
}

function emResetar(){
  _emArquivo = null;
  _emLinhas = [];
  _emGruposCpf = {};
  _emCancelar = false;
  _emRelatorio = [];
  document.getElementById("emArquivoInfo").style.display = "none";
  document.getElementById("emValidacaoErros").style.display = "none";
  document.getElementById("emSection1").style.display = "block";
  document.getElementById("emSection2").style.display = "none";
  document.getElementById("emSection3").style.display = "none";
  document.getElementById("emProgFill").style.width = "0%";
  document.getElementById("emProgFill").textContent = "0%";
  document.getElementById("emProgLog").innerHTML = "";
}

/* ──────────── PROCESSAMENTO ──────────── */

function emCancelar(){
  if(!confirm("Cancelar o processamento? As NFs já criadas continuarão.")) return;
  _emCancelar = true;
  emAddLog("🛑 Cancelamento solicitado…", "wrn");
}

function emAddLog(msg, tipo=""){
  const el = document.getElementById("emProgLog");
  const linha = document.createElement("div");
  linha.className = tipo;
  linha.textContent = `[${new Date().toLocaleTimeString("pt-BR")}] ${msg}`;
  el.appendChild(linha);
  el.scrollTop = el.scrollHeight;
}

function emAtualizarProgresso(atual, total){
  const pct = total === 0 ? 0 : Math.round((atual / total) * 100);
  const fill = document.getElementById("emProgFill");
  fill.style.width = pct + "%";
  fill.textContent = pct + "%";
}

async function emProcessar(){
  // Filtra grupos válidos (cada grupo = 1 NF)
  const grupos = Object.entries(_emGruposCpf);
  if(grupos.length === 0){
    toast("Nenhum grupo válido pra processar", "err");
    return;
  }

  // Esconde etapa 1, mostra etapa 2
  document.getElementById("emSection1").style.display = "none";
  document.getElementById("emSection2").style.display = "block";
  document.getElementById("emSection3").style.display = "none";
  document.getElementById("emProgLog").innerHTML = "";
  _emCancelar = false;
  _emRelatorio = [];

  emAddLog(`📋 Iniciando processamento de ${grupos.length} NF(s)…`, "info");

  let processados = 0;
  for(const [cpf, linhas] of grupos){
    if(_emCancelar){
      emAddLog("⏹ Processamento cancelado pelo usuário.", "wrn");
      break;
    }

    processados++;
    emAtualizarProgresso(processados - 1, grupos.length);

    const primeira = linhas[0];
    const dados = primeira.dados;
    const numPedido = String(dados["Nº Pedido"] || "").trim();
    const nomeCliente = String(dados["Nome/Razão Social"] || "").trim();

    document.getElementById("emProgTxt").textContent =
      `Processando ${processados}/${grupos.length}: ${nomeCliente} (${linhas.length} item(ns))`;

    try{
      // PASSO 1: Pesquisa cliente por CPF/CNPJ
      emAddLog(`🔍 Cliente "${nomeCliente}" (${cpf}) — pesquisando…`, "info");
      let idCliente = null;

      try{
        const respPesq = await emChamarTiny("cliente_pesquisa", { cpf_cnpj: cpf });
        const ret = respPesq.retorno || {};
        if(ret.status === "OK" && Array.isArray(ret.contatos) && ret.contatos.length > 0){
          // Pega o primeiro com CPF/CNPJ que bate (compara só dígitos)
          for(const c of ret.contatos){
            const docCadastrado = emLimparDoc(c.contato?.cpf_cnpj || "");
            if(docCadastrado === cpf){
              idCliente = c.contato.id;
              break;
            }
          }
        }
      }catch(e){
        // Erro na pesquisa — não é crítico, vamos tentar criar mesmo
      }

      // PASSO 2: Cria cliente se não existe
      if(idCliente){
        emAddLog(`  ✓ Cliente já cadastrado (id ${idCliente})`, "ok");
      } else {
        emAddLog(`  → Cadastrando cliente novo…`, "info");
        await emSleep(EM_DELAY_MS);

        const novoCliente = {
          contatos: [{
            contato: {
              sequencia: "1",
              nome: nomeCliente,
              tipo_pessoa: emTipoPessoa(cpf),
              cpf_cnpj: cpf,
              situacao: "A",
              endereco: String(dados["Endereço"] || "").trim(),
              numero: String(dados["Número"] || "").trim(),
              complemento: String(dados["Complemento"] || "").trim(),
              bairro: String(dados["Bairro"] || "").trim(),
              cep: emLimparDoc(dados["CEP"]),
              cidade: String(dados["Cidade"] || "").trim(),
              uf: String(dados["UF"] || "").trim().toUpperCase(),
              fone: String(dados["Telefone"] || "").trim(),
              email: String(dados["Email"] || "").trim()
            }
          }]
        };

        const respInc = await emChamarTiny("cliente_incluir", {
          contato: JSON.stringify(novoCliente)
        });

        const retInc = respInc.retorno || {};
        const reg = retInc.registros?.[0]?.registro || retInc.registros?.registro;

        if(reg && reg.id){
          idCliente = reg.id;
          emAddLog(`  ✓ Cliente cadastrado (id ${idCliente})`, "ok");
        } else if(reg && reg.codigo_erro === "30"){
          // Duplicado — busca de novo
          emAddLog(`  ⚠ Duplicidade detectada — buscando…`, "wrn");
          await emSleep(EM_DELAY_MS);
          const respPesq2 = await emChamarTiny("cliente_pesquisa", { cpf_cnpj: cpf });
          const ret2 = respPesq2.retorno || {};
          if(ret2.status === "OK" && ret2.contatos?.[0]?.contato?.id){
            idCliente = ret2.contatos[0].contato.id;
            emAddLog(`  ✓ Encontrado (id ${idCliente})`, "ok");
          } else {
            throw new Error("Cliente duplicado mas não foi encontrado na pesquisa");
          }
        } else {
          const erros = (reg?.erros || []).map(e => e.erro || e).join("; ");
          throw new Error("Falha ao cadastrar cliente: " + (erros || "erro desconhecido"));
        }
      }

      // PASSO 3: Busca preço dos SKUs
      await emSleep(EM_DELAY_MS);
      const itens = [];
      let erroSku = null;
      for(const li of linhas){
        const sku = String(li.dados["SKU"] || "").trim();
        const qtd = li.qtd;

        emAddLog(`  → Consultando SKU ${sku}…`, "info");
        const respProd = await emChamarTiny("pesquisar_produto", { pesquisa: sku });
        const retProd = respProd.retorno || {};
        let prod = null;
        if(Array.isArray(retProd.produtos)){
          for(const p of retProd.produtos){
            if(String(p?.produto?.codigo || "").trim() === sku){
              prod = p.produto;
              break;
            }
          }
        }
        if(!prod){
          erroSku = `SKU ${sku} não encontrado no Tiny`;
          break;
        }

        const precoTiny = parseFloat(prod.preco) || 0;
        const precoFinal = precoTiny * (1 - EM_DESCONTO_PERC / 100);
        const descricao = String(prod.nome || `Produto ${sku}`).toUpperCase();
        const unidade = String(prod.unidade || "UN").trim();

        itens.push({
          item: {
            codigo: sku,
            descricao: descricao,
            unidade: unidade,
            quantidade: String(qtd),
            valor_unitario: precoFinal.toFixed(2)
          }
        });
        emAddLog(`    ✓ ${sku} qtd ${qtd} R$ ${precoFinal.toFixed(2)} (R$ ${precoTiny.toFixed(2)} − ${EM_DESCONTO_PERC}%)`, "ok");
        await emSleep(EM_DELAY_MS);
      }

      if(erroSku){
        emAddLog(`  ✗ ${erroSku}`, "err");
        _emRelatorio.push({
          numero_pedido: numPedido,
          cliente: nomeCliente,
          cpf: cpf,
          status: "erro",
          mensagem: erroSku
        });
        continue;
      }

      // PASSO 4: Cria pedido
      emAddLog(`  → Criando pedido (Nº ${numPedido})…`, "info");
      const pedidoPayload = {
        pedido: {
          cliente: {
            codigo: "",
            nome: nomeCliente,
            tipo_pessoa: emTipoPessoa(cpf),
            cpf_cnpj: cpf,
            // Endereço completo do cliente (também usado como endereço de entrega
            // do pedido — sem isso o pedido fica sem endereço de entrega)
            endereco: String(dados["Endereço"] || "").trim(),
            numero: String(dados["Número"] || "").trim(),
            complemento: String(dados["Complemento"] || "").trim(),
            bairro: String(dados["Bairro"] || "").trim(),
            cep: emLimparDoc(dados["CEP"]),
            cidade: String(dados["Cidade"] || "").trim(),
            uf: String(dados["UF"] || "").trim().toUpperCase(),
            fone: String(dados["Telefone"] || "").trim(),
            email: String(dados["Email"] || "").trim()
          },
          itens: itens,
          numero_pedido_ecommerce: numPedido,
          forma_envio: EM_FORMA_ENVIO,
          frete_por_conta: EM_FRETE_POR_CONTA,
          forma_pagamento: EM_FORMA_PAGAMENTO
        }
      };

      const respPed = await emChamarTiny("pedido_incluir", {
        pedido: JSON.stringify(pedidoPayload)
      });
      const retPed = respPed.retorno || {};
      const regPed = retPed.registros?.[0]?.registro || retPed.registros?.registro;

      if(!regPed || !regPed.id){
        const erros = (regPed?.erros || retPed.erros || []).map(e => e.erro || e).join("; ");
        throw new Error("Falha ao criar pedido: " + (erros || "erro desconhecido"));
      }

      const idPedido = regPed.id;
      const numPedidoTiny = regPed.numero;
      emAddLog(`  ✓ Pedido criado (id ${idPedido}, nº ${numPedidoTiny})`, "ok");

      // PASSO 5: Gera NF do pedido
      await emSleep(EM_DELAY_MS);
      emAddLog(`  → Gerando NF…`, "info");
      const respNF = await emChamarTiny("gerar_nota_fiscal_pedido", { id: idPedido });
      const retNF = respNF.retorno || {};
      const regNF = retNF.registros?.[0]?.registro || retNF.registros?.registro;

      if(regNF && regNF.idNotaFiscal){
        emAddLog(`  ✓ NF gerada (id ${regNF.idNotaFiscal}, nº ${regNF.numero})`, "ok");
        _emRelatorio.push({
          numero_pedido: numPedido,
          cliente: nomeCliente,
          cpf: cpf,
          id_cliente: idCliente,
          id_pedido: idPedido,
          numero_pedido_tiny: numPedidoTiny,
          id_nf: regNF.idNotaFiscal,
          numero_nf: regNF.numero,
          status: "ok",
          mensagem: "NF gerada (pendente de autorização)"
        });
      } else {
        const erros = (regNF?.erros || retNF.erros || []).map(e => e.erro || e).join("; ");
        emAddLog(`  ⚠ Pedido criado mas NF falhou: ${erros}`, "wrn");
        _emRelatorio.push({
          numero_pedido: numPedido,
          cliente: nomeCliente,
          cpf: cpf,
          id_pedido: idPedido,
          numero_pedido_tiny: numPedidoTiny,
          status: "warn",
          mensagem: "Pedido OK, NF falhou: " + (erros || "erro desconhecido")
        });
      }
    }catch(err){
      emAddLog(`  ✗ Erro: ${err.message}`, "err");
      _emRelatorio.push({
        numero_pedido: numPedido,
        cliente: nomeCliente,
        cpf: cpf,
        status: "erro",
        mensagem: err.message
      });
    }

    await emSleep(EM_DELAY_MS);
  }

  emAtualizarProgresso(grupos.length, grupos.length);

  // Linhas com erro de validação que foram puladas
  const linhasInvalidas = _emLinhas.filter(l => l.erros.length > 0);
  for(const li of linhasInvalidas){
    _emRelatorio.push({
      numero_pedido: String(li.dados["Nº Pedido"] || "").trim() || `(linha ${li.linha})`,
      cliente: String(li.dados["Nome/Razão Social"] || "").trim() || "(sem nome)",
      cpf: li.doc || "",
      status: "skip",
      mensagem: "Linha pulada: " + li.erros.join("; ")
    });
  }

  emAddLog(`\n✅ Processamento concluído.`, "info");
  emMostrarRelatorio();
}

/* ──────────── RELATÓRIO ──────────── */

function emMostrarRelatorio(){
  document.getElementById("emSection2").style.display = "none";
  document.getElementById("emSection3").style.display = "block";

  const total = _emRelatorio.length;
  const ok = _emRelatorio.filter(r => r.status === "ok").length;
  const warn = _emRelatorio.filter(r => r.status === "warn").length;
  const err = _emRelatorio.filter(r => r.status === "erro").length;
  const skip = _emRelatorio.filter(r => r.status === "skip").length;

  // Resumo cards
  document.getElementById("emRelResumo").innerHTML = `
    <div class="em-rel-box ok">
      <div class="em-rel-num">${ok}</div>
      <div class="em-rel-lbl">NFs geradas</div>
    </div>
    ${warn > 0 ? `<div class="em-rel-box wrn">
      <div class="em-rel-num">${warn}</div>
      <div class="em-rel-lbl">Pedido OK, NF falhou</div>
    </div>` : ""}
    ${err > 0 ? `<div class="em-rel-box err">
      <div class="em-rel-num">${err}</div>
      <div class="em-rel-lbl">Erros</div>
    </div>` : ""}
    ${skip > 0 ? `<div class="em-rel-box wrn">
      <div class="em-rel-num">${skip}</div>
      <div class="em-rel-lbl">Linhas puladas</div>
    </div>` : ""}
    <div class="em-rel-box">
      <div class="em-rel-num">${total}</div>
      <div class="em-rel-lbl">Total</div>
    </div>
  `;

  // Tabela detalhada
  let html = `<table class="em-rel-tabela"><thead><tr>
    <th>Status</th><th>Nº Pedido</th><th>Cliente</th>
    <th>NF Tiny</th><th>Mensagem</th>
  </tr></thead><tbody>`;
  for(const r of _emRelatorio){
    const cls = r.status === "ok" ? "ok" : r.status === "warn" ? "wrn" : "err";
    const lbl = r.status === "ok" ? "✓ Sucesso" :
                r.status === "warn" ? "⚠ Parcial" :
                r.status === "skip" ? "⏭ Pulado" : "✗ Erro";
    html += `<tr>
      <td><span class="em-rel-status ${cls}">${lbl}</span></td>
      <td>${escEm(r.numero_pedido)}</td>
      <td>${escEm(r.cliente)}</td>
      <td>${r.numero_nf ? escEm(r.numero_nf) : "—"}</td>
      <td>${escEm(r.mensagem)}</td>
    </tr>`;
  }
  html += "</tbody></table>";
  document.getElementById("emRelDetalhes").innerHTML = html;
}

function emExportarRelatorio(){
  if(_emRelatorio.length === 0){ toast("Nada pra exportar", "err"); return; }
  const linhas = [
    ["Status","Nº Pedido","Cliente","CPF/CNPJ","ID Cliente","ID Pedido","Nº Pedido Tiny","ID NF","Nº NF","Mensagem"]
  ];
  for(const r of _emRelatorio){
    linhas.push([
      r.status, r.numero_pedido || "", r.cliente || "", r.cpf || "",
      r.id_cliente || "", r.id_pedido || "", r.numero_pedido_tiny || "",
      r.id_nf || "", r.numero_nf || "", r.mensagem || ""
    ]);
  }
  const csv = "\uFEFF" + linhas.map(l => l.map(c => `"${String(c).replace(/"/g,'""')}"`).join(";")).join("\n");
  const blob = new Blob([csv], { type: "text/csv;charset=utf-8" });
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  a.href = url;
  a.download = `relatorio-emissao-${new Date().toISOString().slice(0,10)}.csv`;
  a.click();
  URL.revokeObjectURL(url);
  toast("Relatório exportado!");
}

function escEm(s){
  if(s === null || s === undefined) return "";
  return String(s)
    .replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;")
    .replace(/"/g,"&quot;").replace(/'/g,"&#039;");
}

</script>
</body>
</html>
